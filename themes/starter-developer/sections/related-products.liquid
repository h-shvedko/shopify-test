{%- liquid
  assign section_heading = section.settings.heading | default: 'products.you_may_also_like' | t
-%}

{% stylesheet %}
  .related-products {
    padding: 64px 0;
    background: var(--color-bg-alt);
  }

  .related-products__container {
    max-width: var(--page-width, 1280px);
    margin: 0 auto;
    padding: 0 20px;
  }

  .related-products__header {
    margin-bottom: 36px;
  }

  .related-products__heading {
    font-family: var(--font-heading, 'Space Grotesk', sans-serif);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }

  .related-products__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 640px) {
    .related-products__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .related-products__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .related-products__empty {
    color: var(--color-text-muted);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.85rem;
  }
{% endstylesheet %}

<section
  class="related-products"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-products-count="{{ section.settings.products_count }}"
>
  <div class="related-products__container">
    <div class="related-products__header">
      <h2 class="related-products__heading">{{ section_heading }}</h2>
    </div>
    <div class="related-products__grid" id="RelatedProductsGrid-{{ section.id }}">
      {%- comment -%}
        Recommendations are loaded via JS using the Product Recommendations API.
        A static fallback renders nothing until JS populates the grid.
      {%- endcomment -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    var productId = section.dataset.productId;
    var productsCount = parseInt(section.dataset.productsCount, 10) || 4;
    var grid = document.getElementById('RelatedProductsGrid-{{ section.id }}');
    if (!grid || !productId) return;

    var url = '/recommendations/products.json?product_id=' + productId + '&limit=' + productsCount;

    fetch(url)
      .then(function (res) { return res.json(); })
      .then(function (data) {
        if (!data.products || data.products.length === 0) return;

        var moneyFormat = {{ shop.money_format | json }};

        function formatMoney(cents) {
          var amount = (cents / 100).toFixed(2);
          return moneyFormat
            .replace('{{amount}}', amount)
            .replace('{{amount_no_decimals}}', Math.round(cents / 100))
            .replace('{{amount_with_comma_separator}}', amount.replace('.', ','))
            .replace('{{amount_no_decimals_with_comma_separator}}', Math.round(cents / 100));
        }

        data.products.forEach(function (p) {
          var priceHtml = p.available
            ? '<span class="product-card__price">' + formatMoney(p.price) + '</span>'
            : '<span class="product-card__price">{{ "products.sold_out" | t }}</span>';

          var imgHtml = p.featured_image
            ? '<img src="' + p.featured_image + '" alt="" width="720" height="405" loading="lazy">'
            : '';

          var card = document.createElement('article');
          card.className = 'product-card';
          card.innerHTML =
            '<div class="product-card__image">' +
              '<a href="' + p.url + '" tabindex="-1" aria-hidden="true">' + imgHtml + '</a>' +
            '</div>' +
            '<div class="product-card__body">' +
              (p.product_type ? '<p class="product-card__category">' + p.product_type + '</p>' : '') +
              '<h3 class="product-card__title"><a href="' + p.url + '">' + p.title + '</a></h3>' +
            '</div>' +
            '<div class="product-card__footer">' +
              '<div>' + priceHtml + '</div>' +
              '<a href="' + p.url + '" class="product-card__expand">{{ "products.quick_view" | t }} &rarr;</a>' +
            '</div>';

          grid.appendChild(card);
        });
      })
      .catch(function (err) {
        console.error('Related products error:', err);
      });
  })();
</script>

{% schema %}
{
  "name": "t:sections.related_products.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.related_products.settings.heading.label",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "t:sections.related_products.settings.products_count.label",
      "min": 2,
      "max": 8,
      "step": 2,
      "default": 4
    }
  ],
  "presets": [
    { "name": "Related products" }
  ]
}
{% endschema %}
