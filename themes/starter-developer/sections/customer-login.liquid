{%- liquid
  assign login_title = 'customer.login_title' | t
  assign email_label = 'customer.email' | t
  assign password_label = 'customer.password' | t
  assign submit_label = 'customer.submit_login' | t
-%}

{% stylesheet %}
  .customer-login {
    padding: 80px 20px 120px;
    background: var(--color-bg);
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .customer-login__inner {
    width: 100%;
    max-width: 420px;
  }

  .customer-form__title {
    font-family: var(--font-heading, 'Space Grotesk', sans-serif);
    font-size: clamp(1.4rem, 3vw, 1.75rem);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 28px;
    text-align: center;
  }

  .customer-form {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .customer-form__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .customer-form__label {
    font-size: 0.78rem;
    font-weight: 600;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .customer-form__input {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    font-size: 0.9rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    padding: 12px 14px;
    transition: border-color 0.2s, box-shadow 0.2s;
    width: 100%;
  }

  .customer-form__input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.15);
  }

  .customer-form__input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .customer-form__submit {
    width: 100%;
    padding: 14px;
    background: var(--color-primary);
    color: #0F172A;
    font-weight: 700;
    font-size: 0.9rem;
    font-family: var(--font-heading, 'Space Grotesk', sans-serif);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
  }

  .customer-form__submit:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .customer-form__submit:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  .customer-form__links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-top: 4px;
  }

  .customer-form__link {
    font-size: 0.8rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    color: var(--color-text-muted);
    text-decoration: underline;
    transition: color 0.2s;
  }

  .customer-form__link:hover {
    color: var(--color-primary);
  }

  .customer-form__errors {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 8px;
    padding: 12px 14px;
    font-size: 0.82rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    color: var(--color-error, #EF4444);
  }
{% endstylesheet %}

<section class="customer-login" data-section-id="{{ section.id }}">
  <div class="customer-login__inner">
    <h1 class="customer-form__title">{{ login_title }}</h1>

    {%- if form.errors -%}
      <div class="customer-form__errors" role="alert">
        {{ form.errors | default_errors }}
      </div>
    {%- endif -%}

    {%- form 'customer_login' -%}
      <div class="customer-form">
        <div class="customer-form__field">
          <label class="customer-form__label" for="CustomerEmail">
            {{ email_label }}
          </label>
          <input
            type="email"
            id="CustomerEmail"
            name="customer[email]"
            class="customer-form__input"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            required
          >
        </div>

        <div class="customer-form__field">
          <label class="customer-form__label" for="CustomerPassword">
            {{ password_label }}
          </label>
          <input
            type="password"
            id="CustomerPassword"
            name="customer[password]"
            class="customer-form__input"
            autocomplete="current-password"
            required
          >
        </div>

        <button type="submit" class="customer-form__submit">
          {{ submit_label }}
        </button>

        <div class="customer-form__links">
          <a href="{{ routes.account_recover_url }}" class="customer-form__link">
            {{ 'customer.forgot_password' | t }}
          </a>
          <a href="{{ routes.account_register_url }}" class="customer-form__link">
            {{ 'customer.create_account' | t }}
          </a>
        </div>
      </div>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.customer_login.name",
  "presets": [
    { "name": "Customer login" }
  ]
}
{% endschema %}
