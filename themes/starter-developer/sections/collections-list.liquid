{%- liquid
  assign section_heading = section.settings.heading | default: 'courses.filter_all' | t
-%}

{% stylesheet %}
  .collections-list {
    padding: 48px 0 80px;
    background: var(--color-bg);
  }

  .collections-list__container {
    max-width: var(--page-width, 1280px);
    margin: 0 auto;
    padding: 0 20px;
  }

  .collections-list__heading {
    font-family: var(--font-heading, 'Space Grotesk', sans-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 36px;
  }

  .collections-list__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 640px) {
    .collections-list__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .collections-list__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .collections-list__card {
    display: block;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
  }

  .collections-list__card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 8px 30px rgba(6, 182, 212, 0.15);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .collections-list__card:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .collections-list__image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bg-elevated, #1E293B);
  }

  .collections-list__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s;
  }

  .collections-list__card:hover .collections-list__image img {
    transform: scale(1.04);
  }

  .collections-list__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    padding: 32px;
  }

  .collections-list__body {
    padding: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .collections-list__name {
    font-family: var(--font-heading, 'Space Grotesk', sans-serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    margin: 0;
  }

  .collections-list__count {
    font-size: 0.72rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .collections-list__arrow {
    color: var(--color-primary);
    flex-shrink: 0;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .collections-list__card:hover .collections-list__arrow {
    opacity: 1;
  }
{% endstylesheet %}

<section class="collections-list" data-section-id="{{ section.id }}">
  <div class="collections-list__container">

    {%- if section_heading != blank -%}
      <h1 class="collections-list__heading">{{ section_heading }}</h1>
    {%- endif -%}

    <div class="collections-list__grid">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="collections-list__card">
          <div class="collections-list__image">
            {%- if collection.featured_image -%}
              <img
                src="{{ collection.featured_image | image_url: width: 720 }}"
                alt="{{ collection.featured_image.alt | escape | default: collection.title }}"
                width="720"
                height="405"
                loading="lazy"
              >
            {%- else -%}
              <div class="collections-list__image-placeholder">
                {{ 'collection-1' | placeholder_svg_tag }}
              </div>
            {%- endif -%}
          </div>
          <div class="collections-list__body">
            <div>
              <h2 class="collections-list__name">{{ collection.title }}</h2>
              {%- if collection.products_count > 0 -%}
                <p class="collections-list__count">
                  {{- 'products.showing_count' | t: count: collection.products_count -}}
                </p>
              {%- endif -%}
            </div>
            <span class="collections-list__arrow" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "t:sections.collections_list.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.collections_list.settings.heading.label",
      "default": "All collections"
    }
  ],
  "presets": [
    { "name": "Collections list" }
  ]
}
{% endschema %}
