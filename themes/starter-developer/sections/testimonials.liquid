{% stylesheet %}
  .testimonials {
    background: var(--color-bg);
  }

  .testimonials__header {
    text-align: center;
    margin-bottom: 40px;
  }

  .testimonials__heading {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  /* Testimonial card — rendered by @theme blocks */
  .testimonial-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 28px 24px 24px;
    position: relative;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .testimonial-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 8px 30px rgba(6, 182, 212, 0.1);
  }

  .testimonial-card::before {
    content: '//';
    position: absolute;
    top: 20px;
    right: 20px;
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
    opacity: 0.5;
    letter-spacing: -0.05em;
    line-height: 1;
    pointer-events: none;
  }

  .testimonial-card__quote {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0 0 20px;
    font-style: italic;
  }

  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .testimonial-card__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
  }

  .testimonial-card__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-card__avatar-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-primary);
    background: var(--color-primary-glow);
  }

  .testimonial-card__name {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .testimonial-card__role {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-family: var(--font-body);
    margin: 2px 0 0;
  }

  @media (min-width: 768px) {
    .testimonials__heading {
      font-size: 2.25rem;
    }

    .testimonials__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .testimonials__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
{% endstylesheet %}

<section
  class="testimonials section-padding"
  id="section-{{ section.id }}"
>
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <header class="testimonials__header">
        <h2 class="testimonials__heading">{{ section.settings.heading }}</h2>
      </header>
    {%- endif -%}

    <div class="testimonials__grid" role="list">
      {% content_for 'blocks' %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What devs say"
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    }
  ],
  "presets": [
    {
      "name": "Testimonials"
    }
  ]
}
{% endschema %}
