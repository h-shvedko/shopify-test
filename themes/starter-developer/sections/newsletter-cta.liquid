{% stylesheet %}
  .newsletter-cta {
    background: var(--color-terminal-bg);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .newsletter-cta__bg-image {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .newsletter-cta__bg-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.08;
  }

  .newsletter-cta__glow-1 {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: radial-gradient(
      ellipse 60% 50% at 20% 50%,
      rgba(6, 182, 212, 0.2) 0%,
      transparent 60%
    );
    pointer-events: none;
  }

  .newsletter-cta__glow-2 {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: radial-gradient(
      ellipse 50% 60% at 80% 50%,
      rgba(16, 185, 129, 0.15) 0%,
      transparent 60%
    );
    pointer-events: none;
  }

  .newsletter-cta__inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .newsletter-cta__heading {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 16px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .newsletter-cta__subtitle {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0 0 32px;
  }

  .newsletter-cta__form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 480px;
    margin: 0 auto;
  }

  .newsletter-cta__input {
    flex: 1;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(6, 182, 212, 0.25);
    border-radius: var(--border-radius);
    color: var(--color-text);
    padding: 12px 16px;
    font-size: 0.875rem;
    font-family: var(--font-body);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .newsletter-cta__input::placeholder {
    color: var(--color-text-muted);
  }

  .newsletter-cta__input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.15);
  }

  .newsletter-cta__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 24px;
    background: var(--color-primary);
    color: #0B1120;
    border: none;
    border-radius: var(--border-radius);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: background 0.2s, box-shadow 0.2s;
    white-space: nowrap;
  }

  .newsletter-cta__submit:hover {
    background: var(--color-primary-dark);
    box-shadow: 0 0 24px rgba(6, 182, 212, 0.3);
  }

  .newsletter-cta__submit:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .newsletter-cta__privacy {
    margin-top: 12px;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    font-family: var(--font-body);
  }

  .newsletter-cta__success {
    display: none;
    color: var(--color-accent);
    font-size: 0.875rem;
    font-family: var(--font-body);
    margin-top: 12px;
  }

  .newsletter-cta__success.is-visible {
    display: block;
  }

  @media (min-width: 768px) {
    .newsletter-cta__heading {
      font-size: 2.5rem;
    }

    .newsletter-cta__form {
      flex-direction: row;
    }

    .newsletter-cta__submit {
      flex-shrink: 0;
    }
  }

  @media (min-width: 1024px) {
    .newsletter-cta__heading {
      font-size: 3rem;
    }
  }
{% endstylesheet %}

<section
  class="newsletter-cta section-padding"
  id="section-{{ section.id }}"
>
  {%- if section.settings.image != blank -%}
    <div class="newsletter-cta__bg-image" aria-hidden="true">
      <img
        src="{{ section.settings.image | image_url: width: 1600 }}"
        alt=""
        width="1600"
        height="900"
        loading="lazy"
      >
    </div>
  {%- endif -%}

  <div class="newsletter-cta__glow-1" aria-hidden="true"></div>
  <div class="newsletter-cta__glow-2" aria-hidden="true"></div>

  <div class="container">
    <div class="newsletter-cta__inner">
      {%- if section.settings.heading != blank -%}
        <h2 class="newsletter-cta__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="newsletter-cta__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      <form
        class="newsletter-cta__form"
        id="newsletter-form-{{ section.id }}"
        action="/contact#contact_form"
        method="post"
        novalidate
      >
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="&#x2713;">
        <input type="hidden" name="contact[tags]" value="newsletter">

        <label for="newsletter-email-{{ section.id }}" class="visually-hidden">
          {{ 'newsletter.placeholder' | t }}
        </label>
        <input
          type="email"
          id="newsletter-email-{{ section.id }}"
          name="contact[email]"
          class="newsletter-cta__input"
          placeholder="{{ 'newsletter.placeholder' | t }}"
          autocomplete="email"
          required
          aria-required="true"
        >

        <button type="submit" class="newsletter-cta__submit">
          {{ 'newsletter.subscribe' | t }}
        </button>
      </form>

      <p class="newsletter-cta__privacy">{{ 'newsletter.privacy_note' | t }}</p>

      <p
        class="newsletter-cta__success"
        id="newsletter-success-{{ section.id }}"
        role="status"
        aria-live="polite"
      ></p>
    </div>

    {% content_for 'blocks' %}
  </div>
</section>

<script>
  (function () {
    var form = document.getElementById('newsletter-form-{{ section.id }}');
    var successMsg = document.getElementById('newsletter-success-{{ section.id }}');

    if (!form) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      var email = form.querySelector('input[type="email"]').value.trim();
      if (!email) return;

      var submitBtn = form.querySelector('.newsletter-cta__submit');
      submitBtn.disabled = true;

      var body = new FormData(form);

      fetch(form.action, {
        method: 'POST',
        body: body,
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
      })
        .then(function (res) {
          if (res.ok || res.status === 200) {
            form.reset();
            if (successMsg) {
              successMsg.textContent = "{{ 'newsletter.subscribe' | t }} — thanks!";
              successMsg.classList.add('is-visible');
            }
          }
        })
        .catch(function () {
          submitBtn.disabled = false;
        })
        .finally(function () {
          submitBtn.disabled = false;
        });
    });
  })();
</script>

{% schema %}
{
  "name": "Newsletter CTA",
  "tag": "section",
  "class": "section-newsletter-cta",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready to level up?"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image (optional)"
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    }
  ],
  "presets": [
    {
      "name": "Newsletter CTA"
    }
  ]
}
{% endschema %}
