{% stylesheet %}
  .featured-courses {
    background: var(--color-bg);
  }

  .featured-courses__header {
    text-align: center;
    margin-bottom: 40px;
  }

  .featured-courses__heading {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 12px;
  }

  .featured-courses__subtitle {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .featured-courses__grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 20px;
  }

  .featured-courses__footer {
    text-align: center;
    margin-top: 40px;
  }

  @media (min-width: 768px) {
    .featured-courses__heading {
      font-size: 2.25rem;
    }

    .featured-courses__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .featured-courses__grid {
      grid-template-columns: repeat(var(--cols), 1fr);
    }
  }
{% endstylesheet %}

{%- liquid
  assign col_count = section.settings.columns_desktop | default: '3'
  assign products_limit = section.settings.products_count | default: 6

  if section.settings.collection != blank
    assign course_products = section.settings.collection.products | limit: products_limit
  else
    assign course_products = collections.all.products | limit: products_limit
  endif
-%}

<section
  class="featured-courses section-padding"
  id="section-{{ section.id }}"
  style="--cols: {{ col_count }};"
>
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.subtitle != blank -%}
      <header class="featured-courses__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="featured-courses__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="featured-courses__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if course_products.size > 0 -%}
      <div class="featured-courses__grid">
        {%- for product in course_products -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="featured-courses__empty" style="text-align:center;color:var(--color-text-muted);">
        {{ 'courses.no_courses' | t }}
      </p>
    {%- endif -%}

    {%- if section.settings.collection != blank -%}
      <div class="featured-courses__footer">
        <a href="{{ section.settings.collection.url }}" class="btn btn--outline">
          {{ 'courses.view_all' | t }}
        </a>
      </div>
    {%- endif -%}

    {% content_for 'blocks' %}
  </div>
</section>

{% schema %}
{
  "name": "Featured courses",
  "tag": "section",
  "class": "section-featured-courses",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured courses"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Number of products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "3"
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    }
  ],
  "presets": [
    {
      "name": "Featured courses"
    }
  ]
}
{% endschema %}
