{%- liquid
  assign register_title = 'customer.register_title' | t
  assign first_name_label = 'customer.first_name' | t
  assign last_name_label = 'customer.last_name' | t
  assign email_label = 'customer.email' | t
  assign password_label = 'customer.password' | t
  assign submit_label = 'customer.submit_register' | t
-%}

{% stylesheet %}
  .customer-register {
    padding: 80px 20px 120px;
    background: var(--color-bg);
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .customer-register__inner {
    width: 100%;
    max-width: 420px;
  }

  .customer-form__title {
    font-family: var(--font-heading, 'Space Grotesk', sans-serif);
    font-size: clamp(1.4rem, 3vw, 1.75rem);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 28px;
    text-align: center;
  }

  .customer-form {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .customer-form__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .customer-form__label {
    font-size: 0.78rem;
    font-weight: 600;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .customer-form__input {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    font-size: 0.9rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    padding: 12px 14px;
    transition: border-color 0.2s, box-shadow 0.2s;
    width: 100%;
  }

  .customer-form__input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.15);
  }

  .customer-form__input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .customer-form__submit {
    width: 100%;
    padding: 14px;
    background: var(--color-primary);
    color: #0F172A;
    font-weight: 700;
    font-size: 0.9rem;
    font-family: var(--font-heading, 'Space Grotesk', sans-serif);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
  }

  .customer-form__submit:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .customer-form__submit:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  .customer-form__links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-top: 4px;
  }

  .customer-form__link {
    font-size: 0.8rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    color: var(--color-text-muted);
    text-decoration: underline;
    transition: color 0.2s;
  }

  .customer-form__link:hover {
    color: var(--color-primary);
  }

  .customer-form__errors {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 8px;
    padding: 12px 14px;
    margin-bottom: 16px;
    font-size: 0.82rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    color: var(--color-error, #EF4444);
  }
{% endstylesheet %}

<section class="customer-register" data-section-id="{{ section.id }}">
  <div class="customer-register__inner">
    <h1 class="customer-form__title">{{ register_title }}</h1>

    {%- if form.errors -%}
      <div class="customer-form__errors" role="alert">
        {{ form.errors | default_errors }}
      </div>
    {%- endif -%}

    {%- form 'create_customer' -%}
      <div class="customer-form">
        <div class="customer-form__field">
          <label class="customer-form__label" for="RegisterFirstName">
            {{ first_name_label }}
          </label>
          <input
            type="text"
            id="RegisterFirstName"
            name="customer[first_name]"
            class="customer-form__input"
            autocomplete="given-name"
            autocorrect="off"
            autocapitalize="words"
          >
        </div>

        <div class="customer-form__field">
          <label class="customer-form__label" for="RegisterLastName">
            {{ last_name_label }}
          </label>
          <input
            type="text"
            id="RegisterLastName"
            name="customer[last_name]"
            class="customer-form__input"
            autocomplete="family-name"
            autocorrect="off"
            autocapitalize="words"
          >
        </div>

        <div class="customer-form__field">
          <label class="customer-form__label" for="RegisterEmail">
            {{ email_label }}
          </label>
          <input
            type="email"
            id="RegisterEmail"
            name="customer[email]"
            class="customer-form__input"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            required
          >
        </div>

        <div class="customer-form__field">
          <label class="customer-form__label" for="RegisterPassword">
            {{ password_label }}
          </label>
          <input
            type="password"
            id="RegisterPassword"
            name="customer[password]"
            class="customer-form__input"
            autocomplete="new-password"
            required
          >
        </div>

        <button type="submit" class="customer-form__submit">
          {{ submit_label }}
        </button>

        <div class="customer-form__links">
          <a href="{{ routes.account_login_url }}" class="customer-form__link">
            {{ 'customer.already_have_account' | t }}
          </a>
        </div>
      </div>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.customer_register.name",
  "presets": [
    { "name": "Customer register" }
  ]
}
{% endschema %}
