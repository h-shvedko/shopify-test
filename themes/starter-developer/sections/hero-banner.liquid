<section class="hero section-padding" id="HeroBanner-{{ section.id }}">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="container hero__grid">

    {%- comment -%} Left: content column {%- endcomment -%}
    <div class="hero__content">

      {%- if section.settings.badge_text != blank -%}
        <div class="hero__badge">
          <span class="hero__badge-dot" aria-hidden="true"></span>
          {{ section.settings.badge_text }}
        </div>
      {%- endif -%}

      <h1 class="hero__heading">
        {{- section.settings.heading | replace: '&amp;', '&' -}}
      </h1>

      {%- if section.settings.subtitle != blank -%}
        <p class="hero__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      <div class="hero__ctas">
        {%- if section.settings.button_label_1 != blank -%}
          <a
            href="{{ section.settings.button_url_1 | default: '#' }}"
            class="btn btn--primary hero__btn-primary"
          >
            {{ section.settings.button_label_1 }}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a
            href="{{ section.settings.button_url_2 | default: '#' }}"
            class="btn btn--outline hero__btn-secondary"
          >
            {{ section.settings.button_label_2 }}
          </a>
        {%- endif -%}
      </div>

    </div>

    {%- comment -%} Right: terminal window {%- endcomment -%}
    <div class="hero__terminal-wrap">
      <div class="hero__terminal">
        <div class="hero__terminal-bar" aria-hidden="true">
          <span class="hero__terminal-dot hero__terminal-dot--red"></span>
          <span class="hero__terminal-dot hero__terminal-dot--yellow"></span>
          <span class="hero__terminal-dot hero__terminal-dot--green"></span>
          <span class="hero__terminal-title">
            {{- section.settings.terminal_title -}}
          </span>
        </div>
        <div class="hero__terminal-body" aria-label="Terminal output">
          {%- assign line_1 = section.settings.terminal_line_1 -%}
          {%- assign line_2 = section.settings.terminal_line_2 -%}
          {%- assign line_3 = section.settings.terminal_line_3 -%}
          {%- assign line_4 = section.settings.terminal_line_4 -%}

          {%- if line_1 != blank -%}
            <p class="hero__terminal-line">
              <span class="hero__t-prompt" aria-hidden="true">$ </span>
              <span class="hero__t-cmd">{{ line_1 }}</span>
            </p>
          {%- endif -%}
          {%- if line_2 != blank -%}
            <p class="hero__terminal-line hero__terminal-line--output">
              <span class="hero__t-ok" aria-hidden="true">✓ </span>
              <span>{{ line_2 }}</span>
            </p>
          {%- endif -%}
          {%- if line_3 != blank -%}
            <p class="hero__terminal-line hero__terminal-line--output">
              <span class="hero__t-ok" aria-hidden="true">✓ </span>
              <span>{{ line_3 }}</span>
            </p>
          {%- endif -%}
          {%- if line_4 != blank -%}
            <p class="hero__terminal-line hero__terminal-line--output">
              <span class="hero__t-ok" aria-hidden="true">✓ </span>
              <span>{{ line_4 }}</span>
            </p>
          {%- endif -%}

          <p class="hero__terminal-line hero__terminal-cursor-line" aria-hidden="true">
            <span class="hero__t-prompt">$ </span>
            <span class="hero__t-cursor"></span>
          </p>
        </div>
      </div>
    </div>

  </div>
</section>

{% stylesheet %}
.hero {
  position: relative;
  overflow: hidden;
  padding-top: 100px;
  padding-bottom: 80px;
}

/* Radial glow in top-right */
.hero__glow {
  position: absolute;
  top: -120px;
  right: -120px;
  width: 600px;
  height: 600px;
  background: radial-gradient(
    circle at center,
    rgba(6, 182, 212, 0.15) 0%,
    rgba(6, 182, 212, 0.04) 45%,
    transparent 70%
  );
  pointer-events: none;
  z-index: 0;
}

.hero__grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
  align-items: center;
}

/* Badge pill */
.hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 14px;
  background: rgba(16, 185, 129, 0.1);
  border: 1px solid rgba(16, 185, 129, 0.25);
  border-radius: 20px;
  font-size: 0.78rem;
  font-family: var(--font-body);
  color: var(--color-accent);
  margin-bottom: 24px;
  width: fit-content;
}

.hero__badge-dot {
  display: block;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--color-accent);
  flex-shrink: 0;
  animation: badge-pulse 2s ease-in-out infinite;
}

@keyframes badge-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.85); }
}

/* Heading */
.hero__heading {
  font-size: 2.4rem;
  font-family: var(--font-heading);
  font-weight: 700;
  line-height: 1.15;
  color: var(--color-text);
  letter-spacing: -0.02em;
  margin-bottom: 20px;
}

/* Subtitle */
.hero__subtitle {
  font-size: 1rem;
  color: var(--color-text-secondary);
  line-height: 1.75;
  max-width: 520px;
  margin-bottom: 36px;
}

/* CTAs */
.hero__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.hero__btn-primary {
  padding: 12px 24px;
  font-size: 0.875rem;
}

.hero__btn-secondary {
  padding: 12px 24px;
  font-size: 0.875rem;
}

/* Terminal window */
.hero__terminal-wrap {
  width: 100%;
}

.hero__terminal {
  background: var(--color-terminal-bg, #0F172A);
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(6, 182, 212, 0.05);
}

.hero__terminal-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 16px;
  background: rgba(255, 255, 255, 0.03);
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.hero__terminal-dot {
  display: block;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  flex-shrink: 0;
}

.hero__terminal-dot--red    { background: #EF4444; }
.hero__terminal-dot--yellow { background: #FBBF24; }
.hero__terminal-dot--green  { background: #22C55E; }

.hero__terminal-title {
  flex: 1;
  text-align: center;
  color: rgba(255, 255, 255, 0.3);
  font-size: 0.7rem;
  font-family: var(--font-body);
  letter-spacing: 0.04em;
  user-select: none;
}

.hero__terminal-body {
  padding: 24px 20px;
  font-size: 0.82rem;
  line-height: 1.9;
  font-family: var(--font-body);
  min-height: 220px;
}

.hero__terminal-line {
  display: flex;
  align-items: baseline;
  gap: 4px;
  margin-bottom: 2px;
}

.hero__t-prompt {
  color: var(--color-primary);
  flex-shrink: 0;
}

.hero__t-cmd {
  color: #F1F5F9;
}

.hero__terminal-line--output .hero__t-ok {
  color: var(--color-terminal-green, #4ADE80);
  flex-shrink: 0;
}

.hero__terminal-line--output span:last-child {
  color: var(--color-text-secondary);
}

.hero__terminal-cursor-line {
  margin-top: 6px;
}

.hero__t-cursor {
  display: inline-block;
  width: 8px;
  height: 15px;
  background: var(--color-primary);
  border-radius: 1px;
  vertical-align: middle;
  animation: blink 1.1s step-end infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}

@media (min-width: 768px) {
  .hero__heading {
    font-size: 3rem;
  }
}

@media (min-width: 1024px) {
  .hero__grid {
    grid-template-columns: 1fr 1fr;
    gap: 64px;
  }

  .hero__heading {
    font-size: 3.5rem;
  }
}
{% endstylesheet %}

