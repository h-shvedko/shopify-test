{% layout none %}
<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ 'general.gift_card_title' | t }} - {{ shop.name }}</title>
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    *,
    *::before,
    *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Space Grotesk', -apple-system, sans-serif;
      background: #0B1120;
      color: #F1F5F9;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
    }

    .gift-card {
      width: 100%;
      max-width: 440px;
      text-align: center;
    }

    .gift-card__shop-name {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.25rem;
      font-weight: 700;
      color: #F1F5F9;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 32px;
    }

    .gift-card__image {
      max-width: 100%;
      height: auto;
      border-radius: 8px;
      margin-bottom: 32px;
      display: block;
      margin-left: auto;
      margin-right: auto;
    }

    .gift-card__amount {
      font-family: 'JetBrains Mono', monospace;
      font-size: 2.5rem;
      font-weight: 700;
      color: #06B6D4;
      margin-bottom: 24px;
      line-height: 1.2;
    }

    .gift-card__label {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #94A3B8;
      margin-bottom: 8px;
    }

    .gift-card__code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.375rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      color: #06B6D4;
      padding: 18px 24px;
      border: 2px dashed #334155;
      border-radius: 8px;
      margin: 0 0 32px;
      background: #0F1A2E;
      word-break: break-all;
    }

    .gift-card__apple-wallet {
      display: inline-block;
      margin-bottom: 24px;
      color: #94A3B8;
      font-size: 0.875rem;
      text-decoration: underline;
      text-underline-offset: 3px;
      transition: color 0.2s;
    }

    .gift-card__apple-wallet:hover {
      color: #06B6D4;
    }

    .gift-card__expired {
      font-size: 0.875rem;
      font-weight: 500;
      color: #F87171;
      margin-top: 16px;
      padding: 10px 16px;
      border: 1px solid #F87171;
      border-radius: 8px;
      background: rgba(248, 113, 113, 0.08);
    }

    .gift-card__footer {
      margin-top: 40px;
      font-size: 0.8125rem;
      color: #475569;
    }

    @media (min-width: 768px) {
      .gift-card__amount { font-size: 3rem; }
      .gift-card__code { font-size: 1.5rem; padding: 20px 28px; }
    }
  </style>
</head>
<body>
  <div class="gift-card">
    <p class="gift-card__shop-name">{{ shop.name }}</p>

    {% if gift_card.image %}
      <img
        class="gift-card__image"
        src="{{ gift_card.image | image_url: width: 440 }}"
        alt="{{ 'general.gift_card_title' | t }}"
        width="440"
        height="auto"
      >
    {% endif %}

    <p class="gift-card__label">{{ 'general.gift_card_balance' | t }}</p>
    <p class="gift-card__amount">{{ gift_card.balance | money }}</p>

    <p class="gift-card__label">{{ 'general.gift_card_code' | t }}</p>
    <div class="gift-card__code">{{ gift_card.code | format_code }}</div>

    {% if gift_card.pass_url %}
      <a class="gift-card__apple-wallet" href="{{ gift_card.pass_url }}">
        {{ 'general.add_to_apple_wallet' | t }}
      </a>
    {% endif %}

    {% if gift_card.expired %}
      <p class="gift-card__expired">{{ 'general.gift_card_expired' | t }}</p>
    {% endif %}

    <p class="gift-card__footer">{{ shop.name }}</p>
  </div>
</body>
</html>
