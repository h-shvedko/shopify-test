{% doc %}
  Renders a styled button or anchor element using CodeCraft Academy button classes.

  Parameters:
  - label {string} required — Visible button text
  - url {string} optional — If provided, renders an <a> tag; otherwise renders a <button>
  - variant {string} optional — Visual style. One of: primary, outline, ghost.
      Default: "primary"
  - type {string} optional — HTML type attribute for <button> elements. Default: "button"
  - full_width {boolean} optional — When true, the element spans full container width.
      Default: false

  All .btn CSS is defined in assets/critical.css — no <style> tag is needed here.

  Usage:
    {% render 'button', label: 'Browse courses', url: '/collections/all' %}
    {% render 'button', label: 'Enroll now', variant: 'primary', type: 'submit' %}
    {% render 'button', label: 'View curriculum', variant: 'outline', url: '#curriculum' %}
    {% render 'button', label: 'Learn more', variant: 'ghost', url: '#about' %}
{% enddoc %}

{%- liquid
  assign btn_variant = variant | default: 'primary'
  assign btn_type    = type    | default: 'button'

  assign btn_class = 'btn btn--' | append: btn_variant
  if full_width
    assign btn_class = btn_class | append: ' btn--full'
  endif
-%}

{%- if url != blank -%}
  <a href="{{ url }}" class="{{ btn_class }}">{{ label }}</a>
{%- else -%}
  <button type="{{ btn_type }}" class="{{ btn_class }}">{{ label }}</button>
{%- endif -%}
