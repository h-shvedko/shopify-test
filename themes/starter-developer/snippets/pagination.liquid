{% doc %}
  Renders pagination controls for a paginated collection, search result, or blog.
  Dark-themed: uses CodeCraft Academy CSS variables for backgrounds and borders.

  Parameters:
  - paginate {paginate} required — Shopify paginate object from a {% paginate %} block.

  Usage:
    {% paginate collection.products by 12 %}
      {% render 'pagination', paginate: paginate %}
    {% endpaginate %}
{% enddoc %}

<style>
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4px;
    margin-top: 48px;
  }

  .pagination__item {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
    flex-shrink: 0;
  }

  .pagination__item:hover {
    background: rgba(6, 182, 212, 0.08);
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .pagination__item--current {
    background: var(--color-primary);
    color: #0F172A;
    font-weight: 700;
    border-color: var(--color-primary);
    pointer-events: none;
  }

  .pagination__item--current:hover {
    background: var(--color-primary);
  }

  .pagination__item--gap {
    pointer-events: none;
    color: var(--color-text-muted);
    border-color: transparent;
    background: transparent;
  }

  .pagination__item--nav {
    color: var(--color-text-muted);
  }

  .pagination__item--nav[aria-disabled="true"] {
    opacity: 0.25;
    pointer-events: none;
  }

  .pagination__item:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

{%- if paginate.pages > 1 -%}
  <nav class="pagination" aria-label="{{ 'pagination.label' | t }}">
    {%- if paginate.previous -%}
      <a
        href="{{ paginate.previous.url }}"
        class="pagination__item pagination__item--nav"
        aria-label="{{ 'pagination.previous' | t }}"
        rel="prev"
      >
        {% render 'icon', name: 'arrow-left', size: 16 %}
      </a>
    {%- else -%}
      <span
        class="pagination__item pagination__item--nav"
        aria-disabled="true"
        aria-label="{{ 'pagination.previous' | t }}"
      >
        {% render 'icon', name: 'arrow-left', size: 16 %}
      </span>
    {%- endif -%}

    {%- for part in paginate.parts -%}
      {%- if part.is_link -%}
        <a
          href="{{ part.url }}"
          class="pagination__item"
          aria-label="{{ 'pagination.page' | t: number: part.title }}"
        >
          {{ part.title }}
        </a>
      {%- elsif part.title == paginate.current_page -%}
        <span
          class="pagination__item pagination__item--current"
          aria-current="page"
          aria-label="{{ 'pagination.current_page' | t: number: part.title }}"
        >
          {{ part.title }}
        </span>
      {%- else -%}
        <span class="pagination__item pagination__item--gap" aria-hidden="true">
          {{ part.title }}
        </span>
      {%- endif -%}
    {%- endfor -%}

    {%- if paginate.next -%}
      <a
        href="{{ paginate.next.url }}"
        class="pagination__item pagination__item--nav"
        aria-label="{{ 'pagination.next' | t }}"
        rel="next"
      >
        {% render 'icon', name: 'arrow-right', size: 16 %}
      </a>
    {%- else -%}
      <span
        class="pagination__item pagination__item--nav"
        aria-disabled="true"
        aria-label="{{ 'pagination.next' | t }}"
      >
        {% render 'icon', name: 'arrow-right', size: 16 %}
      </span>
    {%- endif -%}
  </nav>
{%- endif -%}
