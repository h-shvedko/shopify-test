{% stylesheet %}
  .related-products {
    padding: 72px 0;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
  }

  .related-products__container {
    max-width: var(--page-width, 1280px);
    margin: 0 auto;
    padding: 0 20px;
  }

  .related-products__header {
    margin-bottom: 40px;
  }

  .related-products__heading {
    font-family: var(--font-display, 'Syne', sans-serif);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    color: var(--color-text);
    margin: 0;
    letter-spacing: -0.02em;
  }

  /* Horizontal scroll on mobile, grid on desktop */
  .related-products__track {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 8px;
    -webkit-overflow-scrolling: touch;
  }

  .related-products__track::-webkit-scrollbar {
    display: none;
  }

  .related-products__item {
    flex: 0 0 calc(60% - 10px);
    scroll-snap-align: start;
    min-width: 200px;
  }

  @media (min-width: 640px) {
    .related-products__item {
      flex: 0 0 calc(33.333% - 14px);
    }
  }

  @media (min-width: 1024px) {
    .related-products__item {
      flex: 0 0 calc(25% - 15px);
    }
  }

  /* Card */
  .rp-card {
    background: var(--color-base);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius, 8px);
    overflow: hidden;
    transition: border-color var(--transition-base, 250ms ease),
                box-shadow var(--transition-base, 250ms ease),
                transform var(--transition-base, 250ms ease);
  }

  .rp-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-3px);
  }

  .rp-card__image {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--color-surface-raised);
    display: block;
  }

  .rp-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-slow, 400ms ease);
  }

  .rp-card:hover .rp-card__img {
    transform: scale(1.04);
  }

  .rp-card__info {
    padding: 12px 14px 14px;
  }

  .rp-card__title {
    font-family: var(--font-display, 'Syne', sans-serif);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 5px;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .rp-card__title a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition-fast, 150ms ease);
  }

  .rp-card__title a:hover {
    color: var(--color-accent);
  }

  .rp-card__price {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .rp-card__price-compare {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    text-decoration: line-through;
    margin-left: 5px;
  }

  .rp-card__quick-add {
    display: block;
    width: 100%;
    margin-top: 10px;
    padding: 8px;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius, 8px);
    color: var(--color-text-muted);
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: border-color var(--transition-fast, 150ms ease),
                color var(--transition-fast, 150ms ease),
                background var(--transition-fast, 150ms ease);
    text-transform: uppercase;
  }

  .rp-card__quick-add:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: rgba(0, 212, 170, 0.06);
  }
{% endstylesheet %}

{%- assign rp_heading = section.settings.heading | default: 'related_products.heading' | t -%}

{%- if recommendations.performed -%}
  {%- if recommendations.products_count > 0 -%}
    <section
      class="related-products"
      data-section-id="{{ section.id }}"
      data-product-id="{{ product.id }}"
      data-products-count="{{ section.settings.products_count }}"
    >
      <div class="related-products__container">
        <header class="related-products__header">
          <h2 class="related-products__heading">{{ rp_heading }}</h2>
        </header>
        <div class="related-products__track" role="list">
          {%- for item in recommendations.products limit: section.settings.products_count -%}
            {%- assign rp_alt = item.featured_image.alt | escape | default: item.title | escape -%}
            <div class="related-products__item" role="listitem">
              <article class="rp-card">
                <a href="{{ item.url }}" class="rp-card__image" tabindex="-1" aria-hidden="true">
                  {%- if item.featured_image -%}
                    <img
                      class="rp-card__img"
                      src="{{ item.featured_image | image_url: width: 600 }}"
                      alt="{{ rp_alt }}"
                      width="600"
                      height="600"
                      loading="lazy"
                    >
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'rp-card__img' }}
                  {%- endif -%}
                </a>
                <div class="rp-card__info">
                  <h3 class="rp-card__title">
                    <a href="{{ item.url }}">{{ item.title }}</a>
                  </h3>
                  <div>
                    {%- if item.compare_at_price > item.price -%}
                      <span class="rp-card__price">{{ item.price | money }}</span>
                      <span class="rp-card__price-compare">{{ item.compare_at_price | money }}</span>
                    {%- else -%}
                      <span class="rp-card__price">{{ item.price | money }}</span>
                    {%- endif -%}
                  </div>
                  {%- if item.available -%}
                    {%- assign rp_quick_add = 'products.quick_add' | t -%}
                    <button
                      type="button"
                      class="rp-card__quick-add"
                      data-rp-quick-add
                      data-variant-id="{{ item.first_available_variant.id }}"
                    >{{ rp_quick_add }}</button>
                  {%- endif -%}
                </div>
              </article>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}
{%- else -%}
  <section
    class="related-products"
    data-section-id="{{ section.id }}"
    data-product-id="{{ product.id }}"
    data-products-count="{{ section.settings.products_count }}"
  >
    <div class="related-products__container">
      <header class="related-products__header">
        <h2 class="related-products__heading">{{ rp_heading }}</h2>
      </header>
      <div class="related-products__track" role="list" data-rp-track></div>
    </div>
  </section>
{%- endif -%}

<script>
  (function () {
    var section = document.querySelector('.related-products[data-product-id]');
    if (!section) return;

    // AJAX quick-add from rendered recommendation items
    section.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-rp-quick-add]');
      if (!btn) return;
      var variantId = parseInt(btn.dataset.variantId, 10);
      if (!variantId) return;
      btn.disabled = true;
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      })
        .then(function (r) { return r.json(); })
        .then(function () { return fetch('/cart.js'); })
        .then(function (r) { return r.json(); })
        .then(function (cart) {
          var badge = document.querySelector('[data-cart-count]');
          if (badge) badge.textContent = cart.item_count;
          document.dispatchEvent(new CustomEvent('cart:updated', { detail: { cart: cart } }));
        })
        .catch(function (err) { console.error('Quick add error:', err); })
        .finally(function () { btn.disabled = false; });
    });

    // Fetch recommendations if track is empty (non-performed state)
    var track = section.querySelector('[data-rp-track]');
    if (!track) return;

    var productId = section.dataset.productId;
    var limit     = section.dataset.productsCount || '4';
    if (!productId) return;

    fetch(
      '/recommendations/products.json?product_id=' +
        encodeURIComponent(productId) + '&limit=' + encodeURIComponent(limit),
      { headers: { 'X-Requested-With': 'XMLHttpRequest' } }
    )
      .then(function (res) {
        if (!res.ok) throw new Error('Recommendations failed');
        return res.json();
      })
      .then(function (data) {
        var products = data.products;
        if (!products || products.length === 0) {
          section.hidden = true;
          return;
        }
        products.forEach(function (product) {
          track.appendChild(buildCard(product));
        });
      })
      .catch(function () { section.hidden = true; });

    function formatMoney(cents) {
      var amount = (cents / 100).toFixed(2);
      var format = (window.Shopify && window.Shopify.money_format) || {% raw %}'${{amount}}'{% endraw %};
      return format
        .replace({% raw %}'{{amount}}'{% endraw %}, amount)
        .replace({% raw %}'{{amount_with_comma_separator}}'{% endraw %}, amount.replace('.', ','))
        .replace({% raw %}'{{amount_no_decimals}}'{% endraw %}, Math.round(cents / 100).toString());
    }

    function escapeHtml(str) {
      var d = document.createElement('div');
      d.appendChild(document.createTextNode(str));
      return d.innerHTML;
    }

    function buildCard(product) {
      var wrap = document.createElement('div');
      wrap.className = 'related-products__item';
      wrap.setAttribute('role', 'listitem');

      var imageUrl = product.featured_image
        ? product.featured_image.replace(/(\.\w+)(\?.*)?$/, '_600x600$1')
        : null;
      var imgHtml = imageUrl
        ? '<img class="rp-card__img" src="' + imageUrl + '" alt="' + escapeHtml(product.title) + '" width="600" height="600" loading="lazy">'
        : '';

      var priceHtml = formatMoney(product.price_min);
      var compareHtml = product.compare_at_price_min > product.price_min
        ? '<span class="rp-card__price-compare">' + formatMoney(product.compare_at_price_min) + '</span>'
        : '';

      wrap.innerHTML =
        '<article class="rp-card">' +
          '<a href="' + product.url + '" class="rp-card__image" tabindex="-1" aria-hidden="true">' +
            imgHtml +
          '</a>' +
          '<div class="rp-card__info">' +
            '<h3 class="rp-card__title"><a href="' + product.url + '">' + escapeHtml(product.title) + '</a></h3>' +
            '<div><span class="rp-card__price">' + priceHtml + '</span>' + compareHtml + '</div>' +
          '</div>' +
        '</article>';

      return wrap;
    }
  })();
</script>

{% schema %}
{
  "name": "Related products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Complete your routine"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Number of products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    { "name": "Related products" }
  ]
}
{% endschema %}
