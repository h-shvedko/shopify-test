{%- assign scroll_label = 'sections.hero_banner.scroll_down' | t -%}

<section
  class="zn-hero section-snap{% if section.settings.enable_parallax %} zn-hero--parallax{% endif %}"
  data-section-id="{{ section.id }}"
  data-hero
  aria-label="{{ section.settings.heading | default: shop.name | escape }}"
>

  {%- comment -%} Background layer {%- endcomment -%}
  <div class="zn-hero__bg" data-parallax-bg>
    {% if section.settings.video_url != blank %}
      <video
        class="zn-hero__video"
        src="{{ section.settings.video_url }}"
        autoplay
        muted
        loop
        playsinline
        preload="none"
        aria-hidden="true"
      ></video>
    {% elsif section.settings.image %}
      {%- assign hero_alt = section.settings.heading | default: shop.name | escape -%}
      {{
        section.settings.image
        | image_url: width: 2000
        | image_tag:
          alt: hero_alt,
          class: 'zn-hero__img',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 1100, 1500, 2000'
      }}
    {% else %}
      <div class="zn-hero__placeholder"></div>
    {% endif %}
    <div class="zn-hero__overlay"></div>
  </div>

  {%- comment -%} Content {%- endcomment -%}
  <div class="zn-hero__content">

    {% if section.settings.eyebrow != blank %}
      <p class="zn-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h1 class="zn-hero__heading{% if section.settings.enable_gradient_text %} zn-hero__heading--gradient{% endif %}">
        {{ section.settings.heading }}
      </h1>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="zn-hero__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    {% if section.settings.button_text != blank %}
      <a
        href="{{ section.settings.button_url | default: routes.all_products_collection_url }}"
        class="zn-hero__cta"
      >
        {{ section.settings.button_text }}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="m5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {% endif %}

  </div>

  {%- comment -%} Scroll indicator {%- endcomment -%}
  <div class="zn-hero__scroll-indicator" aria-label="{{ scroll_label }}" role="img">
    <div class="zn-hero__scroll-mouse">
      <div class="zn-hero__scroll-wheel"></div>
    </div>
  </div>

</section>

{% stylesheet %}
  /* === Zenith Hero Banner === */

  .zn-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 560px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: #0A0A0A;
  }

  /* Snap scroll integration */

  .section-snap {
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  /* Background */

  .zn-hero__bg {
    position: absolute;
    inset: 0;
    will-change: transform;
  }

  .zn-hero__img,
  .zn-hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .zn-hero__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #0A0A0A 0%, #141414 50%, #1E1E1E 100%);
  }

  .zn-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 10, 0.35) 0%,
      rgba(10, 10, 10, 0.6) 60%,
      rgba(10, 10, 10, 0.85) 100%
    );
  }

  /* Content */

  .zn-hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 24px;
    max-width: 900px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .zn-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Inter', var(--font-body, sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #00D4AA;
    margin: 0;
  }

  .zn-hero__eyebrow::before,
  .zn-hero__eyebrow::after {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background-color: #00D4AA;
    opacity: 0.6;
  }

  .zn-hero__heading {
    font-family: 'Syne', var(--font-heading, sans-serif);
    font-weight: 800;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #F0F0F0;
    margin: 0;
  }

  .zn-hero__heading--gradient {
    background: linear-gradient(135deg, #F0F0F0 0%, #00D4AA 50%, #FF6B6B 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .zn-hero__subheading {
    font-family: 'Inter', var(--font-body, sans-serif);
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.65;
    color: rgba(240, 240, 240, 0.75);
    margin: 0;
    max-width: 560px;
  }

  .zn-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 36px;
    background: linear-gradient(135deg, #00D4AA, #00A885);
    color: #0A0A0A;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.04em;
    border-radius: 8px;
    box-shadow: 0 0 24px rgba(0, 212, 170, 0.4), 0 4px 16px rgba(0, 0, 0, 0.4);
    transition: box-shadow 0.25s ease, transform 0.2s ease, opacity 0.2s ease;
    margin-top: 8px;
  }

  .zn-hero__cta:hover {
    text-decoration: none;
    box-shadow: 0 0 40px rgba(0, 212, 170, 0.6), 0 8px 24px rgba(0, 0, 0, 0.5);
    transform: translateY(-2px);
    opacity: 0.95;
  }

  .zn-hero__cta:focus-visible {
    outline: 2px solid #00D4AA;
    outline-offset: 3px;
  }

  .zn-hero__cta svg {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .zn-hero__cta:hover svg {
    transform: translateX(3px);
  }

  /* Scroll indicator */

  .zn-hero__scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .zn-hero__scroll-mouse {
    width: 24px;
    height: 38px;
    border: 2px solid rgba(240, 240, 240, 0.4);
    border-radius: 12px;
    display: flex;
    justify-content: center;
    padding-top: 6px;
    animation: zn-hero-mouse-bounce 2.5s ease-in-out infinite;
  }

  .zn-hero__scroll-wheel {
    width: 4px;
    height: 8px;
    background-color: #00D4AA;
    border-radius: 2px;
    animation: zn-hero-wheel-scroll 2.5s ease-in-out infinite;
  }

  @keyframes zn-hero-mouse-bounce {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(6px); opacity: 0.6; }
  }

  @keyframes zn-hero-wheel-scroll {
    0% { transform: translateY(0); opacity: 1; }
    60% { transform: translateY(8px); opacity: 0; }
    61% { transform: translateY(0); opacity: 0; }
    100% { opacity: 1; }
  }

  /* Reduced motion */

  @media (prefers-reduced-motion: reduce) {
    .zn-hero__scroll-mouse,
    .zn-hero__scroll-wheel {
      animation: none;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    'use strict';

    var hero = document.querySelector('.zn-hero[data-section-id="{{ section.id }}"]');
    if (!hero) return;

    {% if section.settings.enable_parallax %}
    var bg = hero.querySelector('[data-parallax-bg]');
    if (!bg) return;

    var ticking = false;

    function applyParallax() {
      var rect = hero.getBoundingClientRect();
      var progress = -rect.top / window.innerHeight;
      var offset = progress * 80;
      bg.style.transform = 'translateY(' + offset + 'px) scale(1.12)';
      ticking = false;
    }

    window.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(applyParallax);
        ticking = true;
      }
    }, { passive: true });

    applyParallax();
    {% endif %}
  })();
</script>

{% schema %}
{
  "name": "t:sections.hero_banner.name",
  "tag": "section",
  "class": "zenith-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.hero_banner.settings.image.label"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "t:sections.hero_banner.settings.video_url.label",
      "info": "t:sections.hero_banner.settings.video_url.info"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.hero_banner.settings.eyebrow.label",
      "default": "Train beyond limits"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.hero_banner.settings.heading.label",
      "default": "Forged for performance"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.hero_banner.settings.subheading.label",
      "default": "Premium fitness equipment and apparel engineered to push you further."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:sections.hero_banner.settings.button_text.label",
      "default": "Shop the collection"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.hero_banner.settings.button_url.label"
    },
    {
      "type": "checkbox",
      "id": "enable_gradient_text",
      "label": "t:sections.hero_banner.settings.enable_gradient_text.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "label": "t:sections.hero_banner.settings.enable_parallax.label",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:sections.hero_banner.name"
    }
  ]
}
{% endschema %}
