{%- assign search_placeholder = 'sections.faq.search_placeholder' | t -%}
{%- assign all_label = 'sections.faq.all_categories' | t -%}

{%- comment -%} Collect unique categories from blocks {%- endcomment -%}
{%- assign faq_categories = '' -%}
{% for block in section.blocks %}
  {% if block.type == 'faq_item' %}
    {% if block.settings.category != blank %}
      {% unless faq_categories contains block.settings.category %}
        {%- assign faq_categories = faq_categories | append: block.settings.category | append: '|' -%}
      {% endunless %}
    {% endif %}
  {% endif %}
{% endfor %}
{%- assign categories_array = faq_categories | split: '|' -%}

<section
  class="zn-faq"
  data-section-id="{{ section.id }}"
  data-faq
>
  <div class="zn-faq__container">

    {%- comment -%} Header {%- endcomment -%}
    <div class="zn-faq__header">
      {% if section.settings.eyebrow != blank %}
        <p class="zn-faq__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="zn-faq__heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    {%- comment -%} Search input {%- endcomment -%}
    <div class="zn-faq__search-wrap">
      <label for="zn-faq-search-{{ section.id }}" class="visually-hidden">
        {{ search_placeholder }}
      </label>
      <div class="zn-faq__search-inner">
        <svg class="zn-faq__search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.5"/>
          <path d="m21 21-4.35-4.35" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <input
          class="zn-faq__search"
          type="search"
          id="zn-faq-search-{{ section.id }}"
          placeholder="{{ search_placeholder }}"
          autocomplete="off"
          data-faq-search
        >
      </div>
    </div>

    {%- comment -%} Category filter tabs {%- endcomment -%}
    {% if categories_array.size > 0 %}
      <div class="zn-faq__tabs-wrap" role="tablist" aria-label="{{ 'sections.faq.categories_label' | t }}">
        <button
          class="zn-faq__tab zn-faq__tab--active"
          data-faq-tab="all"
          role="tab"
          aria-selected="true"
        >{{ all_label }}</button>
        {% for cat in categories_array %}
          {% if cat != blank %}
            <button
              class="zn-faq__tab"
              data-faq-tab="{{ cat | handleize }}"
              role="tab"
              aria-selected="false"
            >{{ cat }}</button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {%- comment -%} FAQ items {%- endcomment -%}
    <div class="zn-faq__list" data-faq-list>
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' %}
          {%- assign cat_handle = block.settings.category | handleize | default: '' -%}
          <details
            class="zn-faq__item"
            {{ block.shopify_attributes }}
            data-faq-item
            data-category="{{ cat_handle }}"
            data-question="{{ block.settings.question | downcase | escape }}"
          >
            <summary class="zn-faq__question">
              <span class="zn-faq__question-text">{{ block.settings.question }}</span>
              <span class="zn-faq__icon" aria-hidden="true">
                <svg class="zn-faq__icon-plus" width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <svg class="zn-faq__icon-minus" width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path d="M5 12h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </span>
            </summary>
            <div class="zn-faq__answer">
              {{ block.settings.answer }}
            </div>
          </details>
        {% endif %}
      {% endfor %}
    </div>

    {%- comment -%} Empty state {%- endcomment -%}
    <p class="zn-faq__empty" data-faq-empty hidden>
      {{ 'sections.faq.no_results' | t }}
    </p>

  </div>
</section>

{%- comment -%} FAQPage structured data {%- endcomment -%}
{%- assign faq_has_items = false -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'faq_item' -%}
    {%- if block.settings.question != blank -%}
      {%- assign faq_has_items = true -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
{%- if faq_has_items -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- assign faq_printed = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'faq_item' -%}
        {%- if block.settings.question != blank -%}
          {%- if faq_printed > 0 -%},{%- endif -%}
          {
            "@type": "Question",
            "name": {{ block.settings.question | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ block.settings.answer | strip_html | json }}
            }
          }
          {%- assign faq_printed = faq_printed | plus: 1 -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{% stylesheet %}
  /* === Zenith FAQ Section === */

  .zn-faq {
    background-color: var(--color-base);
    padding: 80px 0;
  }

  .zn-faq__container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Header */

  .zn-faq__header {
    text-align: center;
    margin-bottom: 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .zn-faq__eyebrow {
    font-family: var(--font-body, sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
  }

  .zn-faq__heading {
    font-family: var(--font-display, sans-serif);
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0;
    line-height: 1.1;
  }

  /* Search */

  .zn-faq__search-wrap {
    margin-bottom: 24px;
  }

  .zn-faq__search-inner {
    position: relative;
  }

  .zn-faq__search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: color-mix(in srgb, var(--color-text) 40%, transparent);
    pointer-events: none;
  }

  .zn-faq__search {
    width: 100%;
    padding: 14px 16px 14px 48px;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    font-family: var(--font-body, sans-serif);
    font-size: 0.9375rem;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    box-sizing: border-box;
    -webkit-appearance: none;
  }

  .zn-faq__search::placeholder {
    color: color-mix(in srgb, var(--color-text) 30%, transparent);
  }

  .zn-faq__search:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(0, 212, 170, 0.12);
  }

  /* Category tabs */

  .zn-faq__tabs-wrap {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    margin-bottom: 32px;
    padding-bottom: 4px;
  }

  .zn-faq__tabs-wrap::-webkit-scrollbar {
    display: none;
  }

  .zn-faq__tab {
    flex-shrink: 0;
    padding: 8px 20px;
    border-radius: 999px;
    background: transparent;
    border: 1px solid var(--color-border);
    color: color-mix(in srgb, var(--color-text) 60%, transparent);
    font-family: var(--font-body, sans-serif);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    cursor: pointer;
    white-space: nowrap;
    transition: border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
  }

  .zn-faq__tab:hover {
    border-color: rgba(0, 212, 170, 0.4);
    color: var(--color-accent);
  }

  .zn-faq__tab--active {
    background: rgba(0, 212, 170, 0.1);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* FAQ list */

  .zn-faq__list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Individual item */

  .zn-faq__item {
    border-bottom: 1px solid var(--color-border);
    transition: opacity 0.15s ease;
  }

  .zn-faq__item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .zn-faq__item[data-hidden] {
    display: none;
  }

  /* Summary / Question */

  .zn-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 22px 0;
    cursor: pointer;
    list-style: none;
    -webkit-appearance: none;
    user-select: none;
  }

  .zn-faq__question::-webkit-details-marker {
    display: none;
  }

  .zn-faq__question:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .zn-faq__question-text {
    font-family: var(--font-body, sans-serif);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.45;
    flex: 1;
  }

  .zn-faq__icon {
    flex-shrink: 0;
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(0, 212, 170, 0.3);
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .zn-faq__item[open] .zn-faq__icon {
    background-color: rgba(0, 212, 170, 0.1);
    border-color: var(--color-accent);
  }

  .zn-faq__icon-minus {
    display: none;
  }

  .zn-faq__item[open] .zn-faq__icon-plus {
    display: none;
  }

  .zn-faq__item[open] .zn-faq__icon-minus {
    display: block;
  }

  /* Answer */

  .zn-faq__answer {
    padding: 0 0 24px;
    font-family: var(--font-body, sans-serif);
    font-size: 0.9375rem;
    line-height: 1.75;
    color: color-mix(in srgb, var(--color-text) 65%, transparent);
  }

  .zn-faq__answer p {
    margin: 0 0 12px;
  }

  .zn-faq__answer p:last-child {
    margin-bottom: 0;
  }

  .zn-faq__answer a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  /* Empty state */

  .zn-faq__empty {
    text-align: center;
    padding: 48px 0;
    font-family: var(--font-body, sans-serif);
    font-size: 0.9375rem;
    color: color-mix(in srgb, var(--color-text) 40%, transparent);
  }
{% endstylesheet %}

<script>
  (function () {
    'use strict';

    var section = document.querySelector('.zn-faq[data-section-id="{{ section.id }}"]');
    if (!section) return;

    var searchInput = section.querySelector('[data-faq-search]');
    var tabs = section.querySelectorAll('[data-faq-tab]');
    var items = section.querySelectorAll('[data-faq-item]');
    var emptyMsg = section.querySelector('[data-faq-empty]');
    var activeCategory = 'all';

    function filterItems() {
      var query = searchInput ? searchInput.value.trim().toLowerCase() : '';
      var visibleCount = 0;

      items.forEach(function (item) {
        var cat = item.getAttribute('data-category') || '';
        var question = item.getAttribute('data-question') || '';
        var answer = item.querySelector('.zn-faq__answer');
        var answerText = answer ? answer.textContent.toLowerCase() : '';

        var matchesCategory = activeCategory === 'all' || cat === activeCategory;
        var matchesSearch = query === '' || question.includes(query) || answerText.includes(query);

        if (matchesCategory && matchesSearch) {
          item.removeAttribute('data-hidden');
          visibleCount++;
        } else {
          item.setAttribute('data-hidden', '');
        }
      });

      if (emptyMsg) {
        emptyMsg.hidden = visibleCount > 0;
      }
    }

    // Search
    if (searchInput) {
      searchInput.addEventListener('input', filterItems);
    }

    // Category tabs
    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        tabs.forEach(function (t) {
          t.classList.remove('zn-faq__tab--active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('zn-faq__tab--active');
        tab.setAttribute('aria-selected', 'true');
        activeCategory = tab.getAttribute('data-faq-tab');
        filterItems();
      });
    });

  })();
</script>

{% schema %}
{
  "name": "t:sections.faq_section.name",
  "tag": "section",
  "class": "zenith-faq-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.faq_section.settings.eyebrow.label",
      "default": "Got questions?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.faq_section.settings.heading.label",
      "default": "Frequently asked questions"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "t:sections.faq_section.blocks.faq_item.name",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "t:sections.faq_section.blocks.faq_item.settings.question.label",
          "default": "What materials are your products made from?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "t:sections.faq_section.blocks.faq_item.settings.answer.label",
          "default": "<p>All Zenith products are crafted from premium, performance-grade materials selected for durability, comfort, and sustainability.</p>"
        },
        {
          "type": "text",
          "id": "category",
          "label": "t:sections.faq_section.blocks.faq_item.settings.category.label",
          "info": "t:sections.faq_section.blocks.faq_item.settings.category.info",
          "default": "Products"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.faq_section.name",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
