<section
  class="zn-brand-story section-snap{% if section.settings.enable_parallax %} zn-brand-story--parallax{% endif %}"
  data-section-id="{{ section.id }}"
>

  <div class="zn-brand-story__inner">

    {%- comment -%} Image side {%- endcomment -%}
    <div class="zn-brand-story__image-wrap" data-parallax-img>
      {% if section.settings.image %}
        {%- assign story_img_alt = section.settings.heading | default: shop.name | escape -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            alt: story_img_alt,
            class: 'zn-brand-story__image',
            loading: 'lazy',
            widths: '600, 900, 1200'
        }}
      {% else %}
        <div class="zn-brand-story__image-placeholder"></div>
      {% endif %}
      <div class="zn-brand-story__image-overlay"></div>
    </div>

    {%- comment -%} Text side {%- endcomment -%}
    <div class="zn-brand-story__content">

      {% if section.settings.eyebrow != blank %}
        <p class="zn-brand-story__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="zn-brand-story__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      <div class="zn-brand-story__accent-line" aria-hidden="true"></div>

      {% if section.settings.body_text != blank %}
        <div class="zn-brand-story__body">{{ section.settings.body_text }}</div>
      {% endif %}

      {% if section.settings.quote != blank %}
        <blockquote class="zn-brand-story__quote">
          {{ section.settings.quote }}
        </blockquote>
      {% endif %}

      {% if section.settings.button_text != blank %}
        <a
          href="{{ section.settings.button_url | default: routes.all_products_collection_url }}"
          class="zn-brand-story__cta"
        >
          {{ section.settings.button_text }}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="m5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {% endif %}

    </div>

  </div>

</section>

{% stylesheet %}
  /* === Zenith Brand Story === */

  .zn-brand-story {
    background-color: #0A0A0A;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .zn-brand-story__inner {
    display: grid;
    grid-template-columns: 1fr;
    width: 100%;
  }

  @media (min-width: 1024px) {
    .zn-brand-story__inner {
      grid-template-columns: 1fr 1fr;
      min-height: 100vh;
    }
  }

  /* Image side */

  .zn-brand-story__image-wrap {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .zn-brand-story__image-wrap {
      aspect-ratio: unset;
      min-height: 100vh;
    }
  }

  .zn-brand-story__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    will-change: transform;
    transform: scale(1.1);
  }

  .zn-brand-story__image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, #141414 0%, #1E1E1E 50%, #0A0A0A 100%);
  }

  .zn-brand-story__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(10, 10, 10, 0) 70%,
      rgba(10, 10, 10, 0.9) 100%
    );
  }

  @media (max-width: 1023px) {
    .zn-brand-story__image-overlay {
      background: linear-gradient(
        180deg,
        rgba(10, 10, 10, 0) 60%,
        rgba(10, 10, 10, 0.8) 100%
      );
    }
  }

  /* Content side */

  .zn-brand-story__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 24px;
    padding: 56px 40px;
    background-color: #0A0A0A;
  }

  @media (min-width: 1024px) {
    .zn-brand-story__content {
      padding: 80px 64px 80px 56px;
      max-width: 560px;
    }
  }

  .zn-brand-story__eyebrow {
    display: inline-flex;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #00D4AA;
    margin: 0;
  }

  .zn-brand-story__heading {
    font-family: 'Syne', var(--font-heading, sans-serif);
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: #F0F0F0;
    margin: 0;
  }

  /* Teal accent line */

  .zn-brand-story__accent-line {
    width: 56px;
    height: 3px;
    background: linear-gradient(90deg, #00D4AA, rgba(0, 212, 170, 0.3));
    border-radius: 2px;
  }

  .zn-brand-story__body {
    font-family: 'Source Serif 4', 'Georgia', serif;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: rgba(240, 240, 240, 0.72);
  }

  .zn-brand-story__body p {
    margin: 0 0 16px;
  }

  .zn-brand-story__body p:last-child {
    margin-bottom: 0;
  }

  .zn-brand-story__quote {
    border-left: 3px solid #00D4AA;
    padding: 8px 0 8px 20px;
    margin: 0;
    font-family: 'Source Serif 4', 'Georgia', serif;
    font-style: italic;
    font-size: 1.125rem;
    line-height: 1.65;
    color: rgba(240, 240, 240, 0.6);
  }

  .zn-brand-story__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: transparent;
    border: 2px solid rgba(0, 212, 170, 0.5);
    color: #00D4AA;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 8px;
    align-self: flex-start;
    transition: background-color 0.25s ease, border-color 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
  }

  .zn-brand-story__cta:hover {
    background-color: #00D4AA;
    border-color: #00D4AA;
    color: #0A0A0A;
    box-shadow: 0 0 24px rgba(0, 212, 170, 0.4);
    text-decoration: none;
  }

  .zn-brand-story__cta svg {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .zn-brand-story__cta:hover svg {
    transform: translateX(3px);
  }
{% endstylesheet %}

<script>
  (function () {
    'use strict';

    var section = document.querySelector('.zn-brand-story[data-section-id="{{ section.id }}"]');
    if (!section) return;

    {% if section.settings.enable_parallax %}
    var img = section.querySelector('[data-parallax-img] .zn-brand-story__image');
    if (!img) return;

    var ticking = false;

    function applyParallax() {
      var wrap = section.querySelector('[data-parallax-img]');
      var rect = wrap.getBoundingClientRect();
      var progress = (window.innerHeight / 2 - rect.top - rect.height / 2) / window.innerHeight;
      var offset = progress * 40;
      img.style.transform = 'scale(1.1) translateY(' + offset + 'px)';
      ticking = false;
    }

    window.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(applyParallax);
        ticking = true;
      }
    }, { passive: true });

    applyParallax();
    {% endif %}
  })();
</script>

{% schema %}
{
  "name": "t:sections.brand_story.name",
  "tag": "section",
  "class": "zenith-brand-story-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.brand_story.settings.image.label"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.brand_story.settings.eyebrow.label",
      "default": "Our story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.brand_story.settings.heading.label",
      "default": "Built for the relentless"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "t:sections.brand_story.settings.body_text.label",
      "default": "<p>We started Zenith because we believed premium fitness gear shouldn't come at a premium compromise. Every piece we make is engineered to endure the hardest sessions and look exceptional doing it.</p><p>From the weight room to the track, our athletes push limits and our gear pushes with them.</p>"
    },
    {
      "type": "text",
      "id": "quote",
      "label": "t:sections.brand_story.settings.quote.label",
      "default": "The only limit is the one you accept."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:sections.brand_story.settings.button_text.label",
      "default": "Learn more about us"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.brand_story.settings.button_url.label"
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "label": "t:sections.brand_story.settings.enable_parallax.label",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:sections.brand_story.name"
    }
  ]
}
{% endschema %}
