{%- assign play_label = 'sections.video_hero.play' | t -%}
{%- assign pause_label = 'sections.video_hero.pause' | t -%}

<section
  class="zn-video-hero section-snap"
  data-section-id="{{ section.id }}"
  data-video-hero
  style="--overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
>

  {%- comment -%} Background video {%- endcomment -%}
  <div class="zn-video-hero__bg">
    {% if section.settings.video_url != blank %}
      <video
        class="zn-video-hero__video"
        src="{{ section.settings.video_url }}"
        autoplay
        muted
        loop
        playsinline
        preload="none"
        data-video
        aria-hidden="true"
      ></video>
    {% else %}
      <div class="zn-video-hero__fallback"></div>
    {% endif %}
    <div class="zn-video-hero__overlay"></div>
  </div>

  {%- comment -%} Content {%- endcomment -%}
  <div class="zn-video-hero__content">

    {% if section.settings.heading != blank %}
      <h2 class="zn-video-hero__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="zn-video-hero__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    {% if section.settings.button_text != blank %}
      <a
        href="{{ section.settings.button_url | default: routes.all_products_collection_url }}"
        class="zn-video-hero__cta"
      >
        {{ section.settings.button_text }}
      </a>
    {% endif %}

  </div>

  {%- comment -%} Play/pause toggle {%- endcomment -%}
  {% if section.settings.video_url != blank %}
    <button
      class="zn-video-hero__play-toggle"
      aria-label="{{ pause_label }}"
      data-play-toggle
      data-playing="true"
    >
      <svg class="zn-video-hero__icon-pause" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <rect x="6" y="4" width="4" height="16" rx="1" fill="currentColor"/>
        <rect x="14" y="4" width="4" height="16" rx="1" fill="currentColor"/>
      </svg>
      <svg class="zn-video-hero__icon-play" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <polygon points="5,3 19,12 5,21" fill="currentColor"/>
      </svg>
    </button>
  {% endif %}

</section>

{% stylesheet %}
  /* === Zenith Video Hero === */

  .zn-video-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 560px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: #0A0A0A;
  }

  /* Background */

  .zn-video-hero__bg {
    position: absolute;
    inset: 0;
  }

  .zn-video-hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .zn-video-hero__fallback {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #0A0A0A, #1E1E1E);
  }

  .zn-video-hero__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(10, 10, 10, var(--overlay-opacity, 0.55));
  }

  /* Content */

  .zn-video-hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 24px;
    max-width: 860px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .zn-video-hero__heading {
    font-family: 'Syne', var(--font-heading, sans-serif);
    font-weight: 800;
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #F0F0F0;
    margin: 0;
  }

  .zn-video-hero__subheading {
    font-family: 'Inter', var(--font-body, sans-serif);
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.65;
    color: rgba(240, 240, 240, 0.78);
    margin: 0;
    max-width: 520px;
  }

  .zn-video-hero__cta {
    display: inline-flex;
    align-items: center;
    padding: 15px 36px;
    background: transparent;
    border: 2px solid #00D4AA;
    color: #00D4AA;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 8px;
    margin-top: 8px;
    transition: background-color 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
  }

  .zn-video-hero__cta:hover {
    background-color: #00D4AA;
    color: #0A0A0A;
    box-shadow: 0 0 28px rgba(0, 212, 170, 0.45);
    text-decoration: none;
  }

  .zn-video-hero__cta:focus-visible {
    outline: 2px solid #00D4AA;
    outline-offset: 3px;
  }

  /* Play/pause button */

  .zn-video-hero__play-toggle {
    position: absolute;
    bottom: 32px;
    right: 32px;
    z-index: 3;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(20, 20, 20, 0.7);
    border: 1px solid rgba(240, 240, 240, 0.2);
    color: #F0F0F0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .zn-video-hero__play-toggle:hover {
    background: rgba(0, 212, 170, 0.2);
    border-color: #00D4AA;
    color: #00D4AA;
  }

  .zn-video-hero__play-toggle:focus-visible {
    outline: 2px solid #00D4AA;
    outline-offset: 2px;
  }

  /* Icon toggle logic */

  .zn-video-hero__icon-play {
    display: none;
  }

  .zn-video-hero__play-toggle[data-playing="false"] .zn-video-hero__icon-pause {
    display: none;
  }

  .zn-video-hero__play-toggle[data-playing="false"] .zn-video-hero__icon-play {
    display: block;
  }
{% endstylesheet %}

<script>
  (function () {
    'use strict';

    var section = document.querySelector('.zn-video-hero[data-section-id="{{ section.id }}"]');
    if (!section) return;

    var video = section.querySelector('[data-video]');
    var toggle = section.querySelector('[data-play-toggle]');

    if (!video || !toggle) return;

    {%- assign pause_label = 'sections.video_hero.pause' | t | escape -%}
    {%- assign play_label = 'sections.video_hero.play' | t | escape -%}

    toggle.addEventListener('click', function () {
      if (video.paused) {
        video.play();
        toggle.setAttribute('data-playing', 'true');
        toggle.setAttribute('aria-label', '{{ pause_label }}');
      } else {
        video.pause();
        toggle.setAttribute('data-playing', 'false');
        toggle.setAttribute('aria-label', '{{ play_label }}');
      }
    });

    // Pause video when section scrolls out of view (IntersectionObserver)
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) {
            if (!video.paused) video.pause();
          } else {
            if (video.paused && toggle.getAttribute('data-playing') === 'true') {
              video.play();
            }
          }
        });
      }, { threshold: 0.2 });
      observer.observe(section);
    }
  })();
</script>

{% schema %}
{
  "name": "t:sections.video_hero.name",
  "tag": "section",
  "class": "zenith-video-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "t:sections.video_hero.settings.video_url.label",
      "info": "t:sections.video_hero.settings.video_url.info"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.video_hero.settings.heading.label",
      "default": "Every rep counts"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.video_hero.settings.subheading.label",
      "default": "Gear designed for the relentless pursuit of greatness."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:sections.video_hero.settings.button_text.label",
      "default": "Explore now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.video_hero.settings.button_url.label"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.video_hero.settings.overlay_opacity.label",
      "min": 10,
      "max": 90,
      "step": 5,
      "default": 55,
      "unit": "%"
    }
  ],
  "presets": [
    {
      "name": "t:sections.video_hero.name"
    }
  ]
}
{% endschema %}
