{% stylesheet %}
  .comparison-table {
    padding: 80px 0;
    background: var(--color-base);
    overflow: hidden;
  }

  .comparison-table__container {
    max-width: var(--page-width, 1280px);
    margin: 0 auto;
    padding: 0 20px;
  }

  .comparison-table__header {
    text-align: center;
    margin-bottom: 56px;
  }

  .comparison-table__eyebrow {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 16px;
  }

  .comparison-table__heading {
    font-family: var(--font-display, 'Syne', sans-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 14px;
    letter-spacing: -0.03em;
  }

  .comparison-table__subtitle {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 1rem;
    color: var(--color-text-muted);
    margin: 0 auto;
    max-width: 480px;
    line-height: 1.6;
  }

  /* Table wrapper for horizontal scroll on mobile */
  .comparison-table__wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--border-radius-lg, 16px);
    border: 1px solid var(--color-border);
  }

  .comparison-table__table {
    width: 100%;
    border-collapse: collapse;
    min-width: 520px;
  }

  /* Header row */
  .comparison-table__table thead th {
    background: var(--color-surface);
    padding: 0;
    vertical-align: top;
    position: sticky;
    top: 0;
    z-index: 2;
  }

  .comparison-table__table thead th:first-child {
    width: 35%;
    background: var(--color-surface);
    border-right: 1px solid var(--color-border);
  }

  .comparison-table__col-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    border-left: 1px solid var(--color-border);
    padding: 28px 24px;
    text-align: center;
    position: relative;
  }

  .comparison-table__col-header--featured {
    background: rgba(0, 212, 170, 0.06);
    border-left-color: rgba(0, 212, 170, 0.25);
    border-right: 1px solid rgba(0, 212, 170, 0.25);
  }

  /* Popular badge */
  .comparison-table__popular-badge {
    display: inline-block;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--color-accent);
    color: var(--color-text-inverse, #0A0A0A);
    padding: 3px 10px;
    border-radius: 100px;
    margin-bottom: 10px;
    display: block;
  }

  .comparison-table__col-name {
    font-family: var(--font-display, 'Syne', sans-serif);
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 4px;
    letter-spacing: -0.02em;
  }

  .comparison-table__col-name--featured {
    color: var(--color-accent);
  }

  .comparison-table__col-price {
    font-family: var(--font-display, 'Syne', sans-serif);
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-text);
    margin: 8px 0 4px;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .comparison-table__col-price--featured {
    color: var(--color-accent);
  }

  .comparison-table__col-price-period {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 16px;
  }

  .comparison-table__col-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 10px 20px;
    border-radius: var(--border-radius, 8px);
    transition: opacity var(--transition-fast, 150ms ease),
                box-shadow var(--transition-base, 250ms ease);
  }

  .comparison-table__col-btn:hover {
    text-decoration: none;
  }

  .comparison-table__col-btn--featured {
    background: var(--color-accent);
    color: var(--color-text-inverse, #0A0A0A);
    box-shadow: var(--glow-accent);
  }

  .comparison-table__col-btn--featured:hover {
    opacity: 0.88;
    box-shadow: var(--glow-accent-strong);
    color: var(--color-text-inverse, #0A0A0A);
  }

  .comparison-table__col-btn--default {
    background: transparent;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .comparison-table__col-btn--default:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Feature rows */
  .comparison-table__table tbody tr {
    border-bottom: 1px solid var(--color-border);
    transition: background var(--transition-fast, 150ms ease);
  }

  .comparison-table__table tbody tr:last-child {
    border-bottom: none;
  }

  .comparison-table__table tbody tr:hover {
    background: rgba(240, 240, 240, 0.02);
  }

  .comparison-table__table tbody td {
    padding: 16px 20px;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    vertical-align: middle;
  }

  /* Feature name cell */
  .comparison-table__table tbody td:first-child {
    color: var(--color-text);
    font-weight: 500;
    border-right: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  /* Value cells */
  .comparison-table__table tbody td:not(:first-child) {
    text-align: center;
    border-left: 1px solid var(--color-border);
    background: var(--color-base);
  }

  .comparison-table__table tbody td.is-featured-col {
    background: rgba(0, 212, 170, 0.03);
    border-left-color: rgba(0, 212, 170, 0.2);
    border-right-color: rgba(0, 212, 170, 0.2);
  }

  /* Check / X icons */
  .ct-check {
    color: var(--color-accent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .ct-x {
    color: var(--color-border);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  /* Text value */
  .ct-value {
    color: var(--color-text);
    font-weight: 600;
    font-size: 0.875rem;
  }

  @media (max-width: 767px) {
    .comparison-table {
      padding: 56px 0;
    }
    .comparison-table__container {
      padding: 0 12px;
    }
  }
{% endstylesheet %}

<section class="comparison-table" data-section-id="{{ section.id }}">
  <div class="comparison-table__container">

    <header class="comparison-table__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="comparison-table__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="comparison-table__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="comparison-table__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </header>

    <div class="comparison-table__wrap">
      <table class="comparison-table__table" role="table">
        <thead>
          <tr>
            <th scope="col"></th>

            {%- comment -%} Column 1 {%- endcomment -%}
            <th scope="col" aria-label="{{ section.settings.col1_name }}">
              <div class="comparison-table__col-header">
                <div class="comparison-table__col-name">{{ section.settings.col1_name }}</div>
                {%- if section.settings.col1_price != blank -%}
                  <div class="comparison-table__col-price">{{ section.settings.col1_price }}</div>
                  <span class="comparison-table__col-price-period">{{ section.settings.col1_period }}</span>
                {%- endif -%}
                {%- if section.settings.col1_button_label != blank -%}
                  <a
                    href="{{ section.settings.col1_button_url | default: routes.all_products_collection_url }}"
                    class="comparison-table__col-btn comparison-table__col-btn--default"
                  >{{ section.settings.col1_button_label }}</a>
                {%- endif -%}
              </div>
            </th>

            {%- comment -%} Column 2 (featured) {%- endcomment -%}
            <th scope="col" aria-label="{{ section.settings.col2_name }}">
              <div class="comparison-table__col-header comparison-table__col-header--featured">
                {%- if section.settings.col2_popular -%}
                  <span class="comparison-table__popular-badge">{{ 'comparison.most_popular' | t }}</span>
                {%- endif -%}
                <div class="comparison-table__col-name comparison-table__col-name--featured">{{ section.settings.col2_name }}</div>
                {%- if section.settings.col2_price != blank -%}
                  <div class="comparison-table__col-price comparison-table__col-price--featured">{{ section.settings.col2_price }}</div>
                  <span class="comparison-table__col-price-period">{{ section.settings.col2_period }}</span>
                {%- endif -%}
                {%- if section.settings.col2_button_label != blank -%}
                  <a
                    href="{{ section.settings.col2_button_url | default: routes.all_products_collection_url }}"
                    class="comparison-table__col-btn comparison-table__col-btn--featured"
                  >{{ section.settings.col2_button_label }}</a>
                {%- endif -%}
              </div>
            </th>

            {%- comment -%} Column 3 {%- endcomment -%}
            {%- if section.settings.show_col3 -%}
              <th scope="col" aria-label="{{ section.settings.col3_name }}">
                <div class="comparison-table__col-header">
                  <div class="comparison-table__col-name">{{ section.settings.col3_name }}</div>
                  {%- if section.settings.col3_price != blank -%}
                    <div class="comparison-table__col-price">{{ section.settings.col3_price }}</div>
                    <span class="comparison-table__col-price-period">{{ section.settings.col3_period }}</span>
                  {%- endif -%}
                  {%- if section.settings.col3_button_label != blank -%}
                    <a
                      href="{{ section.settings.col3_button_url | default: routes.all_products_collection_url }}"
                      class="comparison-table__col-btn comparison-table__col-btn--default"
                    >{{ section.settings.col3_button_label }}</a>
                  {%- endif -%}
                </div>
              </th>
            {%- endif -%}

          </tr>
        </thead>

        <tbody>
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature_row' -%}
              <tr {{ block.shopify_attributes }}>
                <td>{{ block.settings.feature_name }}</td>

                {%- comment -%} Col 1 value {%- endcomment -%}
                <td>
                  {%- assign v1 = block.settings.col1_value -%}
                  {%- if v1 == 'yes' -%}
                    <span class="ct-check" aria-label="{{ 'comparison.included' | t }}">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    </span>
                  {%- elsif v1 == 'no' -%}
                    <span class="ct-x" aria-label="{{ 'comparison.not_included' | t }}">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </span>
                  {%- elsif v1 != blank -%}
                    <span class="ct-value">{{ v1 }}</span>
                  {%- else -%}
                    <span class="ct-x" aria-hidden="true">—</span>
                  {%- endif -%}
                </td>

                {%- comment -%} Col 2 value {%- endcomment -%}
                <td class="is-featured-col">
                  {%- assign v2 = block.settings.col2_value -%}
                  {%- if v2 == 'yes' -%}
                    <span class="ct-check" aria-label="{{ 'comparison.included' | t }}">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    </span>
                  {%- elsif v2 == 'no' -%}
                    <span class="ct-x" aria-label="{{ 'comparison.not_included' | t }}">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </span>
                  {%- elsif v2 != blank -%}
                    <span class="ct-value">{{ v2 }}</span>
                  {%- else -%}
                    <span class="ct-x" aria-hidden="true">—</span>
                  {%- endif -%}
                </td>

                {%- comment -%} Col 3 value {%- endcomment -%}
                {%- if section.settings.show_col3 -%}
                  <td>
                    {%- assign v3 = block.settings.col3_value -%}
                    {%- if v3 == 'yes' -%}
                      <span class="ct-check" aria-label="{{ 'comparison.included' | t }}">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                      </span>
                    {%- elsif v3 == 'no' -%}
                      <span class="ct-x" aria-label="{{ 'comparison.not_included' | t }}">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                      </span>
                    {%- elsif v3 != blank -%}
                      <span class="ct-value">{{ v3 }}</span>
                    {%- else -%}
                      <span class="ct-x" aria-hidden="true">—</span>
                    {%- endif -%}
                  </td>
                {%- endif -%}

              </tr>
            {%- endif -%}
          {%- endfor -%}
        </tbody>
      </table>
    </div>

  </div>
</section>

