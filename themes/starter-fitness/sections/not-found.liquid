<section class="not-found">
  <div class="not-found__bg" aria-hidden="true">
    <div class="not-found__bg-glow not-found__bg-glow--1"></div>
    <div class="not-found__bg-glow not-found__bg-glow--2"></div>
  </div>

  <div class="container not-found__content">
    <div class="not-found__code-wrap reveal">
      <span class="not-found__code gradient-text" aria-hidden="true">404</span>
    </div>

    <div class="not-found__body reveal reveal--delay-1">
      <span class="eyebrow">{{ 'not_found.eyebrow' | t }}</span>
      <h1 class="not-found__heading">{{ section.settings.heading }}</h1>
      <p class="not-found__message">{{ section.settings.message }}</p>

      <div class="not-found__actions">
        <a href="{{ section.settings.button_url | default: '/' }}" class="btn btn--primary btn--lg">
          {{ section.settings.button_label }}
        </a>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--secondary">
          {{ 'not_found.shop_all' | t }}
        </a>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .not-found {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--color-base);
  }

  .not-found__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .not-found__bg-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.12;
  }

  .not-found__bg-glow--1 {
    width: 600px;
    height: 600px;
    background: var(--color-accent);
    top: -150px;
    left: -100px;
  }

  .not-found__bg-glow--2 {
    width: 400px;
    height: 400px;
    background: var(--color-accent-secondary);
    bottom: -100px;
    right: -80px;
  }

  .not-found__content {
    position: relative;
    z-index: 1;
    padding-block: 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;
  }

  .not-found__code-wrap {
    line-height: 1;
    margin-bottom: 24px;
    user-select: none;
  }

  .not-found__code {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(7rem, 20vw, 18rem);
    letter-spacing: -0.05em;
    display: block;
  }

  .not-found__body {
    max-width: 540px;
  }

  .not-found__body .eyebrow {
    display: block;
    margin-bottom: 16px;
  }

  .not-found__heading {
    font-family: var(--font-display);
    font-size: calc(2rem * var(--font-scale-factor));
    color: var(--color-text);
    margin-bottom: 16px;
  }

  .not-found__message {
    font-size: calc(1.0625rem * var(--font-scale-factor));
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .not-found__actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (min-width: 768px) {
    .not-found__heading {
      font-size: calc(2.75rem * var(--font-scale-factor));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.not_found.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.not_found.settings.heading.label",
      "default": "Page not found"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "t:sections.not_found.settings.message.label",
      "default": "The page you are looking for does not exist or has been moved."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.not_found.settings.button_label.label",
      "default": "Back to home"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.not_found.settings.button_url.label",
      "default": "/"
    }
  ],
  "presets": [
    {
      "name": "t:sections.not_found.presets.default.name"
    }
  ]
}
{% endschema %}
