<section class="customer-auth section-padding">
  <div class="container customer-auth__wrapper">

    <div class="customer-auth__card card reveal">
      <div class="customer-auth__card-header">
        <span class="eyebrow">{{ 'customer.welcome_back' | t }}</span>
        <h1 class="customer-auth__title">{{ 'customer.login_title' | t }}</h1>
      </div>

      {% form 'customer_login' %}
        {{ form.errors | default_errors }}

        <div class="form-group">
          <label for="customer-email">{{ 'customer.email' | t }}</label>
          <input
            type="email"
            id="customer-email"
            name="customer[email]"
            autocomplete="email"
            required
            aria-required="true"
          >
        </div>

        <div class="form-group">
          <label for="customer-password">{{ 'customer.password' | t }}</label>
          <div class="customer-auth__password-wrap">
            <input
              type="password"
              id="customer-password"
              name="customer[password]"
              autocomplete="current-password"
              required
              aria-required="true"
            >
            <button
              type="button"
              class="customer-auth__toggle-pw"
              aria-label="{{ 'customer.show_password' | t }}"
              data-pw-toggle="customer-password"
            >
              <svg class="icon-eye-show" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
              <svg class="icon-eye-hide" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="display:none">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
                <line x1="1" y1="1" x2="23" y2="23"></line>
              </svg>
            </button>
          </div>
        </div>

        <div class="customer-auth__forgot">
          <a href="{{ routes.account_login_url }}#recover">{{ 'customer.forgot_password' | t }}</a>
        </div>

        <button type="submit" class="btn btn--primary btn--full-width btn--lg">
          {{ 'customer.submit_login' | t }}
        </button>
      {% endform %}

      <div class="customer-auth__divider">
        <span>{{ 'customer.or' | t }}</span>
      </div>

      <a href="{{ routes.account_register_url }}" class="btn btn--ghost btn--full-width">
        {{ 'customer.create_account' | t }}
      </a>
    </div>

  </div>
</section>

{% stylesheet %}
  .customer-auth__wrapper {
    display: flex;
    justify-content: center;
    padding-block: var(--section-padding-mobile);
  }

  .customer-auth__card {
    width: 100%;
    max-width: 480px;
    padding: 40px 32px;
    background: var(--color-surface);
  }

  .customer-auth__card-header {
    margin-bottom: 32px;
    text-align: center;
  }

  .customer-auth__card-header .eyebrow {
    display: block;
    margin-bottom: 10px;
  }

  .customer-auth__title {
    font-family: var(--font-display);
    font-size: calc(1.75rem * var(--font-scale-factor));
    color: var(--color-text);
  }

  .customer-auth__password-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .customer-auth__password-wrap input {
    padding-right: 44px;
  }

  .customer-auth__toggle-pw {
    position: absolute;
    right: 12px;
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
    display: flex;
    align-items: center;
    padding: 4px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .customer-auth__toggle-pw:hover {
    color: var(--color-accent);
  }

  .customer-auth__forgot {
    text-align: right;
    margin-bottom: 24px;
    margin-top: -8px;
  }

  .customer-auth__forgot a {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--transition-fast);
  }

  .customer-auth__forgot a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .customer-auth__divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 24px 0;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }

  .customer-auth__divider::before,
  .customer-auth__divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  /* Error styles */
  .customer-auth__card .errors,
  .customer-auth__card .form-errors {
    background: rgba(255, 107, 107, 0.1);
    border: 1px solid var(--color-error);
    border-radius: var(--border-radius);
    padding: 12px 16px;
    margin-bottom: 20px;
    font-size: 0.9375rem;
    color: var(--color-error);
  }

  .customer-auth__card .errors ul,
  .customer-auth__card .form-errors ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .customer-auth__card .errors li,
  .customer-auth__card .form-errors li {
    margin-bottom: 4px;
  }

  .customer-auth__card .errors li:last-child,
  .customer-auth__card .form-errors li:last-child {
    margin-bottom: 0;
  }

  @media (min-width: 768px) {
    .customer-auth__wrapper {
      padding-block: var(--section-padding-tablet);
    }
  }

  @media (min-width: 1024px) {
    .customer-auth__wrapper {
      padding-block: var(--section-padding-desktop);
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var toggleBtns = document.querySelectorAll('[data-pw-toggle]');
    toggleBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var input = document.getElementById(btn.dataset.pwToggle);
        if (!input) return;
        var isHidden = input.type === 'password';
        input.type = isHidden ? 'text' : 'password';
        var showIcon = btn.querySelector('.icon-eye-show');
        var hideIcon = btn.querySelector('.icon-eye-hide');
        if (showIcon) showIcon.style.display = isHidden ? 'none' : '';
        if (hideIcon) hideIcon.style.display = isHidden ? '' : 'none';
        btn.setAttribute('aria-label', isHidden ? '{{ 'customer.hide_password' | t }}' : '{{ 'customer.show_password' | t }}');
      });
    });
  })();
</script>

{% schema %}
{
  "name": "t:sections.customer_login.name",
  "settings": [],
  "presets": [
    {
      "name": "t:sections.customer_login.presets.default.name"
    }
  ]
}
{% endschema %}
