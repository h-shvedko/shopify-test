{%- liquid
  assign bg_alt = section.settings.background_image.alt | escape | default: section.settings.heading | escape
  assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0
-%}

{% stylesheet %}
  .cta-banner {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--color-surface);
  }

  @media (min-width: 768px) {
    .cta-banner {
      min-height: 640px;
    }
  }

  /* Background image */
  .cta-banner__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .cta-banner__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transform: scale(1.04);
    transition: transform 8s ease;
  }

  .cta-banner:hover .cta-banner__bg-img {
    transform: scale(1.0);
  }

  /* Cinematic dark overlay */
  .cta-banner__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(10,10,10,0.2) 0%,
      rgba(10,10,10,0.55) 50%,
      rgba(10,10,10,0.8) 100%
    );
  }

  /* Grain texture */
  .cta-banner__grain {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    opacity: 0.025;
  }

  /* Content */
  .cta-banner__content {
    position: relative;
    z-index: 3;
    text-align: center;
    padding: 80px 20px;
    max-width: 760px;
    margin: 0 auto;
    width: 100%;
  }

  .cta-banner__eyebrow {
    display: inline-block;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid rgba(0, 212, 170, 0.35);
    background: rgba(0, 212, 170, 0.08);
    padding: 5px 14px;
    border-radius: 100px;
    margin: 0 0 24px;
  }

  .cta-banner__heading {
    font-family: var(--font-display, 'Syne', sans-serif);
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 800;
    color: var(--color-text, #F0F0F0);
    margin: 0 0 20px;
    line-height: 1.0;
    letter-spacing: -0.04em;
  }

  .cta-banner__subheading {
    font-family: var(--font-serif, 'Source Serif 4', Georgia, serif);
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: rgba(240, 240, 240, 0.75);
    line-height: 1.65;
    margin: 0 0 40px;
    font-style: italic;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 40px;
  }

  .cta-banner__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .cta-banner__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display, 'Syne', sans-serif);
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 16px 36px;
    border-radius: var(--border-radius, 8px);
    transition: opacity var(--transition-fast, 150ms ease),
                transform var(--transition-fast, 150ms ease),
                box-shadow var(--transition-base, 250ms ease);
    border: none;
    cursor: pointer;
    white-space: nowrap;
  }

  .cta-banner__btn:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 3px;
  }

  .cta-banner__btn--primary {
    background: var(--color-accent);
    color: var(--color-text-inverse, #0A0A0A);
    box-shadow: var(--glow-accent, 0 0 20px rgba(0,212,170,0.25));
  }

  .cta-banner__btn--primary:hover {
    opacity: 0.9;
    transform: translateY(-2px);
    box-shadow: var(--glow-accent-strong, 0 0 40px rgba(0,212,170,0.4));
    text-decoration: none;
    color: var(--color-text-inverse, #0A0A0A);
  }

  .cta-banner__btn--secondary {
    background: transparent;
    color: var(--color-text, #F0F0F0);
    border: 1px solid rgba(240, 240, 240, 0.35);
  }

  .cta-banner__btn--secondary:hover {
    background: rgba(240, 240, 240, 0.08);
    border-color: rgba(240, 240, 240, 0.6);
    text-decoration: none;
    color: var(--color-text, #F0F0F0);
    transform: translateY(-1px);
  }

  @media (max-width: 767px) {
    .cta-banner {
      min-height: 420px;
    }
    .cta-banner__actions {
      flex-direction: column;
      align-items: stretch;
    }
    .cta-banner__btn {
      justify-content: center;
    }
  }
{% endstylesheet %}

<section class="cta-banner" data-section-id="{{ section.id }}">

  {%- if section.settings.background_image != blank -%}
    <div class="cta-banner__bg" aria-hidden="true">
      <img
        class="cta-banner__bg-img"
        src="{{ section.settings.background_image | image_url: width: 2000 }}"
        alt="{{ bg_alt }}"
        width="2000"
        height="1000"
        loading="lazy"
      >
    </div>
  {%- else -%}
    <div class="cta-banner__bg" style="background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-surface-raised) 100%);" aria-hidden="true"></div>
  {%- endif -%}

  <div
    class="cta-banner__overlay"
    aria-hidden="true"
    style="opacity: {{ overlay_alpha }};"
  ></div>
  <div class="cta-banner__grain" aria-hidden="true"></div>

  <div class="cta-banner__content">

    {%- if section.settings.eyebrow != blank -%}
      <span class="cta-banner__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="cta-banner__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="cta-banner__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="cta-banner__actions">
      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_url | default: routes.all_products_collection_url }}"
          class="cta-banner__btn cta-banner__btn--primary"
        >
          {{ section.settings.button_label }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      {%- endif -%}

      {%- if section.settings.secondary_button_label != blank -%}
        <a
          href="{{ section.settings.secondary_button_url | default: routes.all_products_collection_url }}"
          class="cta-banner__btn cta-banner__btn--secondary"
        >
          {{ section.settings.secondary_button_label }}
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "CTA banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Dark overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 65,
      "unit": "%"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Elevate your performance"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Engineered for the dedicated few."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label"
    },
    {
      "type": "url",
      "id": "secondary_button_url",
      "label": "Secondary button URL"
    }
  ],
  "presets": [
    { "name": "CTA banner" }
  ]
}
{% endschema %}
