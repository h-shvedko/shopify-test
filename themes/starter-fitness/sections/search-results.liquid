{% paginate search.results by section.settings.results_per_page %}

<section class="search-results section-padding">
  <div class="container">

    <div class="search-results__header reveal">
      <h1 class="search-results__title">{{ 'search.title' | t }}</h1>
    </div>

    <form
      action="{{ routes.search_url }}"
      method="get"
      class="search-results__form reveal reveal--delay-1"
      role="search"
    >
      <input type="hidden" name="type" value="product,article,page">
      <label for="search-input" class="visually-hidden">{{ 'search.placeholder' | t }}</label>
      <div class="search-results__input-wrapper">
        <svg class="search-results__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
          type="search"
          id="search-input"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'search.placeholder' | t }}"
          autocomplete="off"
          aria-label="{{ 'search.placeholder' | t }}"
        >
        {%- if search.terms != blank -%}
          <a href="{{ routes.search_url }}" class="search-results__clear" aria-label="{{ 'search.clear' | t }}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </a>
        {%- endif -%}
      </div>
      <button type="submit" class="btn btn--primary">{{ 'general.search' | t }}</button>
    </form>

    {%- if search.performed -%}

      {%- if search.results_count > 0 -%}
        <p class="search-results__count reveal">
          {{ 'search.results_count' | t: count: search.results_count, query: search.terms }}
        </p>

        <div class="search-results__grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              <a href="{{ item.url }}" class="search-result-card card reveal" style="--reveal-delay: {{ forloop.index | times: 50 }}ms">
                <div class="search-result-card__image">
                  {%- if item.featured_image -%}
                    {%- assign item_img_alt = item.title -%}
                    {{ item.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', alt: item_img_alt, width: 400, height: 400 }}
                  {%- else -%}
                    <div class="search-result-card__image-placeholder" aria-hidden="true">
                      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <circle cx="8.5" cy="8.5" r="1.5"></circle>
                        <polyline points="21 15 16 10 5 21"></polyline>
                      </svg>
                    </div>
                  {%- endif -%}
                  {%- if item.available == false -%}
                    <span class="badge badge--neutral search-result-card__badge">{{ 'badges.sold_out' | t }}</span>
                  {%- elsif item.compare_at_price > item.price -%}
                    <span class="badge badge--coral search-result-card__badge">{{ 'badges.sale' | t }}</span>
                  {%- endif -%}
                </div>
                <div class="search-result-card__body">
                  <h3 class="search-result-card__title">{{ item.title }}</h3>
                  {%- if item.vendor != blank -%}
                    <p class="search-result-card__vendor">{{ item.vendor }}</p>
                  {%- endif -%}
                  <div class="search-result-card__pricing">
                    {%- if item.compare_at_price > item.price -%}
                      <span class="price--compare">{{ item.compare_at_price | money }}</span>
                      <span class="price price--sale">{{ item.price | money }}</span>
                    {%- else -%}
                      <span class="price">{{ item.price | money }}</span>
                    {%- endif -%}
                  </div>
                </div>
              </a>
            {%- else -%}
              <a href="{{ item.url }}" class="search-result-article card reveal">
                <div class="search-result-article__body">
                  {%- if item.object_type == 'article' -%}
                    <span class="eyebrow">{{ 'search.type_article' | t }}</span>
                  {%- elsif item.object_type == 'page' -%}
                    <span class="eyebrow">{{ 'search.type_page' | t }}</span>
                  {%- endif -%}
                  <h3 class="search-result-article__title">{{ item.title }}</h3>
                  {%- if item.content != blank -%}
                    <p class="search-result-article__excerpt">{{ item.content | strip_html | truncate: 140 }}</p>
                  {%- endif -%}
                  <span class="search-result-article__link">{{ 'search.read_more' | t }} →</span>
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="pagination" aria-label="{{ 'pagination.label' | t }}">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="pagination__item" aria-label="{{ 'pagination.previous' | t }}">
                ← {{ 'pagination.previous' | t }}
              </a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="pagination__item">{{ part.title }}</a>
              {%- else -%}
                {%- if part.title == paginate.current_page -%}
                  <span class="pagination__item pagination__item--active" aria-current="page">{{ part.title }}</span>
                {%- else -%}
                  <span class="pagination__item">{{ part.title }}</span>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="pagination__item" aria-label="{{ 'pagination.next' | t }}">
                {{ 'pagination.next' | t }} →
              </a>
            {%- endif -%}
          </nav>
        {%- endif -%}

      {%- else -%}
        <div class="search-no-results reveal">
          <div class="search-no-results__icon" aria-hidden="true">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              <line x1="8" y1="11" x2="14" y2="11"></line>
            </svg>
          </div>
          <h2 class="search-no-results__heading">{{ 'search.no_results' | t: query: search.terms }}</h2>
          <p class="search-no-results__hint">{{ 'search.no_results_hint' | t }}</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--secondary">
            {{ 'search.browse_products' | t }}
          </a>
        </div>
      {%- endif -%}

    {%- endif -%}

  </div>
</section>

{% endpaginate %}

{% stylesheet %}
  .search-results {
    background: var(--color-base);
  }

  .search-results__header {
    margin-bottom: 32px;
  }

  .search-results__title {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }

  /* ── Search form ── */
  .search-results__form {
    display: flex;
    gap: 12px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .search-results__input-wrapper {
    flex: 1;
    min-width: 240px;
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-results__icon {
    position: absolute;
    left: 14px;
    color: var(--color-text-secondary);
    pointer-events: none;
    flex-shrink: 0;
  }

  .search-results__input-wrapper input[type="search"] {
    padding-left: 44px;
    padding-right: 40px;
    background: var(--color-surface);
    border-color: var(--color-border);
  }

  .search-results__input-wrapper input[type="search"]:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(0, 212, 170, 0.15);
  }

  .search-results__clear {
    position: absolute;
    right: 12px;
    display: flex;
    align-items: center;
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }

  .search-results__clear:hover {
    color: var(--color-accent-secondary);
    text-decoration: none;
  }

  /* ── Count ── */
  .search-results__count {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin-bottom: 28px;
  }

  /* ── Results grid ── */
  .search-results__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--grid-gap-mobile);
    margin-bottom: 48px;
  }

  /* ── Product card ── */
  .search-result-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .search-result-card__image {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--color-surface);
  }

  .search-result-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .search-result-card:hover .search-result-card__image img {
    transform: scale(1.04);
  }

  .search-result-card__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-border);
  }

  .search-result-card__badge {
    position: absolute;
    top: 10px;
    left: 10px;
  }

  .search-result-card__body {
    padding: 16px;
    flex: 1;
  }

  .search-result-card__title {
    font-family: var(--font-display);
    font-size: calc(0.9375rem * var(--font-scale-factor));
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 4px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-result-card:hover .search-result-card__title {
    color: var(--color-accent);
  }

  .search-result-card__vendor {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
  }

  .search-result-card__pricing {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  /* ── Article result ── */
  .search-result-article {
    text-decoration: none;
    padding: 24px;
    display: block;
  }

  .search-result-article__body .eyebrow {
    margin-bottom: 8px;
  }

  .search-result-article__title {
    font-family: var(--font-display);
    font-size: calc(1.0625rem * var(--font-scale-factor));
    color: var(--color-text);
    margin-bottom: 10px;
    transition: color var(--transition-fast);
  }

  .search-result-article:hover .search-result-article__title {
    color: var(--color-accent);
  }

  .search-result-article__excerpt {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .search-result-article__link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  /* ── No results ── */
  .search-no-results {
    text-align: center;
    padding: 80px 0;
  }

  .search-no-results__icon {
    color: var(--color-border);
    margin-bottom: 24px;
    display: flex;
    justify-content: center;
  }

  .search-no-results__heading {
    font-size: calc(1.375rem * var(--font-scale-factor));
    margin-bottom: 12px;
    color: var(--color-text);
  }

  .search-no-results__hint {
    color: var(--color-text-secondary);
    margin-bottom: 32px;
    font-size: 1rem;
  }

  @media (min-width: 768px) {
    .search-results__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--grid-gap-tablet);
    }
  }

  @media (min-width: 1024px) {
    .search-results__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--grid-gap-desktop);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.search_results.name",
  "settings": [
    {
      "type": "range",
      "id": "results_per_page",
      "label": "t:sections.search_results.settings.results_per_page.label",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "t:sections.search_results.presets.default.name"
    }
  ]
}
{% endschema %}
