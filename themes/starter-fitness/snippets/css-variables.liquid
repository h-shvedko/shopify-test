{% doc %}
  Renders all Zenith theme settings as CSS custom properties on :root.
  Must be included in <head> after critical.css so runtime values override
  fallback variables. Emits font-face declarations for display, body, and
  serif fonts each wrapped in its own <style> tag.

  Also outputs dark/light mode variable swaps via a [data-theme="light"]
  selector so the dark-mode-toggle snippet can flip the palette.

  Parameters: none — reads directly from the global `settings` object.

  Usage:
    {% render 'css-variables' %}
{% enddoc %}

<style>
  :root {
    /* ── Core palette ── */
    --color-base:            {{ settings.color_base | default: '#0A0A0A' }};
    --color-surface:         {{ settings.color_surface | default: '#141414' }};
    --color-surface-raised:  {{ settings.color_surface_raised | default: '#1E1E1E' }};
    --color-accent:          {{ settings.color_accent | default: '#00D4AA' }};
    --color-accent-dark:     {{ settings.color_accent_dark | default: '#00A888' }};
    --color-secondary:       {{ settings.color_secondary | default: '#FF6B6B' }};
    --color-secondary-dark:  {{ settings.color_secondary_dark | default: '#E55555' }};
    --color-text:            {{ settings.color_text | default: '#F0F0F0' }};
    --color-text-muted:      {{ settings.color_text_muted | default: '#9A9A9A' }};
    --color-text-inverse:    {{ settings.color_text_inverse | default: '#0A0A0A' }};
    --color-border:          {{ settings.color_border | default: '#2A2A2A' }};
    --color-border-accent:   {{ settings.color_accent | default: '#00D4AA' }};
    --color-error:           #FF6B6B;
    --color-success:         #00D4AA;

    /* ── Typography ── */
    --font-display:          {{ settings.font_display.family | default: 'Syne' }}, 'Arial Black', sans-serif;
    --font-display-weight:   {{ settings.font_display.weight | default: 700 }};
    --font-body:             {{ settings.font_body.family | default: 'Inter' }}, system-ui, sans-serif;
    --font-body-weight:      {{ settings.font_body.weight | default: 400 }};
    --font-serif:            {{ settings.font_serif.family | default: 'Source Serif 4' }}, Georgia, serif;
    --font-serif-weight:     {{ settings.font_serif.weight | default: 400 }};
    --font-scale-factor:     {{ settings.font_scale | default: 100 | divided_by: 100.0 }};

    /* ── Layout ── */
    --page-width:            {{ settings.page_width | default: 1280 }}px;
    --border-radius:         {{ settings.border_radius | default: 8 }}px;
    --border-radius-lg:      {{ settings.border_radius | default: 8 | times: 2 }}px;
    --spacing-scale-factor:  {{ settings.spacing_scale | default: 100 | divided_by: 100.0 }};

    /* ── Glow shadows ── */
    --glow-accent:           0 0 20px rgba(0, 212, 170, 0.25);
    --glow-accent-strong:    0 0 40px rgba(0, 212, 170, 0.4);
    --glow-coral:            0 0 20px rgba(255, 107, 107, 0.3);
    --shadow-card:           0 2px 12px rgba(0, 0, 0, 0.4);
    --shadow-card-hover:     0 8px 32px rgba(0, 0, 0, 0.6), var(--glow-accent);
    --shadow-modal:          0 24px 80px rgba(0, 0, 0, 0.8);

    /* ── Transitions ── */
    --transition-fast:       150ms ease;
    --transition-base:       250ms ease;
    --transition-slow:       400ms ease;

    /* ── Gradient ── */
    --gradient-accent:       linear-gradient(135deg, #00D4AA 0%, #00A8D4 100%);
    --gradient-coral:        linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
    --gradient-dark:         linear-gradient(180deg, #0A0A0A 0%, #141414 100%);
  }

  /* Light mode variable overrides — toggled by data-theme="light" on <html> */
  [data-theme="light"] {
    --color-base:           #F8F8F8;
    --color-surface:        #FFFFFF;
    --color-surface-raised: #F0F0F0;
    --color-text:           #1A1A1A;
    --color-text-muted:     #6A6A6A;
    --color-text-inverse:   #F0F0F0;
    --color-border:         #E0E0E0;
    --shadow-card:          0 2px 12px rgba(0, 0, 0, 0.08);
    --shadow-card-hover:    0 8px 32px rgba(0, 0, 0, 0.12), var(--glow-accent);
  }
</style>

{%- if settings.font_display -%}
  <style>{{ settings.font_display | font_face: font_display: 'swap' }}</style>
{%- endif -%}

{%- if settings.font_body -%}
  <style>{{ settings.font_body | font_face: font_display: 'swap' }}</style>
{%- endif -%}

{%- if settings.font_serif -%}
  <style>{{ settings.font_serif | font_face: font_display: 'swap' }}</style>
{%- endif -%}
