{% doc %}
  Renders a floating compare bar fixed at the bottom of the screen (above the
  bottom tab bar on mobile). Shows up to 3 selected product thumbnails, a
  "Compare now" teal button, and a "Clear" link. Hides when no products are
  selected. Listens for 'compare:toggle' CustomEvent dispatched by product-card.

  Parameters: none.

  Usage:
    {% render 'compare-bar' %}
{% enddoc %}

<style>
  .compare-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 900;
    background-color: var(--color-surface, #141414);
    border-top: 1px solid var(--color-border, #2A2A2A);
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.5);
    transform: translateY(100%);
    transition: transform var(--transition-base, 250ms ease);
    padding: 0.875rem 1rem;
  }

  /* On mobile, sit above the bottom tab bar (height ~56px) */
  @media (max-width: 767px) {
    .compare-bar {
      bottom: 56px;
    }
  }

  .compare-bar--visible {
    transform: translateY(0);
  }

  .compare-bar__inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    max-width: var(--page-width, 1280px);
    margin: 0 auto;
    flex-wrap: wrap;
  }

  .compare-bar__label {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted, #9A9A9A);
    flex-shrink: 0;
  }

  .compare-bar__items {
    display: flex;
    gap: 0.5rem;
    flex: 1;
    align-items: center;
  }

  .compare-bar__item {
    position: relative;
    width: 48px;
    height: 48px;
    border-radius: 4px;
    overflow: hidden;
    border: 1.5px solid var(--color-accent, #00D4AA);
    flex-shrink: 0;
  }

  .compare-bar__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .compare-bar__item-remove {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 16px;
    height: 16px;
    background-color: var(--color-secondary, #FF6B6B);
    border: none;
    border-radius: 50%;
    color: #fff;
    font-size: 10px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .compare-bar__item-slot {
    width: 48px;
    height: 48px;
    border-radius: 4px;
    border: 1.5px dashed var(--color-border, #2A2A2A);
    flex-shrink: 0;
  }

  .compare-bar__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
    margin-left: auto;
  }

  .compare-bar__compare-btn {
    padding: 0.625rem 1.25rem;
    background-color: var(--color-accent, #00D4AA);
    color: var(--color-text-inverse, #0A0A0A);
    font-family: var(--font-body, 'Inter', sans-serif);
    font-weight: 700;
    font-size: 0.875rem;
    border: none;
    border-radius: var(--border-radius, 8px);
    cursor: pointer;
    transition: background-color var(--transition-fast, 150ms ease),
                box-shadow var(--transition-fast, 150ms ease);
    white-space: nowrap;
  }

  .compare-bar__compare-btn:hover {
    background-color: var(--color-accent-dark, #00A888);
    box-shadow: var(--glow-accent, 0 0 20px rgba(0,212,170,0.25));
  }

  .compare-bar__compare-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .compare-bar__clear {
    font-size: 0.8125rem;
    color: var(--color-text-muted, #9A9A9A);
    text-decoration: underline;
    background: none;
    border: none;
    cursor: pointer;
    transition: color var(--transition-fast, 150ms ease);
    white-space: nowrap;
  }

  .compare-bar__clear:hover {
    color: var(--color-secondary, #FF6B6B);
  }

  /* Compare modal */
  .compare-modal {
    border: none;
    padding: 0;
    background: transparent;
    max-width: 100%;
    max-height: 100%;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .compare-modal::backdrop {
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(6px);
  }

  .compare-modal__inner {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .compare-modal__card {
    background-color: var(--color-surface, #141414);
    border: 1px solid var(--color-border, #2A2A2A);
    border-radius: var(--border-radius-lg, 16px);
    width: 100%;
    max-width: 960px;
    max-height: 90vh;
    overflow-y: auto;
    padding: 2rem;
    position: relative;
  }

  .compare-modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: var(--color-surface-raised, #1E1E1E);
    border: 1px solid var(--color-border, #2A2A2A);
    border-radius: 50%;
    color: var(--color-text, #F0F0F0);
    cursor: pointer;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .compare-modal__close:hover {
    border-color: var(--color-accent, #00D4AA);
    color: var(--color-accent, #00D4AA);
  }

  .compare-modal__title {
    font-family: var(--font-display, 'Syne', sans-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text, #F0F0F0);
    margin: 0 0 1.5rem;
  }

  .compare-modal__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .compare-modal__product {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .compare-modal__product-image {
    aspect-ratio: 1 / 1;
    border-radius: var(--border-radius, 8px);
    overflow: hidden;
    background-color: var(--color-surface-raised, #1E1E1E);
  }

  .compare-modal__product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .compare-modal__product-title {
    font-weight: 600;
    color: var(--color-text, #F0F0F0);
    font-size: 0.9375rem;
    text-decoration: none;
  }

  .compare-modal__product-title:hover {
    color: var(--color-accent, #00D4AA);
  }
</style>

<div class="compare-bar" id="zenith-compare-bar" aria-live="polite" aria-label="{{ 'products.compare_bar_label' | t }}">
  <div class="compare-bar__inner">
    <span class="compare-bar__label">{{ 'products.compare' | t }}</span>

    <div class="compare-bar__items" id="compare-bar-items">
      <div class="compare-bar__item-slot" id="compare-slot-0"></div>
      <div class="compare-bar__item-slot" id="compare-slot-1"></div>
      <div class="compare-bar__item-slot" id="compare-slot-2"></div>
    </div>

    <div class="compare-bar__actions">
      <button
        type="button"
        class="compare-bar__compare-btn"
        id="compare-now-btn"
        disabled
      >
        {{ 'products.compare_now' | t }}
      </button>
      <button type="button" class="compare-bar__clear" id="compare-clear-btn">
        {{ 'products.compare_clear' | t }}
      </button>
    </div>
  </div>
</div>

<dialog class="compare-modal" id="zenith-compare-modal" aria-label="{{ 'products.compare_modal_title' | t }}">
  <div class="compare-modal__inner">
    <div class="compare-modal__card">
      <button type="button" class="compare-modal__close" id="compare-modal-close" aria-label="{{ 'accessibility.close' | t }}">
        {% render 'icon', name: 'close', size: 16 %}
      </button>
      <h2 class="compare-modal__title">{{ 'products.compare_modal_title' | t }}</h2>
      <div class="compare-modal__grid" id="compare-modal-grid"></div>
    </div>
  </div>
</dialog>

<script>
(function () {
  'use strict';

  var MAX        = 3;
  var bar        = document.getElementById('zenith-compare-bar');
  var compareBtn = document.getElementById('compare-now-btn');
  var clearBtn   = document.getElementById('compare-clear-btn');
  var modal      = document.getElementById('zenith-compare-modal');
  var modalGrid  = document.getElementById('compare-modal-grid');
  var modalClose = document.getElementById('compare-modal-close');
  var selected   = {}; /* productId => { title, image, id } */

  function renderSlots() {
    var ids   = Object.keys(selected);
    var count = ids.length;

    for (var i = 0; i < MAX; i++) {
      var slot = document.getElementById('compare-slot-' + i);
      if (!slot) continue;
      slot.innerHTML = '';
      slot.className = '';

      if (ids[i]) {
        var item = selected[ids[i]];
        slot.classList.add('compare-bar__item');

        var img = document.createElement('img');
        img.src = item.image || '';
        img.alt = item.title || '';
        slot.appendChild(img);

        var rmBtn = document.createElement('button');
        rmBtn.type = 'button';
        rmBtn.className = 'compare-bar__item-remove';
        rmBtn.setAttribute('aria-label', '{{ 'accessibility.close' | t | escape }} ' + (item.title || ''));
        rmBtn.textContent = '\u00d7';
        rmBtn.dataset.removeId = ids[i];
        slot.appendChild(rmBtn);
      } else {
        slot.classList.add('compare-bar__item-slot');
      }
    }

    /* Show/hide bar */
    bar.classList.toggle('compare-bar--visible', count > 0);

    /* Enable compare button only when 2+ items */
    compareBtn.disabled = count < 2;

    /* Sync checkboxes */
    document.querySelectorAll('[data-compare-id]').forEach(function (cb) {
      cb.checked = !!selected[cb.dataset.compareId];
    });
  }

  /* Listen for compare:toggle from product cards */
  document.addEventListener('compare:toggle', function (e) {
    var d = e.detail;
    if (d.checked) {
      if (Object.keys(selected).length >= MAX) {
        /* Silently uncheck the checkbox that triggered this */
        var cb = document.querySelector('[data-compare-id="' + d.productId + '"]');
        if (cb) cb.checked = false;
        return;
      }
      selected[d.productId] = {
        id:    d.productId,
        title: d.productTitle,
        image: d.productImage
      };
    } else {
      delete selected[d.productId];
    }
    renderSlots();
  });

  /* Remove via slot button (delegated) */
  document.getElementById('compare-bar-items').addEventListener('click', function (e) {
    var rmBtn = e.target.closest('[data-remove-id]');
    if (!rmBtn) return;
    delete selected[rmBtn.dataset.removeId];
    renderSlots();
  });

  /* Clear all */
  clearBtn.addEventListener('click', function () {
    selected = {};
    renderSlots();
  });

  /* Open compare modal */
  compareBtn.addEventListener('click', function () {
    var ids = Object.keys(selected);
    if (ids.length < 2) return;

    modalGrid.innerHTML = ids.map(function (id) {
      var item = selected[id];
      return '<div class="compare-modal__product">'
        + '<div class="compare-modal__product-image">'
        + (item.image ? '<img src="' + item.image + '" alt="' + (item.title || '') + '" loading="lazy">' : '')
        + '</div>'
        + '<span class="compare-modal__product-title">' + (item.title || '') + '</span>'
        + '</div>';
    }).join('');

    modal.showModal();
    document.body.style.overflow = 'hidden';
  });

  /* Close compare modal */
  function closeCompareModal() {
    modal.close();
    document.body.style.overflow = '';
  }

  if (modalClose) modalClose.addEventListener('click', closeCompareModal);
  modal.addEventListener('click', function (e) { if (e.target === modal) closeCompareModal(); });
  modal.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeCompareModal(); });
}());
</script>
