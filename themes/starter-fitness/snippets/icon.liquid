{% doc %}
  Renders an inline SVG icon from the Zenith fitness/wellness icon set.

  @param {string} name - Icon identifier. One of: search, cart, menu, close,
      chevron-left, chevron-right, chevron-down, arrow-right, heart,
      heart-filled, star, star-half, star-empty, check, minus, plus, mail,
      instagram, facebook, twitter, youtube, compare, zoom, play, pause,
      moon, sun, home, user, clock, fire, trophy, dumbbell. Required.
  @param {number} [size] - Width and height in pixels. Default: 24.
  @param {string} [class] - Additional CSS class(es) to apply to the <svg>.

  Usage:
    {% render 'icon', name: 'dumbbell', size: 20 %}
    {% render 'icon', name: 'cart', size: 24, class: 'header__cart-icon' %}
{% enddoc %}

{%- liquid
  assign icon_size = size | default: 24
  assign icon_class = 'icon icon--' | append: name
  if class != blank
    assign icon_class = icon_class | append: ' ' | append: class
  endif
-%}

{%- case name -%}

  {%- when 'search' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="{{ icon_class }}" aria-hidden="true" focusable="false"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>

  {%- when 'cart' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="{{ icon_class }}" aria-hidden="true" focusable="false"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>

  {%- when 'menu' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="{{ icon_class }}" aria-hidden="true" focusable="false"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>

  {%- when 'close' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="{{ icon_class }}" aria-hidden="true" focusable="false"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>

  {%- when 'chevron-left' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="{{ icon_class }}" aria-hidden="true" focusable="false"><polyline points="15 18 9 12 15 6"/></svg>

  {%- when 'chevron-right' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="{{ icon_class }}" aria-hidden="true" focusable="false"><polyline points="9 18 15 12 9 6"/></svg>

  {%- when 'chevron-down' -%}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="{{ icon_class }}" aria-hidden="true" focusable="false"><polyline points="6 9 12 15 18 9"/></svg>

