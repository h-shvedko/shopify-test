{% doc %}
  Renders a compact upsell product card for the cart drawer. Shows image,
  title, price, and an "Add" button that adds the first available variant
  to the cart via AJAX.

  @param {product} product - Shopify product object. Required.

  Usage:
    {% render 'cart-drawer-upsell', product: product %}
{% enddoc %}

{%- liquid
  assign first_variant = product.selected_or_first_available_variant
  assign add_label     = 'cart_drawer.add' | t
  assign adding_label  = 'cart_drawer.adding' | t
-%}

<style>
  .cdu {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
    border-bottom: 1px solid var(--color-border, #2A2A2A);
  }

  .cdu:last-child {
    border-bottom: none;
  }

  .cdu__image {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    border-radius: var(--border-radius, 8px);
    overflow: hidden;
    background-color: var(--color-surface-elevated, #1E1E1E);
    border: 1px solid var(--color-border, #2A2A2A);
    text-decoration: none;
    display: block;
  }

  .cdu__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.25s ease;
  }

  .cdu__image:hover img {
    transform: scale(1.05);
  }

  .cdu__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary, #8A8A8A);
  }

  .cdu__info {
    flex: 1;
    min-width: 0;
  }

  .cdu__title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text, #F0F0F0);
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
    line-height: 1.3;
    margin-bottom: 4px;
    transition: color 0.15s ease;
  }

  .cdu__title:hover {
    color: var(--color-accent, #00D4AA);
  }

  .cdu__price {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-accent, #00D4AA);
  }

  .cdu__price--sale {
    color: var(--color-accent-secondary, #FF6B6B);
  }

  .cdu__price-compare {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-text-secondary, #8A8A8A);
    text-decoration: line-through;
    margin-right: 4px;
  }

  .cdu__add {
    flex-shrink: 0;
    background: none;
    border: 1px solid var(--color-accent, #00D4AA);
    border-radius: 6px;
    color: var(--color-accent, #00D4AA);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 6px 12px;
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease;
    white-space: nowrap;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cdu__add:hover {
    background-color: var(--color-accent, #00D4AA);
    color: var(--color-text-inverse, #0A0A0A);
  }

  .cdu__add:focus-visible {
    outline: 2px solid var(--color-accent, #00D4AA);
    outline-offset: 2px;
  }

  .cdu__add:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .cdu__add--adding {
    opacity: 0.7;
  }
</style>

<div class="cdu" data-upsell-product="{{ product.id }}">
  <a href="{{ product.url }}" class="cdu__image" tabindex="-1" aria-hidden="true">
    {%- if product.featured_image -%}
      {{
        product.featured_image
        | image_url: width: 112
        | image_tag:
          alt: product.featured_image.alt | escape | default: product.title | escape,
          width: 56,
          height: 56,
          loading: 'lazy'
      }}
    {%- else -%}
      <div class="cdu__image-placeholder" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="8.5" cy="8.5" r="1.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="m21 15-5-5L5 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    {%- endif -%}
  </a>

  <div class="cdu__info">
    <a href="{{ product.url }}" class="cdu__title">{{ product.title }}</a>
    <div>
      {%- if first_variant.compare_at_price > first_variant.price -%}
        <span class="cdu__price-compare">{{ first_variant.compare_at_price | money }}</span>
        <span class="cdu__price cdu__price--sale">{{ first_variant.price | money }}</span>
      {%- else -%}
        <span class="cdu__price">{{ first_variant.price | money }}</span>
      {%- endif -%}
    </div>
  </div>

  {%- if first_variant.available -%}
    <button
      class="cdu__add"
      type="button"
      aria-label="{{ add_label }} {{ product.title | escape }}"
      data-upsell-add
      data-variant-id="{{ first_variant.id }}"
      data-adding-label="{{ adding_label | escape }}"
      data-add-label="{{ add_label | escape }}"
    >{{ add_label }}</button>
  {%- endif -%}
</div>
