{% doc %}
  Renders accepted payment method icons using Shopify's shop.enabled_payment_types
  for the current store, with a muted teal/dark colour treatment matching
  the Zenith cinematic dark theme.

  Parameters: none — reads from global shop object.

  Usage:
    {% render 'payment-icons' %}
{% enddoc %}

{%- if shop.enabled_payment_types != empty -%}
  <style>
    .payment-icons {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem;
    }

    .payment-icons__label {
      font-family: var(--font-body, 'Inter', sans-serif);
      font-size: 0.75rem;
      color: var(--color-text-muted, #9A9A9A);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      width: 100%;
    }

    .payment-icons__icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 24px;
      border-radius: 4px;
      overflow: hidden;
      opacity: 0.7;
      transition: opacity var(--transition-fast, 150ms ease);
      filter: brightness(0.85) contrast(0.9);
    }

    .payment-icons__icon:hover {
      opacity: 1;
      filter: none;
    }

    .payment-icons__icon svg,
    .payment-icons__icon img {
      height: 24px;
      width: auto;
      display: block;
    }
  </style>

  <div class="payment-icons" aria-label="{{ 'footer.payment_methods' | t }}">
    <span class="payment-icons__label">{{ 'footer.payment_methods' | t }}</span>
    {%- for type in shop.enabled_payment_types -%}
      <span class="payment-icons__icon">
        {{ type | payment_type_svg_tag: class: 'payment-icon' }}
      </span>
    {%- endfor -%}
  </div>
{%- endif -%}
