{% doc %}
  Renders a styled button or anchor element.

  Parameters:
  - label {string} required — Visible button text
  - url {string} optional — If provided, renders an <a> tag; otherwise renders a <button>
  - variant {string} optional — Visual style. One of: primary, secondary, outline.
      Default: "primary"
  - type {string} optional — HTML type attribute for <button> elements. Default: "button"
  - full_width {boolean} optional — When true, the element spans full container width.
      Default: false

  Usage:
    {% render 'button', label: 'Shop now', url: '/collections/all' %}
    {% render 'button', label: 'Add to cart', variant: 'primary', type: 'submit' %}
    {% render 'button', label: 'Learn more', variant: 'outline', url: '/pages/about' %}
    {% render 'button', label: 'Continue', variant: 'secondary', full_width: true %}
{% enddoc %}

{%- liquid
  assign btn_variant = variant | default: 'primary'
  assign btn_type    = type    | default: 'button'

  assign btn_class = 'btn btn--' | append: btn_variant
  if full_width
    assign btn_class = btn_class | append: ' btn--full-width'
  endif
-%}

{%- unless btn_styles_rendered -%}
  {%- capture btn_styles_rendered -%}true{%- endcapture -%}
  <style>
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 24px;
      border-radius: var(--border-radius, 8px);
      font-weight: 600;
      font-size: 1rem;
      line-height: 1.25;
      text-decoration: none;
      cursor: pointer;
      transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease,
        opacity 0.2s ease;
      border: 2px solid transparent;
      white-space: nowrap;
    }

    .btn--full-width {
      width: 100%;
      text-align: center;
    }

    /* Primary — amber accent fill */
    .btn--primary {
      background-color: var(--color-primary, #d97706);
      color: var(--color-primary-contrast, #ffffff);
      border-color: var(--color-primary, #d97706);
    }
    .btn--primary:hover,
    .btn--primary:focus-visible {
      opacity: 0.88;
    }
    .btn--primary:focus-visible {
      outline: 2px solid var(--color-primary, #d97706);
      outline-offset: 2px;
    }

    /* Secondary — dark fill (text color) */
    .btn--secondary {
      background-color: var(--color-text, #111827);
      color: var(--color-background, #ffffff);
      border-color: var(--color-text, #111827);
    }
    .btn--secondary:hover,
    .btn--secondary:focus-visible {
      opacity: 0.85;
    }
    .btn--secondary:focus-visible {
      outline: 2px solid var(--color-text, #111827);
      outline-offset: 2px;
    }

    /* Outline — transparent fill, primary border */
    .btn--outline {
      background-color: transparent;
      color: var(--color-primary, #d97706);
      border-color: var(--color-primary, #d97706);
    }
    .btn--outline:hover,
    .btn--outline:focus-visible {
      background-color: var(--color-primary, #d97706);
      color: var(--color-primary-contrast, #ffffff);
    }
    .btn--outline:focus-visible {
      outline: 2px solid var(--color-primary, #d97706);
      outline-offset: 2px;
    }
  </style>
{%- endunless -%}

{%- if url != blank -%}
  <a href="{{ url }}" class="{{ btn_class }}">{{ label }}</a>
{%- else -%}
  <button type="{{ btn_type }}" class="{{ btn_class }}">{{ label }}</button>
{%- endif -%}
