{% doc %}
  Renders pagination controls for a paginated collection, search result, or blog.

  @param {paginate} paginate - Shopify paginate object from a {% paginate %} block. Required.

  @example
  {% paginate collection.products by 12 %}
    {% render 'pagination', paginate: paginate %}
  {% endpaginate %}
{% enddoc %}

<style>
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4px;
    margin-top: 40px;
  }

  .pagination__item {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--border-radius);
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.875rem;
    border: none;
    background: none;
    cursor: pointer;
    transition: background 0.15s;
    flex-shrink: 0;
  }

  .pagination__item:hover {
    background: var(--color-background-alt);
  }

  .pagination__item--current {
    background: var(--color-primary);
    color: var(--color-primary-contrast);
    font-weight: 600;
    pointer-events: none;
  }

  .pagination__item--current:hover {
    background: var(--color-primary);
  }

  .pagination__item--gap {
    pointer-events: none;
    color: var(--color-text-secondary);
  }

  .pagination__item:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

{% if paginate.pages > 1 %}
  <nav class="pagination" aria-label="{{ 'pagination.label' | t }}">
    {% if paginate.previous %}
      <a
        href="{{ paginate.previous.url }}"
        class="pagination__item"
        aria-label="{{ 'pagination.previous' | t }}"
        rel="prev"
      >
        {% render 'icon', name: 'arrow-left', size: 18 %}
      </a>
    {% else %}
      <span class="pagination__item" aria-hidden="true">
        {% render 'icon', name: 'arrow-left', size: 18 %}
      </span>
    {% endif %}

    {% for part in paginate.parts %}
      {% if part.is_link %}
        <a href="{{ part.url }}" class="pagination__item" aria-label="{{ 'pagination.page' | t: number: part.title }}">
          {{ part.title }}
        </a>
      {% elsif part.title == paginate.current_page %}
        <span
          class="pagination__item pagination__item--current"
          aria-current="page"
          aria-label="{{ 'pagination.current_page' | t: number: part.title }}"
        >
          {{ part.title }}
        </span>
      {% else %}
        <span class="pagination__item pagination__item--gap" aria-hidden="true">
          {{ part.title }}
        </span>
      {% endif %}
    {% endfor %}

    {% if paginate.next %}
      <a
        href="{{ paginate.next.url }}"
        class="pagination__item"
        aria-label="{{ 'pagination.next' | t }}"
        rel="next"
      >
        {% render 'icon', name: 'chevron-right', size: 18 %}
      </a>
    {% else %}
      <span class="pagination__item" aria-hidden="true">
        {% render 'icon', name: 'chevron-right', size: 18 %}
      </span>
    {% endif %}
  </nav>
{% endif %}
