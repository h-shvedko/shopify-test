<header class="header" data-section-id="{{ section.id }}">
  <div class="container header__inner">

    {%- comment -%} Logo {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="header__logo">
      {% if section.settings.logo %}
        {{
          section.settings.logo
          | image_url: width: section.settings.logo_width
          | image_tag:
            alt: shop.name,
            width: section.settings.logo_width,
            loading: 'eager',
            fetchpriority: 'high'
        }}
      {% else %}
        <img src="{{ 'logo-brewmaster.svg' | asset_url }}" alt="{{ shop.name }}" width="160" height="40" loading="eager">
      {% endif %}
    </a>

    {%- comment -%} Desktop navigation {%- endcomment -%}
    <nav class="header__nav" aria-label="{{ 'sections.header.nav_aria_label' | t }}">
      {% for link in section.settings.menu.links %}
        <a
          href="{{ link.url }}"
          class="header__nav-link{% if link.active %} header__nav-link--active{% endif %}"
          {% if link.current %}aria-current="page"{% endif %}
        >
          {{ link.title }}
        </a>
      {% endfor %}
    </nav>

    {%- comment -%} Action icons {%- endcomment -%}
    <div class="header__actions">
      <a
        href="{{ routes.search_url }}"
        class="header__icon"
        aria-label="{{ 'general.search' | t }}"
      >
        {% render 'icon', name: 'search', size: 20 %}
      </a>

      <a
        href="{{ routes.cart_url }}"
        class="header__icon header__cart"
        aria-label="{{ 'general.cart' | t }}"
      >
        {% render 'icon', name: 'cart', size: 20 %}
        <span
          class="header__cart-count{% if cart.item_count == 0 %} header__cart-count--empty{% endif %}"
          data-cart-count
          aria-hidden="{{ cart.item_count | default: 0 | times: 0 | plus: 1 | modulo: 2 | append: '' }}"
        >
          {{ cart.item_count }}
        </span>
      </a>

      <button
        class="header__menu-toggle"
        aria-label="{{ 'accessibility.open_menu' | t }}"
        aria-expanded="false"
        aria-controls="mobile-menu-{{ section.id }}"
        data-menu-toggle
      >
        {% render 'icon', name: 'menu', size: 20 %}
      </button>
    </div>
  </div>

  {%- comment -%} Mobile menu dialog {%- endcomment -%}
  <dialog
    class="header__mobile-menu"
    id="mobile-menu-{{ section.id }}"
    aria-label="{{ 'sections.header.mobile_menu_aria_label' | t }}"
    data-mobile-menu
  >
    <div class="header__mobile-menu-inner">
      <div class="header__mobile-menu-top">
        <span class="header__mobile-menu-title">{{ shop.name }}</span>
        <button
          class="header__mobile-menu-close"
          aria-label="{{ 'accessibility.close_menu' | t }}"
          data-menu-close
        >
          {% render 'icon', name: 'close', size: 24 %}
        </button>
      </div>

      <nav aria-label="{{ 'sections.header.mobile_nav_aria_label' | t }}">
        {% for link in section.settings.menu.links %}
          <a
            href="{{ link.url }}"
            class="header__mobile-link{% if link.active %} header__mobile-link--active{% endif %}"
            {% if link.current %}aria-current="page"{% endif %}
          >
            {{ link.title }}
            {% render 'icon', name: 'chevron-right', size: 16 %}
          </a>
        {% endfor %}
      </nav>

      <div class="header__mobile-menu-footer">
        <a href="{{ routes.cart_url }}" class="header__mobile-cart-link">
          {% render 'icon', name: 'cart', size: 20 %}
          {{ 'general.cart' | t }}
          {% if cart.item_count > 0 %}
            <span class="header__mobile-cart-count">({{ cart.item_count }})</span>
          {% endif %}
        </a>
      </div>
    </div>
  </dialog>
</header>

{% stylesheet %}
  /* ---- Header ---- */

  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-background);
    border-bottom: 1px solid var(--color-border);
    padding: 16px 0;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  /* Logo */

  .header__logo {
    text-decoration: none;
    color: var(--color-text);
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: 1.25rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .header__logo img {
    height: auto;
    display: block;
    max-width: 100%;
  }

  .header__logo:hover,
  .header__logo:focus-visible {
    text-decoration: none;
    opacity: 0.85;
  }

  /* Desktop nav — hidden on mobile */

  .header__nav {
    display: none;
    align-items: center;
    gap: 24px;
    flex: 1;
  }

  .header__nav-link {
    text-decoration: none;
    color: var(--color-text);
    font-weight: 500;
    font-size: 0.875rem;
    transition: color 0.15s ease;
    white-space: nowrap;
  }

  .header__nav-link:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .header__nav-link--active,
  .header__nav-link[aria-current="page"] {
    color: var(--color-primary);
  }

  /* Actions */

  .header__actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  .header__icon {
    color: var(--color-text);
    text-decoration: none;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s ease;
  }

  .header__icon:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .header__icon:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Cart badge */

  .header__cart-count {
    position: absolute;
    top: -8px;
    right: -8px;
    background-color: var(--color-primary);
    color: var(--color-primary-contrast);
    font-size: 0.625rem;
    font-weight: 700;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    pointer-events: none;
    transition: transform 0.15s ease;
  }

  .header__cart-count--empty {
    display: none;
  }

  /* Mobile menu toggle — visible on mobile only */

  .header__menu-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: 4px;
    transition: color 0.15s ease;
  }

  .header__menu-toggle:hover {
    color: var(--color-primary);
  }

  /* ---- Mobile menu dialog ---- */

  .header__mobile-menu {
    /* Reset dialog defaults */
    border: none;
    padding: 0;
    margin: 0;
    width: 100%;
    max-width: 100%;
    max-height: 100%;
    height: 100%;
    /* Slide in from right */
    position: fixed;
    inset: 0;
    background-color: var(--color-background);
    overflow-y: auto;
    overscroll-behavior: contain;
    opacity: 0;
    transform: translateX(100%);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .header__mobile-menu[open] {
    opacity: 1;
    transform: translateX(0);
  }

  .header__mobile-menu::backdrop {
    background-color: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(2px);
  }

  .header__mobile-menu-inner {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 0;
  }

  .header__mobile-menu-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px;
    border-bottom: 1px solid var(--color-border);
  }

  .header__mobile-menu-title {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: 1.125rem;
    color: var(--color-text);
  }

  .header__mobile-menu-close {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    transition: color 0.15s ease;
  }

  .header__mobile-menu-close:hover {
    color: var(--color-primary);
  }

  .header__mobile-menu nav {
    flex: 1;
    padding: 8px 0;
  }

  .header__mobile-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    border-bottom: 1px solid var(--color-border);
    transition: background-color 0.1s ease, color 0.1s ease;
  }

  .header__mobile-link:hover {
    background-color: var(--color-background-alt);
    color: var(--color-primary);
    text-decoration: none;
  }

  .header__mobile-link--active,
  .header__mobile-link[aria-current="page"] {
    color: var(--color-primary);
  }

  .header__mobile-menu-footer {
    padding: 16px;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .header__mobile-cart-link {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
  }

  .header__mobile-cart-link:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .header__mobile-cart-count {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }

  /* ---- Desktop breakpoint ---- */

  @media (min-width: 1024px) {
    .header__nav {
      display: flex;
    }

    .header__menu-toggle {
      display: none;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    'use strict';

    var section = document.querySelector('.header[data-section-id="{{ section.id }}"]');
    if (!section) return;

    var toggle = section.querySelector('[data-menu-toggle]');
    var dialog = section.querySelector('[data-mobile-menu]');
    var closeBtn = section.querySelector('[data-menu-close]');

    if (!toggle || !dialog) return;

    function openMenu() {
      dialog.showModal();
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      dialog.close();
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', openMenu);

    if (closeBtn) {
      closeBtn.addEventListener('click', closeMenu);
    }

    // Close on backdrop click (click outside dialog content)
    dialog.addEventListener('click', function (e) {
      if (e.target === dialog) {
        closeMenu();
      }
    });

    // Close on Escape (dialog handles this natively, but sync aria-expanded)
    dialog.addEventListener('close', function () {
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });

    // Update cart badge count when cart is updated via AJAX
    document.addEventListener('cart:updated', function(e) {
      var badge = document.querySelector('[data-cart-count]');
      if (badge) {
        badge.textContent = e.detail.item_count;
        // Show/hide badge based on count
        if (e.detail.item_count > 0) {
          badge.classList.remove('header__cart-count--empty');
        } else {
          badge.classList.add('header__cart-count--empty');
        }
      }
    });
  })();
</script>

{% schema %}
{
  "name": "t:sections.header.name",
  "tag": "div",
  "class": "header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:sections.header.settings.logo.label"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "t:sections.header.settings.logo_width.label",
      "default": 120,
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:sections.header.settings.menu.label",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "t:sections.header.name"
    }
  ]
}
{% endschema %}
