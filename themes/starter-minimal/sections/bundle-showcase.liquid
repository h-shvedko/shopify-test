<section class="bundle-showcase section-padding">
  <div class="container">
    {% if section.settings.heading != blank %}
      <h2 class="bundle-showcase__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="bundle-showcase__grid">
        {% for block in section.blocks %}
          {%- assign block_products = block.settings.products -%}
          {%- liquid
            assign bundle_retail_total = 0
            for bp in block_products
              assign bundle_retail_total = bundle_retail_total | plus: bp.price
            endfor
            assign bundle_discount = block.settings.discount_percent | default: 0
            assign bundle_savings = bundle_retail_total | times: bundle_discount | divided_by: 100
            assign bundle_discounted = bundle_retail_total | minus: bundle_savings
          -%}

          <article
            class="bundle-showcase__card"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.image %}
              <div class="bundle-showcase__card-image">
                {{ block.settings.image | image_url: width: 600 | image_tag:
                  loading: 'lazy',
                  alt: block.settings.title,
                  width: 600,
                  height: 400
                }}
              </div>
            {% elsif block_products.first %}
              <div class="bundle-showcase__card-image">
                {{ block_products.first.featured_image | image_url: width: 600 | image_tag:
                  loading: 'lazy',
                  alt: block.settings.title,
                  width: 600,
                  height: 400
                }}
              </div>
            {% else %}
              <div class="bundle-showcase__card-image bundle-showcase__card-image--placeholder">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}

            <div class="bundle-showcase__card-body">
              {% if bundle_discount > 0 %}
                {%- assign discount_label = 'bundles.bundle_discount' | t: percent: bundle_discount -%}
                {% render 'badge', type: 'bundle', label: discount_label %}
              {% endif %}

              {% if block.settings.title != blank %}
                <h3 class="bundle-showcase__card-title">{{ block.settings.title }}</h3>
              {% endif %}

              {% if block.settings.description != blank %}
                <p class="bundle-showcase__card-description">{{ block.settings.description }}</p>
              {% endif %}

              {% if block_products.size > 0 %}
                <ul class="bundle-showcase__card-products" role="list">
                  {% for bp in block_products %}
                    <li class="bundle-showcase__card-product">
                      {% if bp.featured_image %}
                        <div class="bundle-showcase__card-product-image">
                          {{ bp.featured_image | image_url: width: 48 | image_tag:
                            loading: 'lazy',
                            alt: bp.featured_image.alt,
                            width: 48,
                            height: 48
                          }}
                        </div>
                      {% endif %}
                      <span class="bundle-showcase__card-product-name">{{ bp.title }}</span>
                      <span class="bundle-showcase__card-product-price">{{ bp.price | money }}</span>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}

              <div class="bundle-showcase__card-pricing">
                {% if bundle_savings > 0 %}
                  <div class="bundle-showcase__card-original">
                    <span class="bundle-showcase__card-original-price">{{ bundle_retail_total | money }}</span>
                    <span class="bundle-showcase__card-savings">
                      {% render 'icon', name: 'tag', size: 14 %}
                      {%- assign bundle_savings_formatted = bundle_savings | money -%}
                      {{ 'bundles.bundle_savings' | t: amount: bundle_savings_formatted }}
                    </span>
                  </div>
                {% endif %}
                <div class="bundle-showcase__card-total">
                  {{ bundle_discounted | money }}
                </div>
              </div>

              {% if block.settings.url != blank %}
                <a
                  href="{{ block.settings.url }}"
                  class="btn btn--primary btn--full-width bundle-showcase__card-cta"
                >
                  {{ 'bundles.shop_this_bundle' | t }}
                </a>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <p class="bundle-showcase__empty">{{ 'bundles.curated_bundles_subtitle' | t }}</p>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .bundle-showcase__heading {
    margin-bottom: 40px;
    text-align: center;
  }

  .bundle-showcase__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  .bundle-showcase__card {
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .bundle-showcase__card-image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--color-background-alt);
  }

  .bundle-showcase__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .bundle-showcase__card:hover .bundle-showcase__card-image img {
    transform: scale(1.03);
  }

  .bundle-showcase__card-image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bundle-showcase__card-image--placeholder svg {
    width: 60%;
    height: auto;
  }

  .bundle-showcase__card-body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex: 1;
  }

  .bundle-showcase__card-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
  }

  .bundle-showcase__card-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .bundle-showcase__card-products {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .bundle-showcase__card-product {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.875rem;
  }

  .bundle-showcase__card-product:last-child {
    border-bottom: none;
  }

  .bundle-showcase__card-product-image {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--color-background-alt);
  }

  .bundle-showcase__card-product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bundle-showcase__card-product-name {
    flex: 1;
    color: var(--color-text);
  }

  .bundle-showcase__card-product-price {
    font-weight: 600;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .bundle-showcase__card-pricing {
    padding-top: 12px;
    border-top: 1px solid var(--color-border);
  }

  .bundle-showcase__card-original {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }

  .bundle-showcase__card-original-price {
    font-size: 0.9375rem;
    text-decoration: line-through;
    color: var(--color-text-secondary);
  }

  .bundle-showcase__card-savings {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.875rem;
    color: var(--color-success);
    font-weight: 600;
  }

  .bundle-showcase__card-total {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .bundle-showcase__card-cta {
    margin-top: auto;
  }

  .bundle-showcase__empty {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 1rem;
    padding: 40px 0;
  }

  @media (min-width: 768px) {
    .bundle-showcase__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .bundle-showcase__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.bundle_showcase.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.bundle_showcase.settings.heading.label",
      "default": "Shop our bundles"
    }
  ],
  "blocks": [
    {
      "type": "bundle_card",
      "name": "t:blocks.bundle_card.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:blocks.bundle_card.settings.title.label",
          "default": "Starter kit"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:blocks.bundle_card.settings.description.label"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:blocks.bundle_card.settings.image.label"
        },
        {
          "type": "product_list",
          "id": "products",
          "label": "t:blocks.bundle_card.settings.products.label",
          "limit": 4
        },
        {
          "type": "range",
          "id": "discount_percent",
          "label": "t:blocks.bundle_card.settings.discount_percent.label",
          "min": 0,
          "max": 30,
          "step": 5,
          "unit": "%",
          "default": 10
        },
        {
          "type": "url",
          "id": "url",
          "label": "t:blocks.bundle_card.settings.url.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bundle showcase"
    }
  ]
}
{% endschema %}
