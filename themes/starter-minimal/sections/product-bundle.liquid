{%- liquid
  assign bundle_products = product.metafields.custom.bundle_products.value
  assign has_bundle = false
  if bundle_products != blank
    if bundle_products.size > 0
      assign has_bundle = true
    endif
  endif
-%}

{% if has_bundle %}
  {%- assign max = section.settings.max_products | minus: 1 -%}

  <section class="product-bundle section-padding" data-product-bundle>
    <div class="container">
      {% if section.settings.heading != blank %}
        <h2 class="product-bundle__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      <div class="product-bundle__layout">
        <div class="product-bundle__products" data-bundle-products>

          {% comment %}Current product card — always checked, disabled{% endcomment %}
          <div class="product-bundle__card product-bundle__card--current">
            <label class="product-bundle__card-inner">
              <input
                type="checkbox"
                class="product-bundle__checkbox"
                checked
                disabled
                data-bundle-item
                data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                data-price="{{ product.selected_or_first_available_variant.price }}"
                aria-label="{{ product.title }}"
              >
              <div class="product-bundle__card-image">
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 200 | image_tag:
                    loading: 'lazy',
                    alt: product.featured_image.alt,
                    width: 200,
                    height: 200
                  }}
                {% else %}
                  <div class="product-bundle__card-placeholder">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              <p class="product-bundle__card-title">{{ product.title }}</p>
              <p class="product-bundle__card-price">{{ product.selected_or_first_available_variant.price | money }}</p>
              <span class="product-bundle__this-item">{{ 'bundles.this_item' | t }}</span>
            </label>
          </div>

          {% comment %}Bundle products from metafield{% endcomment %}
          {% for bundle_product in bundle_products limit: max %}
            {% if bundle_product.available %}
              {%- assign bundle_variant = bundle_product.selected_or_first_available_variant -%}
              <div class="product-bundle__separator" aria-hidden="true">
                {% render 'icon', name: 'plus', size: 20 %}
              </div>
              <div class="product-bundle__card">
                <label class="product-bundle__card-inner" for="bundle-item-{{ bundle_product.id }}">
                  <input
                    type="checkbox"
                    id="bundle-item-{{ bundle_product.id }}"
                    class="product-bundle__checkbox"
                    checked
                    data-bundle-item
                    data-variant-id="{{ bundle_variant.id }}"
                    data-price="{{ bundle_variant.price }}"
                    aria-label="{{ bundle_product.title }}"
                  >
                  <div class="product-bundle__card-image">
                    {% if bundle_product.featured_image %}
                      {{ bundle_product.featured_image | image_url: width: 200 | image_tag:
                        loading: 'lazy',
                        alt: bundle_product.featured_image.alt,
                        width: 200,
                        height: 200
                      }}
                    {% else %}
                      <div class="product-bundle__card-placeholder">
                        {{ 'product-1' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </div>
                  <p class="product-bundle__card-title">{{ bundle_product.title }}</p>
                  <p class="product-bundle__card-price">{{ bundle_variant.price | money }}</p>
                </label>
              </div>
            {% endif %}
          {% endfor %}
        </div>

        <div class="product-bundle__summary" aria-live="polite" aria-atomic="true" data-bundle-summary>
          {%- assign discount = section.settings.discount_percent -%}
          <div class="product-bundle__summary-inner">
            <div class="product-bundle__summary-row">
              <span>{{ 'bundles.bundle_total' | t }}</span>
              <span data-bundle-original-total></span>
            </div>
            <div class="product-bundle__summary-row product-bundle__summary-row--savings">
              {% render 'icon', name: 'tag', size: 16 %}
              <span data-bundle-savings-label>
                {{ 'bundles.bundle_discount' | t: percent: discount }}
              </span>
              <span data-bundle-savings-amount class="product-bundle__savings-amount"></span>
            </div>
            <div class="product-bundle__summary-row product-bundle__summary-row--total">
              <span>{{ 'bundles.bundle_total' | t }}</span>
              <span data-bundle-discounted-total class="product-bundle__discounted-total"></span>
            </div>
          </div>

          <button
            type="button"
            class="btn btn--primary btn--full-width product-bundle__add-btn"
            data-bundle-add-btn
            data-discount="{{ discount }}"
            data-adding-label="{{ 'bundles.adding_bundle' | t }}"
            data-add-label="{{ 'bundles.add_bundle_to_cart' | t }}"
          >
            {{ 'bundles.add_bundle_to_cart' | t }}
          </button>

          <p class="product-bundle__disclaimer">
            {% render 'icon', name: 'tag', size: 14 %}
            {{ 'bundles.bundle_discount' | t: percent: discount }}
          </p>
        </div>
      </div>
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .product-bundle__heading {
    margin-bottom: 32px;
  }

  .product-bundle__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  .product-bundle__products {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
  }

  .product-bundle__separator {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px 0;
    color: var(--color-text-secondary);
  }

  .product-bundle__card {
    border: 2px solid var(--color-border);
    border-radius: var(--border-radius);
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .product-bundle__card--current {
    border-color: var(--color-primary);
  }

  .product-bundle__card-inner {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    cursor: pointer;
  }

  .product-bundle__card--current .product-bundle__card-inner {
    cursor: default;
  }

  .product-bundle__checkbox {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    accent-color: var(--color-primary);
    cursor: pointer;
  }

  .product-bundle__checkbox:disabled {
    cursor: default;
    opacity: 0.7;
  }

  .product-bundle__card-image {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--color-background-alt);
  }

  .product-bundle__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-bundle__card-placeholder {
    width: 100%;
    height: 100%;
  }

  .product-bundle__card-placeholder svg {
    width: 100%;
    height: 100%;
  }

  .product-bundle__card-title {
    flex: 1;
    font-size: 0.9rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }

  .product-bundle__card-price {
    font-weight: 700;
    font-size: 0.9375rem;
    margin: 0;
    white-space: nowrap;
    color: var(--color-text);
  }

  .product-bundle__this-item {
    font-size: 0.75rem;
    color: var(--color-primary);
    font-weight: 600;
    white-space: nowrap;
  }

  .product-bundle__card--unchecked {
    border-color: var(--color-border);
    opacity: 0.6;
  }

  .product-bundle__summary {
    background: var(--color-background-alt);
    border-radius: var(--border-radius);
    padding: 24px;
  }

  .product-bundle__summary-inner {
    margin-bottom: 20px;
  }

  .product-bundle__summary-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 6px 0;
    font-size: 0.9375rem;
  }

  .product-bundle__summary-row--savings {
    color: var(--color-success);
    font-weight: 600;
    font-size: 0.875rem;
  }

  .product-bundle__summary-row--total {
    border-top: 2px solid var(--color-text);
    margin-top: 8px;
    padding-top: 12px;
    font-weight: 700;
    font-size: 1.125rem;
  }

  .product-bundle__savings-amount {
    font-weight: 700;
    color: var(--color-success);
  }

  .product-bundle__discounted-total {
    font-weight: 700;
    color: var(--color-primary);
  }

  .product-bundle__add-btn {
    width: 100%;
  }

  .product-bundle__disclaimer {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 12px;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  @media (min-width: 768px) {
    .product-bundle__products {
      flex-direction: row;
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .product-bundle__card {
      flex: 1;
      min-width: 160px;
    }

    .product-bundle__card-inner {
      flex-direction: column;
      text-align: center;
    }

    .product-bundle__card-image {
      width: 100%;
      height: 120px;
    }

    .product-bundle__separator {
      padding: 0 4px;
      align-self: center;
      flex-shrink: 0;
    }
  }

  @media (min-width: 1024px) {
    .product-bundle__layout {
      grid-template-columns: 2fr 1fr;
      align-items: start;
    }

    .product-bundle__card-image {
      height: 140px;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var bundleEl = document.querySelector('[data-product-bundle]');
    if (!bundleEl) return;

    var checkboxes = bundleEl.querySelectorAll('[data-bundle-item]');
    var addBtn = bundleEl.querySelector('[data-bundle-add-btn]');
    var originalTotalEl = bundleEl.querySelector('[data-bundle-original-total]');
    var savingsAmountEl = bundleEl.querySelector('[data-bundle-savings-amount]');
    var discountedTotalEl = bundleEl.querySelector('[data-bundle-discounted-total]');
    var discountPercent = addBtn ? parseInt(addBtn.dataset.discount || '0', 10) : 0;

    function formatMoney(cents) {
      var amount = (cents / 100).toFixed(2);
      return '$' + amount.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }

    function recalcTotals() {
      var total = 0;
      checkboxes.forEach(function (cb) {
        if (cb.checked) {
          total += parseInt(cb.dataset.price || '0', 10);
        }
      });
      var savings = Math.round(total * discountPercent / 100);
      var discounted = total - savings;

      if (originalTotalEl) originalTotalEl.textContent = formatMoney(total);
      if (savingsAmountEl) savingsAmountEl.textContent = '- ' + formatMoney(savings);
      if (discountedTotalEl) discountedTotalEl.textContent = formatMoney(discounted);
    }

    function updateCardState(checkbox) {
      var card = checkbox.closest('.product-bundle__card');
      if (!card) return;
      if (checkbox.checked) {
        card.classList.remove('product-bundle__card--unchecked');
      } else {
        card.classList.add('product-bundle__card--unchecked');
      }
    }

    function updateCartBadge(count) {
      var badges = document.querySelectorAll('[data-cart-count]');
      badges.forEach(function (badge) {
        badge.textContent = count;
        badge.hidden = count === 0;
      });
    }

    checkboxes.forEach(function (cb) {
      cb.addEventListener('change', function () {
        updateCardState(cb);
        recalcTotals();
      });
    });

    if (addBtn) {
      addBtn.addEventListener('click', function () {
        var items = [];
        var bundleId = 'bundle_' + Date.now();

        checkboxes.forEach(function (cb) {
          if (cb.checked) {
            items.push({
              id: parseInt(cb.dataset.variantId, 10),
              quantity: 1,
              properties: { '_bundle_id': bundleId }
            });
          }
        });

        if (items.length === 0) return;

        var addingLabel = addBtn.dataset.addingLabel || 'Adding...';
        var addLabel = addBtn.dataset.addLabel || 'Add bundle to cart';

        addBtn.disabled = true;
        addBtn.setAttribute('aria-busy', 'true');
        addBtn.textContent = addingLabel;

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ items: items })
        })
          .then(function (response) {
            if (!response.ok) {
              return response.json().then(function (data) {
                throw new Error(data.description || 'Could not add bundle to cart');
              });
            }
            return response.json();
          })
          .then(function () {
            return fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
          })
          .then(function (response) { return response.json(); })
          .then(function (cart) {
            updateCartBadge(cart.item_count);
            document.dispatchEvent(new CustomEvent('cart:updated', { detail: { item_count: cart.item_count } }));

            var toast = document.querySelector('[data-cart-toast]');
            if (toast) {
              var bundleAddedMsg = addBtn.closest('[data-product-bundle]').dataset.bundleAddedMsg;
              toast.textContent = bundleAddedMsg || 'Bundle added to cart';
              toast.classList.add('product-detail__toast--visible');
              setTimeout(function () {
                toast.classList.remove('product-detail__toast--visible');
              }, 3000);
            }
          })
          .catch(function (err) {
            var toast = document.querySelector('[data-cart-toast]');
            if (toast) {
              toast.textContent = err.message;
              toast.classList.add('product-detail__toast--visible');
              setTimeout(function () {
                toast.classList.remove('product-detail__toast--visible');
              }, 3000);
            }
          })
          .finally(function () {
            addBtn.disabled = false;
            addBtn.setAttribute('aria-busy', 'false');
            addBtn.textContent = addLabel;
          });
      });
    }

    // Initial calculation
    recalcTotals();
  })();
</script>

{% schema %}
{
  "name": "t:sections.product_bundle.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.product_bundle.settings.heading.label",
      "default": "Frequently bought together"
    },
    {
      "type": "range",
      "id": "discount_percent",
      "label": "t:sections.product_bundle.settings.discount_percent.label",
      "min": 0,
      "max": 30,
      "step": 5,
      "unit": "%",
      "default": 10
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "t:sections.product_bundle.settings.max_products.label",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Product bundle"
    }
  ]
}
{% endschema %}
