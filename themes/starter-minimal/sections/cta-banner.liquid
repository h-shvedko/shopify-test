<section
  class="cta-banner section-padding"
  style="background: var(--color-primary); color: var(--color-primary-contrast);"
>
  <div class="container cta-banner__content">
    {% if section.settings.heading != blank %}
      <h2 class="cta-banner__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    {% if section.settings.subtitle != blank %}
      <p class="cta-banner__subtitle">{{ section.settings.subtitle | escape }}</p>
    {% endif %}

    {% if section.settings.button_label != blank %}
      {% render 'button',
        label: section.settings.button_label,
        url: section.settings.button_url,
        variant: 'secondary'
      %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .cta-banner__content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-banner__heading {
    font-size: 2rem;
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .cta-banner__subtitle {
    font-size: 1.125rem;
    opacity: 0.9;
    margin: 0 0 32px;
  }

  @media (min-width: 1024px) {
    .cta-banner__heading {
      font-size: 2.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.cta_banner.name",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.cta_banner.settings.heading.label",
      "default": "Ready to start brewing?"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "t:sections.cta_banner.settings.subtitle.label",
      "default": ""
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.cta_banner.settings.button_label.label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.cta_banner.settings.button_url.label",
      "default": "/collections/all"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "CTA banner"
    }
  ]
}
{% endschema %}
