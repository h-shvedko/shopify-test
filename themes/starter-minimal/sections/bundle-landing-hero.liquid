<section
  class="bundle-landing-hero"
  style="{% if section.settings.image %}--hero-bg: url('{{ section.settings.image | image_url: width: 1920 }}');{% endif %}"
>
  <div class="bundle-landing-hero__overlay"></div>
  <div class="container bundle-landing-hero__content">
    {% if section.settings.heading != blank %}
      <h1 class="bundle-landing-hero__heading">{{ section.settings.heading }}</h1>
    {% endif %}
    {% if section.settings.subtitle != blank %}
      <p class="bundle-landing-hero__subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .bundle-landing-hero {
    position: relative;
    min-height: 320px;
    display: flex;
    align-items: center;
    background-color: var(--color-text);
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center;
  }

  .bundle-landing-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
  }

  .bundle-landing-hero__content {
    position: relative;
    z-index: 1;
    padding-block: 60px;
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
  }

  .bundle-landing-hero__heading {
    color: #ffffff;
    font-size: 2rem;
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .bundle-landing-hero__subtitle {
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.125rem;
    line-height: 1.6;
    margin: 0;
  }

  @media (min-width: 768px) {
    .bundle-landing-hero {
      min-height: 420px;
    }

    .bundle-landing-hero__heading {
      font-size: 2.75rem;
    }
  }

  @media (min-width: 1024px) {
    .bundle-landing-hero {
      min-height: 520px;
    }

    .bundle-landing-hero__heading {
      font-size: 3.25rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.bundle_landing_hero.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.bundle_landing_hero.settings.image.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.bundle_landing_hero.settings.heading.label",
      "default": "Curated brewing bundles"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "t:sections.bundle_landing_hero.settings.subtitle.label",
      "default": "Everything you need to start brewing, bundled together at a discount."
    }
  ],
  "presets": [
    {
      "name": "Bundle landing hero"
    }
  ]
}
{% endschema %}
