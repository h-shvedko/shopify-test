<section class="not-found section-padding">
  <div class="container not-found__content">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.message }}</p>
    {% render 'button',
      label: section.settings.button_label,
      url: section.settings.button_url,
      variant: 'primary'
    %}
  </div>
</section>

{% stylesheet %}
  .not-found__content {
    text-align: center;
    padding-top: 40px;
    padding-bottom: 40px;
  }

  .not-found__content h1 {
    margin-bottom: 16px;
    font-size: calc(3rem * var(--font-scale-factor));
    color: var(--color-text);
  }

  .not-found__content p {
    color: var(--color-text-secondary);
    font-size: 1.125rem;
    margin-bottom: 32px;
    max-width: 480px;
    margin-inline: auto;
    margin-bottom: 32px;
  }

  @media (min-width: 768px) {
    .not-found__content {
      padding-top: 80px;
      padding-bottom: 80px;
    }

    .not-found__content h1 {
      font-size: calc(4rem * var(--font-scale-factor));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.not_found.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.not_found.settings.heading.label",
      "default": "404"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "t:sections.not_found.settings.message.label",
      "default": "The page you're looking for doesn't exist."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.not_found.settings.button_label.label",
      "default": "Back to home"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.not_found.settings.button_url.label",
      "default": "/"
    }
  ],
  "presets": [
    {
      "name": "404 page"
    }
  ]
}
{% endschema %}
