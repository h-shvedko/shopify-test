{% doc %}
  Renders a quantity input with rounded decrement and increment buttons,
  styled to match PawHaven's friendly aesthetic.

  @param {number} [value] - Current quantity value. Default: 1.
  @param {string} [name] - The name attribute for the number input. Default: "quantity".
  @param {number} [min] - Minimum allowed value. Default: 1.
  @param {number} [max] - Maximum allowed value. Default: 99.
  @param {string} [line_item_key] - Cart line item key for AJAX quantity updates.
      When provided, a 'quantity:change' CustomEvent is dispatched on change
      with detail { key, quantity }.

  Usage:
    {% render 'quantity-selector', name: 'quantity', value: 1 %}
    {% render 'quantity-selector', name: 'quantity', value: item.quantity, line_item_key: item.key %}
{% enddoc %}

{%- liquid
  assign qty_value = value | default: 1
  assign qty_name  = name  | default: 'quantity'
  assign qty_min   = min   | default: 1
  assign qty_max   = max   | default: 99
-%}

<style>
  .quantity-selector {
    display: inline-flex;
    align-items: center;
    border: 1.5px solid var(--color-border, #E7E0D6);
    border-radius: 100px;
    background-color: var(--color-surface, #ffffff);
    overflow: hidden;
  }

  .quantity-selector__btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text, #1C1917);
    padding: 0;
    flex-shrink: 0;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .quantity-selector__btn:hover {
    color: var(--color-primary, #059669);
    background-color: var(--color-background, #F5F0E8);
  }

  .quantity-selector__btn:focus-visible {
    outline: 2px solid var(--color-primary, #059669);
    outline-offset: -2px;
  }

  .quantity-selector__input {
    width: 46px;
    height: 40px;
    text-align: center;
    border: none;
    border-left: 1.5px solid var(--color-border, #E7E0D6);
    border-right: 1.5px solid var(--color-border, #E7E0D6);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text, #1C1917);
    background: transparent;
    -moz-appearance: textfield;
    padding: 0;
  }

  .quantity-selector__input::-webkit-outer-spin-button,
  .quantity-selector__input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .quantity-selector__input:focus {
    outline: none;
  }
</style>

<div
  class="quantity-selector"
  {%- if line_item_key != blank %} data-line-item-key="{{ line_item_key }}"{% endif %}
>
  <button
    type="button"
    class="quantity-selector__btn quantity-selector__btn--minus"
    aria-label="{{ 'accessibility.decrease_quantity' | t }}"
  >
    {% render 'icon', name: 'minus', size: 16 %}
  </button>

  <input
    type="number"
    class="quantity-selector__input"
    name="{{ qty_name }}"
    value="{{ qty_value }}"
    min="{{ qty_min }}"
    max="{{ qty_max }}"
    step="1"
    aria-label="{{ 'products.quantity' | t }}"
  >

  <button
    type="button"
    class="quantity-selector__btn quantity-selector__btn--plus"
    aria-label="{{ 'accessibility.increase_quantity' | t }}"
  >
    {% render 'icon', name: 'plus', size: 16 %}
  </button>
</div>

<script>
  (function () {
    document.querySelectorAll('.quantity-selector').forEach(function (selector) {
      if (selector.dataset.qsInit) return;
      selector.dataset.qsInit = '1';

      var input    = selector.querySelector('.quantity-selector__input');
      var minusBtn = selector.querySelector('.quantity-selector__btn--minus');
      var plusBtn  = selector.querySelector('.quantity-selector__btn--plus');
      var lineItemKey = selector.dataset.lineItemKey || null;

      function clamp(val) {
        var min = parseInt(input.min, 10) || 1;
        var max = parseInt(input.max, 10) || 99;
        return Math.min(max, Math.max(min, val));
      }

      function dispatchChange(qty) {
        if (!lineItemKey) return;
        selector.dispatchEvent(
          new CustomEvent('quantity:change', {
            bubbles: true,
            detail: { key: lineItemKey, quantity: qty }
          })
        );
      }

      minusBtn.addEventListener('click', function () {
        var next = clamp(parseInt(input.value, 10) - 1);
        input.value = next;
        dispatchChange(next);
      });

      plusBtn.addEventListener('click', function () {
        var next = clamp(parseInt(input.value, 10) + 1);
        input.value = next;
        dispatchChange(next);
      });

      input.addEventListener('change', function () {
        var next = clamp(parseInt(input.value, 10) || 1);
        input.value = next;
        dispatchChange(next);
      });
    });
  })();
</script>
