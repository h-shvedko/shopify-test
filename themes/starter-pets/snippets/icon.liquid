{% doc %}
  Renders an inline SVG icon from the PawHaven icon set (Lucide-style + paw).

  @param {string} name - Icon identifier. One of: search, cart, menu, close,
      chevron-left, chevron-right, chevron-down, arrow-right, heart, star,
      star-half, star-empty, check, minus, plus, mail, instagram, facebook,
      pinterest, twitter, paw, truck, shield, user, map-pin, phone, arrow-left.
      Required.
  @param {number} [size] - Width and height in pixels. Default: 24.
  @param {string} [class] - Additional CSS class(es) to apply to the <svg>.

  Usage:
    {% render 'icon', name: 'paw', size: 20, class: 'header__paw' %}
    {% render 'icon', name: 'cart', size: 24 %}
{% enddoc %}

{%- liquid
  assign icon_size = size | default: 24
  assign icon_class = 'icon icon--' | append: name
  if class != blank
    assign icon_class = icon_class | append: ' ' | append: class
  endif
-%}

{%- case name -%}

  {%- when 'paw' -%}
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="{{ icon_size }}"
      height="{{ icon_size }}"
      viewBox="0 0 24 24"
      fill="currentColor"
      class="{{ icon_class }}"
      aria-hidden="true"
      focusable="false"
    ><path d="M12 2C9.5 2 7.5 4 7.5 6.5c0 1.5.7 2.8 1.8 3.7C7.5 11 6 12.8 6 15c0 3.3 2.7 6 6 6s6-2.7 6-6c0-2.2-1.5-4-3.3-4.8 1.1-.9 1.8-2.2 1.8-3.7C16.5 4 14.5 2 12 2zm-3.5 2.5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3zm7 0a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3zM5 7a1.5 1.5 0 1 1 0 3A1.5 1.5 0 0 1 5 7zm14 0a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3z"/></svg>

