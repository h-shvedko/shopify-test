{% layout none %}
<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ 'gift_card.title' | t }} — {{ shop.name }}</title>
  {{ content_for_header }}
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Quicksand', 'Trebuchet MS', Arial, sans-serif;
      background: #F5F0E8;
      color: #1C1917;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 32px 16px;
    }

    h1, h2, h3 {
      font-family: 'Nunito', 'Arial Rounded MT Bold', Arial, sans-serif;
      font-weight: 800;
    }

    .gift-card {
      background: #fff;
      border: 1px solid #E7E0D6;
      border-radius: 12px;
      max-width: 480px;
      width: 100%;
      overflow: hidden;
      box-shadow: 0 4px 32px rgba(5, 150, 105, 0.10);
    }

    .gift-card__visual {
      background: linear-gradient(135deg, #059669 0%, #047857 50%, #065f46 100%);
      padding: 40px 32px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .gift-card__visual::before {
      content: '🐾';
      position: absolute;
      top: -16px;
      right: -12px;
      font-size: 6rem;
      opacity: 0.12;
      transform: rotate(20deg);
    }

    .gift-card__visual::after {
      content: '🐾';
      position: absolute;
      bottom: -12px;
      left: -10px;
      font-size: 4.5rem;
      opacity: 0.10;
      transform: rotate(-15deg);
    }

    .gift-card__shop-name {
      font-family: 'Nunito', 'Arial Rounded MT Bold', Arial, sans-serif;
      font-weight: 800;
      font-size: 1.5rem;
      color: #fff;
      margin-bottom: 24px;
      position: relative;
      z-index: 1;
    }

    .gift-card__image {
      border-radius: 10px;
      max-width: 280px;
      width: 100%;
      height: auto;
      margin-bottom: 20px;
      position: relative;
      z-index: 1;
    }

    .gift-card__balance-label {
      font-family: 'Nunito', 'Arial Rounded MT Bold', Arial, sans-serif;
      font-size: 0.875rem;
      font-weight: 700;
      color: rgba(255,255,255,0.8);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 6px;
      position: relative;
      z-index: 1;
    }

    .gift-card__balance {
      font-family: 'Nunito', 'Arial Rounded MT Bold', Arial, sans-serif;
      font-weight: 800;
      font-size: 3rem;
      color: #fff;
      line-height: 1;
      position: relative;
      z-index: 1;
    }

    .gift-card__body {
      padding: 32px;
      text-align: center;
    }

    .gift-card__code-label {
      font-family: 'Nunito', 'Arial Rounded MT Bold', Arial, sans-serif;
      font-size: 0.875rem;
      font-weight: 700;
      color: #78716C;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 10px;
    }

    .gift-card__code-box {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      background: #F5F0E8;
      border: 1.5px dashed #E7E0D6;
      border-radius: 12px;
      padding: 14px 18px;
      margin-bottom: 20px;
    }

    .gift-card__code {
      font-family: 'Courier New', Courier, monospace;
      font-size: 1.25rem;
      font-weight: 700;
      color: #1C1917;
      letter-spacing: 0.12em;
      flex: 1;
      word-break: break-all;
    }

    .gift-card__copy-btn {
      background: var(--gc-primary, #059669);
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 8px 16px;
      font-family: 'Nunito', 'Arial Rounded MT Bold', Arial, sans-serif;
      font-size: 0.8125rem;
      font-weight: 700;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.2s ease;
      flex-shrink: 0;
    }

    .gift-card__copy-btn:hover {
      background: #047857;
    }

    .gift-card__copy-btn--copied {
      background: #065f46;
    }

    .gift-card__expired-notice {
      background: #fef2f2;
      border: 1px solid #fca5a5;
      border-radius: 12px;
      padding: 12px 16px;
      color: #dc2626;
      font-size: 0.9375rem;
      font-family: 'Quicksand', 'Trebuchet MS', Arial, sans-serif;
      font-weight: 600;
      margin-bottom: 20px;
    }

    .gift-card__qr {
      background: #f9f7f3;
      border: 1px solid #E7E0D6;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }

    .gift-card__qr-placeholder {
      width: 120px;
      height: 120px;
      background: #E7E0D6;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.5rem;
    }

    .gift-card__qr-label {
      font-size: 0.8125rem;
      color: #78716C;
      font-family: 'Quicksand', 'Trebuchet MS', Arial, sans-serif;
    }

    .gift-card__actions {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-top: 8px;
    }

    .gift-card__wallet-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: #000;
      color: #fff;
      border-radius: 12px;
      padding: 12px 20px;
      text-decoration: none;
      font-family: 'Nunito', 'Arial Rounded MT Bold', Arial, sans-serif;
      font-weight: 700;
      font-size: 0.9375rem;
      transition: opacity 0.2s ease;
    }

    .gift-card__wallet-link:hover {
      opacity: 0.85;
    }

    .gift-card__wallet-link img {
      display: inline-block;
      vertical-align: middle;
    }

    .gift-card__print-btn {
      background: none;
      border: 1.5px solid #E7E0D6;
      border-radius: 12px;
      padding: 12px 20px;
      font-family: 'Nunito', 'Arial Rounded MT Bold', Arial, sans-serif;
      font-size: 0.9375rem;
      font-weight: 700;
      color: #78716C;
      cursor: pointer;
      transition: border-color 0.2s ease, color 0.2s ease;
      width: 100%;
    }

    .gift-card__print-btn:hover {
      border-color: #059669;
      color: #059669;
    }

    @media print {
      body {
        background: #fff;
        padding: 0;
      }
      .gift-card__actions {
        display: none;
      }
    }
  </style>
</head>
<body>
  <main class="gift-card" role="main">
    <div class="gift-card__visual">
      <p class="gift-card__shop-name">{{ shop.name }}</p>

      {% if gift_card.image %}
        {%- assign gift_card_alt = 'gift_card.title' | t -%}
        {{ gift_card.image | image_url: width: 560 | image_tag: class: 'gift-card__image', alt: gift_card_alt, width: 560, height: 280, loading: 'eager' }}
      {% endif %}

      <p class="gift-card__balance-label">{{ 'gift_card.balance_label' | t }}</p>
      <p class="gift-card__balance">{{ gift_card.balance | money }}</p>
    </div>

    <div class="gift-card__body">
      {% if gift_card.expired %}
        <div class="gift-card__expired-notice" role="alert">
          {{ 'general.gift_card_expired' | t }}
        </div>
      {% endif %}

      <p class="gift-card__code-label">{{ 'gift_card.code_label' | t }}</p>
      <div class="gift-card__code-box">
        <span class="gift-card__code" id="gift-card-code" aria-label="{{ 'gift_card.code_label' | t }}">
          {{ gift_card.code | format_code }}
        </span>
        <button
          class="gift-card__copy-btn"
          id="copy-code-btn"
          type="button"
          data-code="{{ gift_card.code }}"
          aria-label="{{ 'gift_card.copy_code' | t }}"
        >
          {{ 'gift_card.copy' | t }}
        </button>
      </div>

      <div class="gift-card__qr" aria-label="{{ 'gift_card.qr_label' | t }}">
        <div class="gift-card__qr-placeholder" data-gift-card-code="{{ gift_card.code }}" aria-hidden="true">🐾</div>
        <p class="gift-card__qr-label">{{ 'gift_card.qr_label' | t }}</p>
      </div>

      <div class="gift-card__actions">
        {% if gift_card.pass_url %}
          <a href="{{ gift_card.pass_url }}" class="gift-card__wallet-link">
            {{ 'general.add_to_apple_wallet' | t }}
          </a>
        {% endif %}

        <button type="button" class="gift-card__print-btn" onclick="window.print()">
          {{ 'gift_card.print' | t }}
        </button>
      </div>
    </div>
  </main>

  <script>
    (function () {
      var copyBtn = document.getElementById('copy-code-btn');
      if (!copyBtn) return;

      copyBtn.addEventListener('click', function () {
        var code = copyBtn.dataset.code;
        if (!code) return;

        if (navigator.clipboard) {
          navigator.clipboard.writeText(code).then(function () {
            showCopied();
          }).catch(function () {
            fallbackCopy(code);
          });
        } else {
          fallbackCopy(code);
        }
      });

      function showCopied() {
        copyBtn.textContent = '{{ 'gift_card.copied' | t }}';
        copyBtn.classList.add('gift-card__copy-btn--copied');
        setTimeout(function () {
          copyBtn.textContent = '{{ 'gift_card.copy' | t }}';
          copyBtn.classList.remove('gift-card__copy-btn--copied');
        }, 2000);
      }

      function fallbackCopy(text) {
        var textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.left = '-9999px';
        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();
        try {
          document.execCommand('copy');
          showCopied();
        } catch (e) {
          // copy not supported
        }
        document.body.removeChild(textarea);
      }
    })();
  </script>
</body>
</html>
