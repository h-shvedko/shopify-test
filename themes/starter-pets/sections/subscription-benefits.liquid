{%- liquid
  assign bg_color = section.settings.background_color | default: '#F5F0E8'
  assign heading = section.settings.heading | default: 'subscription_benefits.heading' | t
  assign subheading = section.settings.subheading | default: 'subscription_benefits.subheading' | t
-%}

<section
  class="sub-benefits section-padding"
  style="--sub-benefits-bg: {{ bg_color }};"
>
  <div class="container">
    <div class="sub-benefits__header">
      {% if heading != blank %}
        <h2 class="sub-benefits__heading">{{ heading }}</h2>
      {% endif %}
      {% if subheading != blank %}
        <p class="sub-benefits__subheading">{{ subheading }}</p>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="sub-benefits__grid">
        {% for block in section.blocks %}
          {%- assign block_icon = block.settings.icon | default: 'truck' -%}
          {%- assign block_heading = block.settings.heading -%}
          {%- assign block_desc = block.settings.description -%}

          <div class="sub-benefits__card" {{ block.shopify_attributes }}>
            <div class="sub-benefits__icon" aria-hidden="true">
              {% render 'icon', name: block_icon, size: 24 %}
            </div>
            {% if block_heading != blank %}
              <h3 class="sub-benefits__card-heading">{{ block_heading }}</h3>
            {% endif %}
            {% if block_desc != blank %}
              <p class="sub-benefits__card-desc">{{ block_desc }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .sub-benefits {
    background-color: var(--sub-benefits-bg, #F5F0E8);
    padding-top: 56px;
    padding-bottom: 56px;
  }

  .sub-benefits__header {
    text-align: center;
    margin-bottom: 40px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .sub-benefits__heading {
    font-family: var(--font-heading, 'Nunito', sans-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--color-text, #1C1917);
    margin: 0 0 12px;
  }

  .sub-benefits__subheading {
    font-size: 1rem;
    color: var(--color-text-secondary, #78716C);
    font-family: var(--font-body, 'Quicksand', sans-serif);
    line-height: 1.6;
    margin: 0;
  }

  .sub-benefits__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .sub-benefits__card {
    background: var(--color-surface, #ffffff);
    border-radius: 12px;
    padding: 28px 24px;
    text-align: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .sub-benefits__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
  }

  .sub-benefits__icon {
    width: 52px;
    height: 52px;
    background: var(--color-primary, #059669);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    color: #ffffff;
    flex-shrink: 0;
  }

  .sub-benefits__card-heading {
    font-family: var(--font-heading, 'Nunito', sans-serif);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text, #1C1917);
    margin: 0 0 8px;
  }

  .sub-benefits__card-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary, #78716C);
    font-family: var(--font-body, 'Quicksand', sans-serif);
    line-height: 1.6;
    margin: 0;
  }

  @media (min-width: 768px) {
    .sub-benefits__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .sub-benefits__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.subscription_benefits.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.subscription_benefits.settings.heading.label",
      "default": "Why subscribe?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.subscription_benefits.settings.subheading.label",
      "default": "Automatic deliveries so your pet never goes without"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.subscription_benefits.settings.background_color.label",
      "default": "#F5F0E8"
    }
  ],
  "blocks": [
    {
      "type": "benefit_item",
      "name": "t:sections.subscription_benefits.blocks.benefit_item.name",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "t:sections.subscription_benefits.blocks.benefit_item.settings.icon.label",
          "options": [
            { "value": "truck", "label": "Truck" },
            { "value": "paw", "label": "Paw" },
            { "value": "tag", "label": "Tag" },
            { "value": "refresh", "label": "Refresh" },
            { "value": "shield", "label": "Shield" },
            { "value": "calendar", "label": "Calendar" },
            { "value": "pause", "label": "Pause" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.subscription_benefits.blocks.benefit_item.settings.heading.label",
          "default": "Benefit heading"
        },
        {
          "type": "text",
          "id": "description",
          "label": "t:sections.subscription_benefits.blocks.benefit_item.settings.description.label",
          "default": "Brief description of this benefit."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Subscription benefits",
      "blocks": [
        {
          "type": "benefit_item",
          "settings": {
            "icon": "truck",
            "heading": "Free shipping",
            "description": "Every subscription delivery ships free"
          }
        },
        {
          "type": "benefit_item",
          "settings": {
            "icon": "tag",
            "heading": "Save on every order",
            "description": "Up to 15% off the regular price"
          }
        },
        {
          "type": "benefit_item",
          "settings": {
            "icon": "pause",
            "heading": "Flexible schedule",
            "description": "Pause, skip, or cancel anytime"
          }
        },
        {
          "type": "benefit_item",
          "settings": {
            "icon": "refresh",
            "heading": "Auto-delivery",
            "description": "Set it and forget it — we will handle the rest"
          }
        }
      ]
    }
  ]
}
{% endschema %}
