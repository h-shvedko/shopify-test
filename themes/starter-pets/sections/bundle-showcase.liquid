<section class="bundle-showcase section-padding">
  <div class="container">
    <div class="bundle-showcase__header">
      {%- assign bs_heading = section.settings.heading | default: '' -%}
      {%- assign bs_subheading = section.settings.subheading | default: '' -%}

      <h1 class="bundle-showcase__heading">
        {%- if bs_heading != blank -%}
          {{ bs_heading }}
        {%- else -%}
          {{ 'bundles.shop_bundles_heading' | t }}
        {%- endif -%}
      </h1>
      <p class="bundle-showcase__subheading">
        {%- if bs_subheading != blank -%}
          {{ bs_subheading }}
        {%- else -%}
          {{ 'bundles.shop_bundles_subheading' | t }}
        {%- endif -%}
      </p>
    </div>

    {% if section.blocks.size > 0 %}
      <div class="bundle-showcase__grid">
        {% for block in section.blocks %}
          {%- assign block_product = block.settings.product -%}

          {% if block_product != blank %}
            {%- assign card_label = block.settings.label | default: '' -%}
            {%- assign card_desc = block.settings.description | default: '' -%}

            {% render 'bundle-showcase-card',
              product: block_product,
              label: card_label,
              description: card_desc
            %}
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <p class="bundle-showcase__empty">{{ 'bundles.no_bundles' | t }}</p>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .bundle-showcase {
    padding-top: 56px;
    padding-bottom: 64px;
  }

  .bundle-showcase__header {
    text-align: center;
    margin-bottom: 48px;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .bundle-showcase__heading {
    font-family: var(--font-heading, 'Nunito', sans-serif);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--color-text, #1C1917);
    margin: 0 0 14px;
    line-height: 1.2;
  }

  .bundle-showcase__subheading {
    font-size: 1.0625rem;
    color: var(--color-text-secondary, #78716C);
    font-family: var(--font-body, 'Quicksand', sans-serif);
    line-height: 1.6;
    margin: 0;
  }

  .bundle-showcase__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
  }

  .bundle-showcase__empty {
    text-align: center;
    color: var(--color-text-secondary, #78716C);
    font-family: var(--font-body, 'Quicksand', sans-serif);
    font-size: 1rem;
    padding: 48px 0;
    background: var(--color-background, #F5F0E8);
    border-radius: 12px;
    border: 1px dashed var(--color-border, #E7E0D6);
  }

  @media (min-width: 768px) {
    .bundle-showcase__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .bundle-showcase__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.bundle_showcase.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.bundle_showcase.settings.heading.label",
      "default": "Shop pet care bundles"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.bundle_showcase.settings.subheading.label",
      "default": "Curated kits for every pet parent"
    }
  ],
  "blocks": [
    {
      "type": "bundle_card",
      "name": "t:sections.bundle_showcase.blocks.bundle_card.name",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "t:sections.bundle_showcase.blocks.bundle_card.settings.product.label"
        },
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.bundle_showcase.blocks.bundle_card.settings.label.label"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.bundle_showcase.blocks.bundle_card.settings.description.label"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Bundle showcase"
    }
  ]
}
{% endschema %}
