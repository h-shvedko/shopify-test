<footer class="footer" data-section-id="{{ section.id }}">
  <div class="footer__main">
    <div class="container footer__grid">

      {%- comment -%} Column 1: About {%- endcomment -%}
      <div class="footer__col footer__col--about">
        <a href="{{ routes.root_url }}" class="footer__brand">{{ shop.name }}</a>
        {% if section.settings.about_text != blank %}
          <p class="footer__about-text">{{ section.settings.about_text | escape }}</p>
        {% endif %}
        {%- comment -%} Social icons {%- endcomment -%}
        <div class="footer__socials" aria-label="{{ 'footer.social_label' | t }}">
          {% if section.settings.social_instagram != blank %}
            <a href="{{ section.settings.social_instagram }}" class="footer__social-btn" target="_blank" rel="noopener noreferrer" aria-label="{{ 'footer.instagram' | t }}">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {% endif %}
          {% if section.settings.social_facebook != blank %}
            <a href="{{ section.settings.social_facebook }}" class="footer__social-btn" target="_blank" rel="noopener noreferrer" aria-label="{{ 'footer.facebook' | t }}">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.social_tiktok != blank %}
            <a href="{{ section.settings.social_tiktok }}" class="footer__social-btn" target="_blank" rel="noopener noreferrer" aria-label="{{ 'footer.tiktok' | t }}">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.16 8.16 0 0 0 4.77 1.52V6.74a4.85 4.85 0 0 1-1-.05z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.social_youtube != blank %}
            <a href="{{ section.settings.social_youtube }}" class="footer__social-btn" target="_blank" rel="noopener noreferrer" aria-label="{{ 'footer.youtube' | t }}">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.96-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      {%- comment -%} Columns 2–3: Link blocks {%- endcomment -%}
      {% for block in section.blocks %}
        {% if block.type == 'link_column' %}
          <div class="footer__col" {{ block.shopify_attributes }}>
            {% if block.settings.heading != blank %}
              <h2 class="footer__col-heading">{{ block.settings.heading | escape }}</h2>
            {% endif %}
            {% if block.settings.menu != blank %}
              <ul class="footer__links" role="list">
                {% for link in block.settings.menu.links %}
                  <li>
                    <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}

      {%- comment -%} Column 4: Newsletter {%- endcomment -%}
      <div class="footer__col footer__col--newsletter">
        <h2 class="footer__col-heading">{{ 'footer.newsletter_heading' | t }}</h2>
        <p class="footer__newsletter-sub">{{ 'footer.newsletter_sub' | t }}</p>
        <form
          class="footer__newsletter-form"
          action="{{ routes.root_url }}contact#contact_form"
          method="post"
          data-newsletter-form
        >
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="&#x2713;">
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label for="footer-email-{{ section.id }}" class="visually-hidden">
            {{ 'footer.newsletter_placeholder' | t }}
          </label>
          <input
            class="footer__newsletter-input"
            type="email"
            id="footer-email-{{ section.id }}"
            name="contact[email]"
            placeholder="{{ 'footer.newsletter_placeholder' | t }}"
            autocomplete="email"
            required
            aria-required="true"
          >
          <button type="submit" class="footer__newsletter-btn">
            {{ 'footer.subscribe' | t }}
          </button>
        </form>
      </div>

    </div>
  </div>

  {%- comment -%} Bottom bar {%- endcomment -%}
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copyright">
        {%- assign current_year = 'now' | date: '%Y' -%}
        {{ 'footer.copyright' | t: shop: shop.name, year: current_year }}
      </p>
      <div class="footer__payment-icons" aria-label="{{ 'footer.payment_methods' | t }}">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
        {%- endfor -%}
      </div>
    </div>
  </div>

</footer>

{% stylesheet %}
  /* ============================================================
     PawHaven Footer
  ============================================================ */

  .footer {
    background-color: #1C1917;
    color: #C9BFB5;
  }

  .footer .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media (min-width: 768px) {
    .footer .container {
      padding: 0 32px;
    }
  }

  /* Main grid area */

  .footer__main {
    padding: 60px 0 40px;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 640px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .footer__grid {
      grid-template-columns: 2fr 1fr 1fr 1.5fr;
    }
  }

  /* About column */

  .footer__brand {
    display: block;
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 1.5rem;
    color: #ffffff;
    text-decoration: none;
    margin-bottom: 14px;
    line-height: 1;
  }

  .footer__brand:hover {
    text-decoration: none;
    color: #059669;
  }

  .footer__about-text {
    font-family: 'Quicksand', sans-serif;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: #C9BFB5;
    margin: 0 0 20px;
  }

  /* Social buttons */

  .footer__socials {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .footer__social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background-color: #059669;
    color: #ffffff;
    border-radius: 12px;
    text-decoration: none;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .footer__social-btn:hover {
    background-color: #047857;
    transform: translateY(-2px);
    text-decoration: none;
  }

  .footer__social-btn:focus-visible {
    outline: 2px solid #059669;
    outline-offset: 3px;
  }

  /* Link columns */

  .footer__col-heading {
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    color: #ffffff;
    margin: 0 0 16px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    font-size: 0.8125rem;
  }

  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__link {
    color: #C9BFB5;
    text-decoration: none;
    font-family: 'Quicksand', sans-serif;
    font-size: 0.9375rem;
    transition: color 0.15s ease;
  }

  .footer__link:hover {
    color: #ffffff;
    text-decoration: none;
  }

  /* Newsletter column */

  .footer__newsletter-sub {
    font-family: 'Quicksand', sans-serif;
    font-size: 0.9375rem;
    color: #C9BFB5;
    line-height: 1.5;
    margin: 0 0 16px;
  }

  .footer__newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__newsletter-input {
    padding: 12px 16px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background-color: rgba(255, 255, 255, 0.07);
    color: #ffffff;
    font-family: 'Quicksand', sans-serif;
    font-size: 0.9375rem;
    outline: none;
    transition: border-color 0.2s ease;
    width: 100%;
  }

  .footer__newsletter-input::placeholder {
    color: #8C8580;
  }

  .footer__newsletter-input:focus {
    border-color: #059669;
  }

  .footer__newsletter-btn {
    padding: 12px 20px;
    background-color: #059669;
    color: #ffffff;
    border: none;
    border-radius: 12px;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 0.9375rem;
    cursor: pointer;
    transition: background-color 0.2s ease;
    align-self: flex-start;
    width: 100%;
  }

  .footer__newsletter-btn:hover {
    background-color: #047857;
  }

  .footer__newsletter-btn:focus-visible {
    outline: 2px solid #059669;
    outline-offset: 2px;
  }

  /* Bottom bar */

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 20px 0;
  }

  .footer__bottom-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .footer__copyright {
    font-family: 'Quicksand', sans-serif;
    font-size: 0.875rem;
    color: #8C8580;
    margin: 0;
  }

  .footer__payment-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }

  .footer__payment-icon {
    height: 24px;
    width: auto;
    border-radius: 4px;
    opacity: 0.6;
  }

  /* Visually hidden (screen reader only) */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
{% endstylesheet %}

<script>
  (function () {
    'use strict';

    var form = document.querySelector(
      '.footer[data-section-id="{{ section.id }}"] [data-newsletter-form]'
    );
    if (!form) return;

    form.addEventListener('submit', function () {
      var btn = form.querySelector('button[type="submit"]');
      if (btn) {
        btn.disabled = true;
        btn.style.opacity = '0.7';
      }
    });
  })();
</script>

{% schema %}
{
  "name": "t:sections.footer.name",
  "tag": "div",
  "class": "footer-section",
  "settings": [
    {
      "type": "textarea",
      "id": "about_text",
      "label": "t:sections.footer.settings.about_text.label",
      "default": "Your one-stop shop for happy, healthy pets. Curated natural products loved by pet parents everywhere."
    },
    {
      "type": "text",
      "id": "social_instagram",
      "label": "t:sections.footer.settings.social_instagram.label"
    },
    {
      "type": "text",
      "id": "social_facebook",
      "label": "t:sections.footer.settings.social_facebook.label"
    },
    {
      "type": "text",
      "id": "social_tiktok",
      "label": "t:sections.footer.settings.social_tiktok.label"
    },
    {
      "type": "text",
      "id": "social_youtube",
      "label": "t:sections.footer.settings.social_youtube.label"
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "t:sections.footer.blocks.link_column.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.link_column.settings.heading.label",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:sections.footer.blocks.link_column.settings.menu.label",
          "default": "footer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.footer.name",
      "blocks": [
        {
          "type": "link_column",
          "settings": {
            "heading": "Quick links"
          }
        },
        {
          "type": "link_column",
          "settings": {
            "heading": "Customer care"
          }
        }
      ]
    }
  ]
}
{% endschema %}
