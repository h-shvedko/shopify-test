<section class="customer-form section-padding">
  <div class="container">
    <div class="customer-form__wrapper">
      <div class="customer-form__icon" aria-hidden="true">🐾</div>
      <h1 class="customer-form__title">{{ 'customer.login_title' | t }}</h1>

      {% form 'customer_login' %}
        {{ form.errors | default_errors }}

        <div class="customer-form__field">
          <label class="customer-form__label" for="customer-email">{{ 'customer.email' | t }}</label>
          <input
            class="customer-form__input"
            type="email"
            id="customer-email"
            name="customer[email]"
            autocomplete="email"
            required
          >
        </div>

        <div class="customer-form__field">
          <label class="customer-form__label" for="customer-password">{{ 'customer.password' | t }}</label>
          <input
            class="customer-form__input"
            type="password"
            id="customer-password"
            name="customer[password]"
            autocomplete="current-password"
            required
          >
        </div>

        <button type="submit" class="btn btn--primary btn--full-width customer-form__submit">
          {{ 'customer.submit_login' | t }}
        </button>
      {% endform %}

      <div class="customer-form__links">
        <a href="{{ routes.account_register_url }}" class="customer-form__link">{{ 'customer.create_account' | t }}</a>
        <a href="{{ routes.account_recover_url }}" class="customer-form__link">{{ 'customer.forgot_password' | t }}</a>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .customer-form {
    padding-top: 60px;
    padding-bottom: 60px;
  }

  .customer-form__wrapper {
    max-width: 480px;
    margin: 0 auto;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 40px 32px;
  }

  .customer-form__icon {
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 16px;
    display: block;
  }

  .customer-form__title {
    font-family: var(--font-heading);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 28px;
    text-align: center;
    font-size: 1.75rem;
  }

  .customer-form__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 20px;
  }

  .customer-form__label {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--color-text);
  }

  .customer-form__input {
    padding: 12px 16px;
    border: 1.5px solid var(--color-border);
    border-radius: 12px;
    font-size: 1rem;
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-background);
    transition: border-color 0.2s ease;
    width: 100%;
  }

  .customer-form__input:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .customer-form__input:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .customer-form__input::placeholder {
    color: var(--color-text-secondary);
  }

  .customer-form__submit {
    background: var(--color-primary);
    color: #fff;
    border-radius: 12px;
    padding: 14px 24px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    border: none;
    cursor: pointer;
    width: 100%;
    transition: background 0.2s ease;
    margin-top: 8px;
  }

  .customer-form__submit:hover {
    background: #047857;
  }

  .customer-form__links {
    display: flex;
    justify-content: space-between;
    margin-top: 20px;
    gap: 12px;
    flex-wrap: wrap;
  }

  .customer-form__link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-primary);
    text-decoration: underline;
  }

  .customer-form__link:hover {
    opacity: 0.8;
  }

  .customer-form .errors {
    background: #fef2f2;
    border: 1px solid #dc2626;
    border-radius: 12px;
    padding: 12px 16px;
    margin-bottom: 20px;
    font-size: 0.9375rem;
    color: #dc2626;
    font-family: var(--font-body);
  }

  .customer-form .errors ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.customer_login.name",
  "settings": [],
  "presets": [
    {
      "name": "Customer login"
    }
  ]
}
{% endschema %}
