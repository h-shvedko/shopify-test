{% if recommendations.performed %}
  {% if recommendations.products_count > 0 %}
    <section
      class="rp section-padding"
      data-product-id="{{ product.id }}"
      data-products-count="{{ section.settings.products_to_show }}"
    >
      <div class="container">
        <h2 class="rp__heading">{{ section.settings.heading | escape }}</h2>
        <div class="rp__track-wrap">
          <div class="rp__track" data-related-products>
            {% for rec in recommendations.products limit: section.settings.products_to_show %}
              {% render 'product-card', product: rec %}
            {% endfor %}
          </div>
        </div>
      </div>
    </section>
  {% endif %}
{% else %}
  <section
    class="rp section-padding"
    data-product-id="{{ product.id }}"
    data-products-count="{{ section.settings.products_to_show }}"
  >
    <div class="container">
      <h2 class="rp__heading">{{ section.settings.heading | escape }}</h2>
      <div class="rp__track-wrap">
        <div class="rp__track" data-related-products></div>
      </div>
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .rp {
    padding-top: 48px;
    padding-bottom: 64px;
  }

  .rp__heading {
    font-family: var(--font-heading, 'Nunito', sans-serif);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    text-align: center;
    margin: 0 0 32px;
    color: var(--color-text, #1C1917);
  }

  .rp__track-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }

  .rp__track-wrap::-webkit-scrollbar {
    display: none;
  }

  .rp__track {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media (min-width: 600px) {
    .rp__track {
      display: flex;
      gap: 20px;
    }

    .rp__track > * {
      flex: 0 0 240px;
      min-width: 0;
    }
  }

  @media (min-width: 1024px) {
    .rp__track-wrap {
      overflow: visible;
    }

    .rp__track {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }

    .rp__track > * {
      flex: unset;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var section = document.querySelector('.rp[data-product-id]');
    if (!section) return;

    var grid = section.querySelector('[data-related-products]');
    if (!grid) return;

    if (grid.children.length > 0) return;

    var productId = section.dataset.productId;
    var limit = section.dataset.productsCount || '4';

    if (!productId) return;

    fetch(
      '/recommendations/products.json?product_id=' +
        encodeURIComponent(productId) +
        '&limit=' +
        encodeURIComponent(limit),
      { headers: { 'X-Requested-With': 'XMLHttpRequest' } }
    )
      .then(function (res) {
        if (!res.ok) throw new Error('Failed to load recommendations');
        return res.json();
      })
      .then(function (data) {
        var products = data.products;
        if (!products || products.length === 0) {
          section.hidden = true;
          return;
        }

        products.forEach(function (product) {
          grid.appendChild(buildCard(product));
        });
      })
      .catch(function () {
        section.hidden = true;
      });

    function buildCard(product) {
      var article = document.createElement('article');
      article.className = 'product-card';

      var imageUrl = product.featured_image
        ? product.featured_image.replace(/(\.\w+)$/, '_600x600$1')
        : null;

      var imageHtml = imageUrl
        ? '<img class="product-card__image" src="' + imageUrl + '" alt="' + escapeHtml(product.title) + '" width="600" height="600" loading="lazy">'
        : '<div class="product-card__image-placeholder" aria-hidden="true"></div>';

      // Use inline money formatting (no Liquid template strings in JS)
      var priceCents = product.price_min;
      var priceHtml = formatMoney(priceCents);

      article.innerHTML =
        '<a href="' + product.url + '" tabindex="-1" aria-hidden="true">' +
          '<div class="product-card__image-wrapper">' + imageHtml + '</div>' +
        '</a>' +
        '<div class="product-card__info">' +
          '<h3 class="product-card__title"><a href="' + product.url + '">' + escapeHtml(product.title) + '</a></h3>' +
          '<div class="product-card__price">' + priceHtml + '</div>' +
        '</div>';

      return article;
    }

    function formatMoney(cents) {
      var amount = (cents / 100).toFixed(2);
      var shopFormat = (window.Shopify && window.Shopify.money_format) || null;
      var formatted;
      if (shopFormat) {
        formatted = shopFormat
          {% raw %}.replace('{{amount}}', amount)
          .replace('{{amount_with_comma_separator}}', amount.replace('.', ','))
          .replace('{{amount_no_decimals}}', Math.round(cents / 100).toString()){% endraw %};
      } else {
        formatted = '$' + amount;
      }
      return '<span class="price">' + formatted + '</span>';
    }

    function escapeHtml(str) {
      var div = document.createElement('div');
      div.appendChild(document.createTextNode(str));
      return div.innerHTML;
    }
  })();
</script>

{% schema %}
{
  "name": "t:sections.related_products.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.related_products.settings.heading.label",
      "default": "You might also love"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:sections.related_products.settings.products_to_show.label",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Related products"
    }
  ]
}
{% endschema %}
