<section class="fc section-padding" data-scroll-reveal>
  <div class="container">
    <div class="fc__header">
      {% if section.settings.heading != blank %}
        <h2 class="fc__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="fc__subheading">{{ section.settings.subheading | escape }}</p>
      {% endif %}
    </div>

    {% if section.settings.collection != blank %}
      <div class="fc__mosaic">
        {% for product in section.settings.collection.products limit: section.settings.products_to_show %}
          <div class="fc__card{% if forloop.index == 1 %} fc__card--featured{% endif %}" data-reveal>
            {% render 'product-card', product: product %}
          </div>
        {% endfor %}
      </div>

      {% if section.settings.show_view_all %}
        <div class="fc__footer">
          <a href="{{ section.settings.collection.url }}" class="btn btn--outline fc__view-all">
            {{ 'products.view_all' | t }}
          </a>
        </div>
      {% endif %}
    {% else %}
      <p class="fc__no-collection">{{ 'collections.select_collection' | t }}</p>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .fc {
    padding-top: 64px;
    padding-bottom: 64px;
  }

  .fc__header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 40px;
  }

  .fc__heading {
    font-family: var(--font-heading, 'Nunito', sans-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 800;
    color: var(--color-text, #1C1917);
    margin: 0 0 12px;
  }

  .fc__subheading {
    font-size: 1.0625rem;
    color: var(--color-text-secondary, #78716C);
    margin: 0;
    line-height: 1.6;
  }

  /* Mosaic grid */
  .fc__mosaic {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .fc__card--featured {
    grid-column: span 2;
  }

  .fc__footer {
    text-align: center;
    margin-top: 40px;
  }

  .fc__view-all {
    display: inline-block;
    padding: 14px 36px;
    border-radius: 24px;
    font-weight: 700;
    font-family: var(--font-heading, 'Nunito', sans-serif);
    border: 2px solid var(--color-primary, #059669);
    color: var(--color-primary, #059669);
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
  }

  .fc__view-all:hover {
    background: var(--color-primary, #059669);
    color: #ffffff;
    transform: translateY(-2px);
  }

  .fc__view-all:focus-visible {
    outline: 2px solid var(--color-primary, #059669);
    outline-offset: 3px;
  }

  .fc__no-collection {
    text-align: center;
    color: var(--color-text-secondary, #78716C);
    padding: 60px 20px;
  }

  /* Scroll reveal */
  [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  @media (min-width: 768px) {
    .fc__mosaic {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .fc__card--featured {
      grid-column: span 1;
      grid-row: span 2;
    }
  }

  @media (min-width: 1024px) {
    .fc__mosaic {
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }

    .fc__card--featured {
      grid-column: span 2;
      grid-row: span 1;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var revealEls = document.querySelectorAll('[data-reveal]');
    if (!revealEls.length) return;

    if (!('IntersectionObserver' in window)) {
      revealEls.forEach(function (el) { el.classList.add('is-visible'); });
      return;
    }

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            var delay = entry.target.closest('.fc__mosaic')
              ? Array.from(entry.target.parentElement.children).indexOf(entry.target) * 80
              : 0;
            setTimeout(function () {
              entry.target.classList.add('is-visible');
            }, delay);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    revealEls.forEach(function (el) { observer.observe(el); });
  })();
</script>

{% schema %}
{
  "name": "t:sections.featured_collection.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured_collection.settings.heading.label",
      "default": "Our favourites"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.featured_collection.settings.subheading.label",
      "default": "Hand-picked products your pets will love"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured_collection.settings.collection.label"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:sections.featured_collection.settings.products_to_show.label",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "t:sections.featured_collection.settings.show_view_all.label",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
