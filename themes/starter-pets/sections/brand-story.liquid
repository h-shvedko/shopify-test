{%- liquid
  assign layout_class = 'brand-story--img-left'
  if section.settings.layout == 'image_right'
    assign layout_class = 'brand-story--img-right'
  endif
-%}

<section
  class="brand-story {{ layout_class }}"
  data-section-id="{{ section.id }}"
>
  <div class="container brand-story__inner">

    {%- comment -%} Image column {%- endcomment -%}
    <div class="brand-story__img-col" data-reveal>
      {% if section.settings.image %}
        {%- assign bs_alt = section.settings.image.alt | escape -%}
        {{
          section.settings.image
          | image_url: width: 900
          | image_tag:
            class: 'brand-story__img',
            loading: 'lazy',
            alt: bs_alt,
            widths: '480, 640, 900'
        }}
      {% else %}
        <div class="brand-story__img-placeholder" aria-hidden="true">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        </div>
      {% endif %}
    </div>

    {%- comment -%} Text column {%- endcomment -%}
    <div class="brand-story__text-col" data-reveal>
      {% if section.settings.heading != blank %}
        <h2 class="brand-story__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.content != blank %}
        <div class="brand-story__content rte">{{ section.settings.content }}</div>
      {% endif %}

      {% if section.settings.button_text != blank %}
        <a
          href="{{ section.settings.button_url | default: routes.root_url }}"
          class="brand-story__btn"
        >
          {{ section.settings.button_text | escape }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      {% endif %}
    </div>

  </div>
</section>

{% stylesheet %}
  /* ============================================================
     PawHaven Brand Story
  ============================================================ */

  .brand-story {
    padding: 72px 0;
    background-color: #F5F0E8;
  }

  .brand-story .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media (min-width: 768px) {
    .brand-story .container {
      padding: 0 32px;
    }
  }

  /* Inner two-column grid */

  .brand-story__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }

  @media (min-width: 768px) {
    .brand-story__inner {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
    }

    /* Image on the right: swap column order */
    .brand-story--img-right .brand-story__img-col {
      order: 2;
    }

    .brand-story--img-right .brand-story__text-col {
      order: 1;
    }
  }

  /* Image column */

  .brand-story__img-col {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(28, 25, 23, 0.1);
  }

  .brand-story__img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 12px;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .brand-story__img-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #E7E0D6;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #8C8580;
  }

  /* Text column */

  .brand-story__text-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  .brand-story__heading {
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 2rem;
    color: #1C1917;
    margin: 0;
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .brand-story__heading {
      font-size: 2.5rem;
    }
  }

  /* Rich text body */

  .brand-story__content {
    font-family: 'Quicksand', sans-serif;
    font-size: 1.0625rem;
    color: #5C5753;
    line-height: 1.7;
  }

  .brand-story__content p {
    margin: 0 0 16px;
  }

  .brand-story__content p:last-child {
    margin-bottom: 0;
  }

  .brand-story__content a {
    color: #059669;
    text-decoration: underline;
  }

  .brand-story__content a:hover {
    color: #047857;
  }

  .brand-story__content ul,
  .brand-story__content ol {
    padding-left: 20px;
    margin: 0 0 16px;
  }

  .brand-story__content li {
    margin-bottom: 6px;
    line-height: 1.65;
  }

  /* CTA button */

  .brand-story__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background-color: #059669;
    color: #ffffff;
    border-radius: 12px;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(5, 150, 105, 0.25);
    margin-top: 4px;
  }

  .brand-story__btn:hover {
    background-color: #047857;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(5, 150, 105, 0.3);
    text-decoration: none;
    color: #ffffff;
  }

  .brand-story__btn:focus-visible {
    outline: 2px solid #059669;
    outline-offset: 3px;
  }

  .brand-story__btn svg {
    transition: transform 0.2s ease;
  }

  .brand-story__btn:hover svg {
    transform: translateX(3px);
  }

  /* Scroll reveal — staggered */

  [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  [data-reveal].is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .brand-story__text-col[data-reveal] {
    transition-delay: 0.15s;
  }
{% endstylesheet %}

<script>
  (function () {
    'use strict';

    var sectionId = '{{ section.id }}';
    var section = document.querySelector('.brand-story[data-section-id="' + sectionId + '"]');
    if (!section) return;

    if ('IntersectionObserver' in window) {
      var revealEls = section.querySelectorAll('[data-reveal]');
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12 });

      revealEls.forEach(function (el) { obs.observe(el); });
    } else {
      section.querySelectorAll('[data-reveal]').forEach(function (el) {
        el.classList.add('is-revealed');
      });
    }
  })();
</script>

{% schema %}
{
  "name": "t:sections.brand_story.name",
  "tag": "div",
  "class": "brand-story-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.brand_story.settings.image.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.brand_story.settings.heading.label",
      "default": "Our story"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "t:sections.brand_story.settings.content.label",
      "default": "<p>We started PawHaven because we believe every pet deserves the very best. From natural treats to cozy beds, every product we carry is chosen with love, safety, and sustainability in mind.</p><p>Our mission is simple: happy pets, happy people.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:sections.brand_story.settings.button_text.label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.brand_story.settings.button_url.label"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.brand_story.settings.layout.label",
      "default": "image_left",
      "options": [
        { "value": "image_left", "label": "t:sections.brand_story.settings.layout.options.image_left" },
        { "value": "image_right", "label": "t:sections.brand_story.settings.layout.options.image_right" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.brand_story.name"
    }
  ]
}
{% endschema %}
