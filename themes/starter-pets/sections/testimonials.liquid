<section class="tst section-padding" data-testimonials>
  <div class="container">
    {% if section.settings.heading != blank %}
      <h2 class="tst__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="tst__subheading">{{ section.settings.subheading | escape }}</p>
    {% endif %}

    <div class="tst__carousel-wrap">
      <div class="tst__carousel" data-tst-carousel>
        {% for block in section.blocks %}
          {% if block.type == 'testimonial' %}
            <div class="tst__card" {{ block.shopify_attributes }}>
              <div class="tst__stars" aria-label="{{ 'testimonials.rating_aria' | t: rating: block.settings.rating }}">
                {% for i in (1..5) %}
                  <svg
                    class="tst__star{% if i <= block.settings.rating %} tst__star--filled{% endif %}"
                    width="16" height="16" viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {% endfor %}
              </div>

              {% if block.settings.quote != blank %}
                <blockquote class="tst__quote">
                  <p>{{ block.settings.quote | escape }}</p>
                </blockquote>
              {% endif %}

              <footer class="tst__footer">
                {% if block.settings.image %}
                  {%- assign avatar_alt = block.settings.author | escape -%}
                  {{ block.settings.image
                    | image_url: width: 120
                    | image_tag:
                      class: 'tst__avatar',
                      loading: 'lazy',
                      alt: avatar_alt,
                      width: 60,
                      height: 60
                  }}
                {% else %}
                  <div class="tst__avatar-placeholder" aria-hidden="true">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  </div>
                {% endif %}

                <div class="tst__author-info">
                  {% if block.settings.author != blank %}
                    <cite class="tst__author">{{ block.settings.author | escape }}</cite>
                  {% endif %}
                  {% if block.settings.pet_name != blank %}
                    <span class="tst__pet">{{ 'testimonials.pet_owner' | t: name: block.settings.pet_name }}</span>
                  {% endif %}
                </div>
              </footer>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if section.blocks.size > 1 %}
        <button
          class="tst__arrow tst__arrow--prev"
          data-tst-prev
          aria-label="{{ 'testimonials.previous' | t }}"
          type="button"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button
          class="tst__arrow tst__arrow--next"
          data-tst-next
          aria-label="{{ 'testimonials.next' | t }}"
          type="button"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .tst {
    padding-top: 64px;
    padding-bottom: 64px;
    background: var(--color-background, #F5F0E8);
  }

  .tst__heading {
    font-family: var(--font-heading, 'Nunito', sans-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    text-align: center;
    color: var(--color-text, #1C1917);
    margin: 0 0 12px;
  }

  .tst__subheading {
    text-align: center;
    color: var(--color-text-secondary, #78716C);
    margin: 0 auto 40px;
    max-width: 500px;
    font-size: 1.0625rem;
    line-height: 1.6;
  }

  /* Carousel */
  .tst__carousel-wrap {
    position: relative;
  }

  .tst__carousel {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }

  .tst__carousel::-webkit-scrollbar {
    display: none;
  }

  /* Cards */
  .tst__card {
    flex: 0 0 min(320px, 85vw);
    scroll-snap-align: start;
    background: var(--color-surface, #ffffff);
    border-radius: 12px;
    padding: 28px 24px 24px;
    border: 1px solid var(--color-border, #E7E0D6);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .tst__card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    transform: translateY(-2px);
  }

  /* Stars */
  .tst__stars {
    display: flex;
    gap: 3px;
  }

  .tst__star {
    fill: var(--color-border, #E7E0D6);
  }

  .tst__star--filled {
    fill: var(--color-secondary, #D97706);
  }

  /* Quote */
  .tst__quote {
    flex: 1;
    margin: 0;
  }

  .tst__quote p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text, #1C1917);
    margin: 0;
    font-style: italic;
  }

  /* Footer */
  .tst__footer {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .tst__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-primary, #059669);
    flex-shrink: 0;
  }

  .tst__avatar-placeholder {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-background, #F5F0E8);
    border: 2px solid var(--color-border, #E7E0D6);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--color-text-secondary, #78716C);
  }

  .tst__author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .tst__author {
    font-style: normal;
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--color-text, #1C1917);
  }

  .tst__pet {
    font-size: 0.8125rem;
    color: var(--color-primary, #059669);
    font-weight: 500;
  }

  /* Arrow buttons */
  .tst__arrow {
    display: none;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-surface, #ffffff);
    border: 1.5px solid var(--color-border, #E7E0D6);
    cursor: pointer;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: background-color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
    z-index: 2;
    color: var(--color-text, #1C1917);
  }

  .tst__arrow:hover {
    background: var(--color-primary, #059669);
    border-color: var(--color-primary, #059669);
    color: #ffffff;
    transform: translateY(-50%) scale(1.05);
  }

  .tst__arrow:focus-visible {
    outline: 2px solid var(--color-primary, #059669);
    outline-offset: 2px;
  }

  .tst__arrow--prev {
    left: -22px;
  }

  .tst__arrow--next {
    right: -22px;
  }

  @media (min-width: 768px) {
    .tst__arrow {
      display: flex;
    }

    .tst__carousel-wrap {
      padding: 0 10px;
    }
  }

  @media (min-width: 1024px) {
    .tst__card {
      flex: 0 0 340px;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var carousel = document.querySelector('[data-tst-carousel]');
    var prevBtn = document.querySelector('[data-tst-prev]');
    var nextBtn = document.querySelector('[data-tst-next]');
    if (!carousel) return;

    var cardWidth = function () {
      var card = carousel.querySelector('.tst__card');
      if (!card) return 340;
      return card.offsetWidth + 20;
    };

    if (prevBtn) {
      prevBtn.addEventListener('click', function () {
        carousel.scrollBy({ left: -cardWidth(), behavior: 'smooth' });
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function () {
        carousel.scrollBy({ left: cardWidth(), behavior: 'smooth' });
      });
    }
  })();
</script>

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.testimonials.settings.heading.label",
      "default": "Happy pets, happy owners"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.testimonials.settings.subheading.label",
      "default": "See what pet parents are saying"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "t:sections.testimonials.blocks.testimonial.name",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "t:sections.testimonials.blocks.testimonial.settings.quote.label",
          "default": "My dog absolutely loves these treats. The quality is amazing and you can tell they're made with natural ingredients!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "t:sections.testimonials.blocks.testimonial.settings.author.label",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "pet_name",
          "label": "t:sections.testimonials.blocks.testimonial.settings.pet_name.label",
          "default": "Buddy's mom"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.testimonials.blocks.testimonial.settings.image.label"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "t:sections.testimonials.blocks.testimonial.settings.rating.label",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        }
      ]
    }
  ]
}
{% endschema %}
