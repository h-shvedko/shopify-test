{%- assign form_id = 'newsletter-' | append: section.id -%}
{%- assign email_id = 'newsletter-email-' | append: section.id -%}

<section class="nl section-padding" data-scroll-reveal>
  <div class="container">
    <div class="nl__inner" data-reveal>
      <div class="nl__icon" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 64 64" fill="none">
          <circle cx="32" cy="32" r="32" fill="rgba(255,255,255,0.15)"/>
          <path d="M20 24c0-2.2 1.8-4 4-4h16c2.2 0 4 1.8 4 4v16c0 2.2-1.8 4-4 4H24c-2.2 0-4-1.8-4-4V24z" stroke="#ffffff" stroke-width="2" fill="none"/>
          <path d="M20 24l12 9 12-9" stroke="#ffffff" stroke-width="2" fill="none" stroke-linecap="round"/>
          <circle cx="44" cy="20" r="4" fill="#D97706"/>
          <path d="M43 20h2M44 19v2" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>

      {% if section.settings.heading != blank %}
        <h2 class="nl__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="nl__subheading">{{ section.settings.subheading | escape }}</p>
      {% endif %}

      {%- form 'customer', id: form_id, class: 'nl__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label for="{{ email_id }}" class="visually-hidden">{{ 'newsletter.placeholder' | t }}</label>
        <input
          type="email"
          id="{{ email_id }}"
          name="contact[email]"
          class="nl__input"
          placeholder="{{ 'newsletter.placeholder' | t }}"
          required
          autocomplete="email"
        >
        <button type="submit" class="nl__submit">
          {{ 'newsletter.subscribe' | t }}
        </button>
      {%- endform -%}

      {% if section.settings.privacy_note != blank %}
        <p class="nl__privacy">{{ section.settings.privacy_note | escape }}</p>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .nl {
    background: var(--color-primary, #059669);
    padding-top: 72px;
    padding-bottom: 72px;
    color: #ffffff;
  }

  .nl__inner {
    text-align: center;
    max-width: 580px;
    margin: 0 auto;
  }

  .nl__icon {
    margin-bottom: 20px;
  }

  .nl__heading {
    font-family: var(--font-heading, 'Nunito', sans-serif);
    font-size: clamp(1.875rem, 4vw, 2.75rem);
    font-weight: 800;
    color: #ffffff;
    margin: 0 0 12px;
    line-height: 1.15;
  }

  .nl__subheading {
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 auto 32px;
    max-width: 420px;
    line-height: 1.6;
  }

  .nl__form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 480px;
    margin: 0 auto;
  }

  @media (min-width: 560px) {
    .nl__form {
      flex-direction: row;
    }
  }

  .nl__input {
    flex: 1;
    padding: 14px 20px;
    border-radius: 24px;
    border: 2px solid rgba(255, 255, 255, 0.35);
    background: rgba(255, 255, 255, 0.15);
    color: #ffffff;
    font-size: 1rem;
    min-width: 0;
    transition: border-color 0.2s ease, background-color 0.2s ease;
    font-family: var(--font-body, 'Quicksand', sans-serif);
  }

  .nl__input::placeholder {
    color: rgba(255, 255, 255, 0.6);
  }

  .nl__input:focus {
    outline: none;
    border-color: rgba(255, 255, 255, 0.8);
    background: rgba(255, 255, 255, 0.22);
  }

  .nl__submit {
    padding: 14px 28px;
    border-radius: 24px;
    background: var(--color-secondary, #D97706);
    color: #ffffff;
    border: none;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    font-family: var(--font-heading, 'Nunito', sans-serif);
    white-space: nowrap;
    transition: background-color 0.2s ease, transform 0.15s ease;
  }

  .nl__submit:hover {
    background: #b45309;
    transform: translateY(-1px);
  }

  .nl__submit:active {
    transform: translateY(0);
  }

  .nl__submit:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 3px;
  }

  .nl__privacy {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.65);
    margin: 16px 0 0;
  }

  /* Scroll reveal (shared with featured-collection, but scoped here) */
  .nl [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  .nl [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
{% endstylesheet %}

<script>
  (function () {
    var revealEl = document.querySelector('.nl [data-reveal]');
    if (!revealEl) return;

    if (!('IntersectionObserver' in window)) {
      revealEl.classList.add('is-visible');
      return;
    }

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    observer.observe(revealEl);
  })();
</script>

{% schema %}
{
  "name": "t:sections.newsletter_cta.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.newsletter_cta.settings.heading.label",
      "default": "Join the pack"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.newsletter_cta.settings.subheading.label",
      "default": "Get exclusive deals, pet care tips, and early access to new arrivals."
    },
    {
      "type": "text",
      "id": "privacy_note",
      "label": "t:sections.newsletter_cta.settings.privacy_note.label",
      "default": "No spam, unsubscribe any time."
    }
  ],
  "presets": [
    {
      "name": "Newsletter CTA"
    }
  ]
}
{% endschema %}
