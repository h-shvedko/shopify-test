<section class="cl section-padding">
  <div class="container">
    {% if section.settings.heading != blank %}
      <h2 class="cl__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="cl__subheading">{{ section.settings.subheading | escape }}</p>
    {% endif %}

    <div class="cl__grid">
      {% for collection in collections %}
        {% if collection.handle != 'all' %}
          <a href="{{ collection.url }}" class="cl__item">
            <div class="cl__image-wrap">
              {% if collection.image %}
                {%- assign cl_alt = collection.title | escape -%}
                {{ collection.image
                  | image_url: width: 600
                  | image_tag:
                    class: 'cl__image',
                    loading: 'lazy',
                    alt: cl_alt,
                    width: 600,
                    height: 500
                }}
              {% else %}
                <div class="cl__image-placeholder" aria-hidden="true">
                  {{ 'collection-1' | placeholder_svg_tag: 'cl__placeholder-svg' }}
                </div>
              {% endif %}
              {% if collection.products_count > 0 %}
                <span class="cl__count">
                  {{ 'collections.products_count' | t: count: collection.products_count }}
                </span>
              {% endif %}
            </div>
            <div class="cl__info">
              <h3 class="cl__title">{{ collection.title }}</h3>
              <span class="cl__arrow" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .cl {
    padding-top: 64px;
    padding-bottom: 64px;
  }

  .cl__heading {
    font-family: var(--font-heading, 'Nunito', sans-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    color: var(--color-text, #1C1917);
    margin: 0 0 12px;
    text-align: center;
  }

  .cl__subheading {
    text-align: center;
    color: var(--color-text-secondary, #78716C);
    font-size: 1.0625rem;
    margin: 0 auto 40px;
    max-width: 480px;
    line-height: 1.6;
  }

  .cl__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .cl__item {
    display: block;
    text-decoration: none;
    border-radius: 12px;
    overflow: hidden;
    background: var(--color-surface, #ffffff);
    border: 1px solid var(--color-border, #E7E0D6);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .cl__item:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    transform: translateY(-3px);
  }

  .cl__item:focus-visible {
    outline: 2px solid var(--color-primary, #059669);
    outline-offset: 2px;
  }

  .cl__image-wrap {
    position: relative;
    overflow: hidden;
  }

  .cl__image {
    width: 100%;
    aspect-ratio: 5 / 4;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .cl__item:hover .cl__image {
    transform: scale(1.04);
  }

  .cl__image-placeholder {
    width: 100%;
    aspect-ratio: 5 / 4;
    background: var(--color-background, #F5F0E8);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cl__placeholder-svg {
    width: 60%;
    height: auto;
    opacity: 0.5;
  }

  .cl__count {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(255, 255, 255, 0.92);
    border-radius: 20px;
    padding: 3px 10px;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text, #1C1917);
    border: 1px solid var(--color-border, #E7E0D6);
  }

  .cl__info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 16px;
    gap: 8px;
  }

  .cl__title {
    font-family: var(--font-heading, 'Nunito', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text, #1C1917);
    margin: 0;
    line-height: 1.3;
  }

  .cl__arrow {
    color: var(--color-primary, #059669);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    transition: transform 0.2s ease;
  }

  .cl__item:hover .cl__arrow {
    transform: translateX(3px);
  }

  @media (min-width: 768px) {
    .cl__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
  }

  @media (min-width: 1024px) {
    .cl__grid {
      gap: 24px;
    }

    .cl__title {
      font-size: 1.0625rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.collections_list.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.collections_list.settings.heading.label",
      "default": "Shop by category"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.collections_list.settings.subheading.label",
      "default": "Find everything your furry friend needs"
    }
  ],
  "presets": [
    {
      "name": "Collections list"
    }
  ]
}
{% endschema %}
