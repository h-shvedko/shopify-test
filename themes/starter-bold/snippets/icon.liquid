{% doc %}
  Renders an inline SVG icon from the ArtVault icon set (Lucide-style).

  Parameters:
  - name {string} required — Icon identifier. One of: cart, search, truck, shield, star,
      check, minus, plus, menu, close, arrow-left, arrow-right, phone, mail, map-pin,
      chevron-right, chevron-down, shopping-bag, instagram, facebook, twitter, pinterest,
      play, heart, eye
  - size {number} optional — Width and height in pixels. Default: 24
  - class {string} optional — Additional CSS class(es) to apply to the <svg> element

  Usage:
    {% render 'icon', name: 'cart', size: 20, class: 'header__icon' %}
    {% render 'icon', name: 'instagram', size: 18 %}
{% enddoc %}

{%- liquid
  assign icon_size = size | default: 24
  assign icon_class = 'icon icon--' | append: name
  if class != blank
    assign icon_class = icon_class | append: ' ' | append: class
  endif
-%}

{%- case name -%}

  {%- when 'cart' -%}
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="{{ icon_size }}"
      height="{{ icon_size }}"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="{{ icon_class }}"
      aria-hidden="true"
      focusable="false"
    ><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>

