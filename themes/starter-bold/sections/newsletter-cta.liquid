{%- liquid
  assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0
-%}

<section
  class="newsletter-cta"
  {%- if section.settings.image != blank -%}
    style="background-image: url('{{ section.settings.image | image_url: width: 2000 }}');"
  {%- endif -%}
>
  {%- if section.settings.image != blank -%}
    <img
      src="{{ section.settings.image | image_url: width: 2000 }}"
      alt="{{ section.settings.image.alt | escape }}"
      class="newsletter-cta__bg-img"
      width="2000"
      height="900"
      loading="lazy"
    >
  {%- endif -%}

  <div class="newsletter-cta__overlay" style="opacity: {{ overlay_alpha }};"></div>

  <div class="container">
    <div class="newsletter-cta__content">
      <h2>{{ section.settings.heading }}</h2>

      {%- if section.settings.subtitle != blank -%}
        <p>{{ section.settings.subtitle }}</p>
      {%- endif -%}

      {%- form 'customer', id: 'newsletter-form-{{ section.id }}', class: 'newsletter-cta__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label for="newsletter-email-{{ section.id }}" class="visually-hidden">
          {{ 'newsletter.placeholder' | t }}
        </label>
        <input
          type="email"
          id="newsletter-email-{{ section.id }}"
          name="contact[email]"
          class="newsletter-cta__input"
          placeholder="{{ 'newsletter.placeholder' | t }}"
          required
          autocomplete="email"
        >
        <button type="submit" class="btn btn--primary">
          {{ 'newsletter.subscribe' | t }}
        </button>
      {%- endform -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .newsletter-cta {
    position: relative;
    padding: 100px 0;
    color: #ffffff;
    text-align: center;
    background-color: var(--color-primary-dark, #1e3d2a);
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }

  .newsletter-cta__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .newsletter-cta__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(45, 90, 61, 0.92), rgba(30, 61, 42, 0.88));
    z-index: 1;
  }

  .newsletter-cta .container {
    position: relative;
    z-index: 2;
  }

  .newsletter-cta__content {
    position: relative;
  }

  .newsletter-cta h2 {
    font-family: var(--font-heading, georgia, serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    margin: 0 0 12px;
    color: #ffffff;
    line-height: 1.15;
  }

  .newsletter-cta h2 em {
    color: var(--color-accent-light, #e8c4a0);
    font-style: italic;
  }

  .newsletter-cta p {
    color: rgba(255, 255, 255, 0.75);
    margin: 0 auto 32px;
    max-width: 500px;
    line-height: 1.7;
  }

  .newsletter-cta__form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 480px;
    margin: 0 auto;
  }

  @media (min-width: 600px) {
    .newsletter-cta__form {
      flex-direction: row;
    }
  }

  .newsletter-cta__input {
    flex: 1;
    padding: 14px 20px;
    border-radius: var(--border-radius, 4px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    font-size: 1rem;
    min-width: 0;
  }

  .newsletter-cta__input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  .newsletter-cta__input:focus {
    outline: 2px solid rgba(255, 255, 255, 0.5);
    outline-offset: 2px;
  }

  @media (max-width: 767px) {
    .newsletter-cta {
      padding: 64px 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.newsletter_cta.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.newsletter_cta.settings.image.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.newsletter_cta.settings.heading.label",
      "default": "Join the creative circle"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "t:sections.newsletter_cta.settings.subtitle.label",
      "default": "Get early access to new collections, artist stories, and exclusive offers."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.newsletter_cta.settings.overlay_opacity.label",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 90,
      "unit": "%"
    }
  ],
  "presets": [
    {
      "name": "Newsletter CTA"
    }
  ]
}
{% endschema %}
