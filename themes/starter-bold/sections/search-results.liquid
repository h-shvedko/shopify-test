{% paginate search.results by section.settings.products_per_page %}
<section class="search-results section-padding">
  <div class="container">
    <h1 class="search-results__title">{{ 'search.title' | t }}</h1>

    <form action="/search" method="get" class="search-results__form" role="search">
      <label for="search-input" class="visually-hidden">{{ 'search.placeholder' | t }}</label>
      <input
        type="text"
        id="search-input"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'search.placeholder' | t }}"
        autocomplete="off"
        class="search-results__input"
      >
      <button type="submit" class="btn btn--green">{{ 'general.search' | t }}</button>
    </form>

    {% if search.performed %}
      {% if search.results_count > 0 %}
        <p class="search-results__count">
          {{ 'search.results_count' | t: count: search.results_count, query: search.terms }}
        </p>
        <div class="search-results__grid">
          {% for item in search.results %}
            {% if item.object_type == 'product' %}
              {%- assign quick_view_label = 'products.quick_view' | t -%}
              {% render 'product-card', product: item, quick_view_label: quick_view_label %}
            {% else %}
              <div class="search-results__article">
                <h3 class="search-results__article-title">
                  <a href="{{ item.url }}">{{ item.title }}</a>
                </h3>
                <p class="search-results__article-excerpt">
                  {{ item.content | strip_html | truncate: 150 }}
                </p>
              </div>
            {% endif %}
          {% endfor %}
        </div>
        {% render 'pagination', paginate: paginate %}
      {% else %}
        <p class="search-results__no-results">
          {{ 'search.no_results' | t: query: search.terms }}
        </p>
      {% endif %}
    {% endif %}
  </div>
</section>
{% endpaginate %}

{% stylesheet %}
  .search-results__title {
    font-family: var(--font-heading);
    margin-bottom: 32px;
    color: var(--color-text);
  }

  .search-results__form {
    display: flex;
    gap: 12px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .search-results__input {
    flex: 1;
    min-width: 220px;
    padding: 14px 20px;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-background);
    transition: border-color 0.2s ease;
    font-family: var(--font-body);
  }

  .search-results__input::placeholder {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .search-results__input:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .search-results__input:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .search-results__count {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    margin-bottom: 28px;
    font-style: italic;
  }

  .search-results__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 40px;
  }

  .search-results__article {
    padding: 24px;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    background: var(--color-background-warm);
    transition: box-shadow 0.2s;
  }

  .search-results__article:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .search-results__article-title {
    font-family: var(--font-heading);
    margin-bottom: 8px;
    font-size: 1.0625rem;
  }

  .search-results__article-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .search-results__article-title a:hover {
    color: var(--color-primary);
  }

  .search-results__article-excerpt {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .search-results__no-results {
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
    padding: 48px 0;
    font-style: italic;
  }

  @media (min-width: 768px) {
    .search-results__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
    }
  }

  @media (min-width: 1024px) {
    .search-results__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.search_results.name",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "t:sections.search_results.settings.products_per_page.label",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Search results"
    }
  ]
}
{% endschema %}
