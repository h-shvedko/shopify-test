<section class="not-found section-padding">
  <div class="container not-found__content">
    <p class="not-found__eyebrow">404</p>
    <h1 class="not-found__heading">{{ section.settings.heading }}</h1>
    <p class="not-found__message">{{ section.settings.message }}</p>
    {% render 'button',
      label: section.settings.button_label,
      url: section.settings.button_url,
      variant: 'green'
    %}
  </div>
</section>

{% stylesheet %}
  .not-found__content {
    text-align: center;
    padding-top: 60px;
    padding-bottom: 60px;
  }

  .not-found__eyebrow {
    font-family: var(--font-heading);
    font-size: calc(5rem * var(--font-scale-factor));
    font-weight: 700;
    color: var(--color-border);
    line-height: 1;
    margin-bottom: 0;
    letter-spacing: -0.02em;
  }

  .not-found__heading {
    font-family: var(--font-heading);
    font-size: calc(2rem * var(--font-scale-factor));
    color: var(--color-text);
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .not-found__message {
    color: var(--color-text-secondary);
    font-size: 1.125rem;
    margin-bottom: 40px;
    max-width: 480px;
    margin-inline: auto;
    font-style: italic;
  }

  @media (min-width: 768px) {
    .not-found__content {
      padding-top: 100px;
      padding-bottom: 100px;
    }

    .not-found__eyebrow {
      font-size: calc(8rem * var(--font-scale-factor));
    }

    .not-found__heading {
      font-size: calc(2.5rem * var(--font-scale-factor));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.not_found.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.not_found.settings.heading.label",
      "default": "Page not found"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "t:sections.not_found.settings.message.label",
      "default": "The page you're looking for doesn't exist."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.not_found.settings.button_label.label",
      "default": "Back to home"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.not_found.settings.button_url.label",
      "default": "/"
    }
  ],
  "presets": [
    {
      "name": "404 page"
    }
  ]
}
{% endschema %}
