<section class="collections-list section-padding">
  <div class="container">
    {% if section.settings.heading != blank %}
      <h1 class="collections-list__heading">{{ section.settings.heading }}</h1>
    {% endif %}
    <div class="collections-list__grid">
      {% for collection in collections %}
        {% if collection.handle != 'all' %}
          <a href="{{ collection.url }}" class="collections-list__item">
            <div class="collections-list__item-image">
              {% if collection.image %}
                {{ collection.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: collection.title }}
              {% else %}
                <div class="collections-list__item-placeholder" aria-hidden="true"></div>
              {% endif %}
            </div>
            <div class="collections-list__item-info">
              <h3 class="collections-list__item-title">{{ collection.title }}</h3>
              <span class="collections-list__item-count">{{ collection.products_count }} {{ 'blocks.collection_card.products' | t }}</span>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .collections-list__heading {
    font-family: var(--font-heading);
    margin-bottom: 40px;
    color: var(--color-text);
  }

  .collections-list__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .collections-list__item {
    display: block;
    text-decoration: none;
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    background: var(--color-background-alt);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .collections-list__item:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.1);
    text-decoration: none;
  }

  .collections-list__item:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .collections-list__item-image {
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .collections-list__item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .collections-list__item:hover .collections-list__item-image img {
    transform: scale(1.06);
  }

  .collections-list__item-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-border);
  }

  .collections-list__item-info {
    padding: 16px 20px;
  }

  .collections-list__item-title {
    color: var(--color-text);
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .collections-list__item-count {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    display: block;
  }

  @media (min-width: 768px) {
    .collections-list__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
    }
  }

  @media (min-width: 1024px) {
    .collections-list__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.collections_list.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.collections_list.settings.heading.label",
      "default": "All collections"
    }
  ],
  "presets": [
    {
      "name": "Collections list"
    }
  ]
}
{% endschema %}
