<section class="main-page section-padding">
  <div class="container">
    {% if section.settings.show_title %}
      <h1 class="main-page__title">{{ page.title }}</h1>
    {% endif %}
    <div class="main-page__content">{{ page.content }}</div>
  </div>
</section>

{% stylesheet %}
  .main-page__title {
    font-family: var(--font-heading);
    margin-bottom: 40px;
    color: var(--color-text);
  }

  .main-page__content {
    line-height: 1.8;
    max-width: 800px;
    font-size: 1rem;
    color: var(--color-text);
  }

  .main-page__content p {
    margin-bottom: 1.25em;
    color: var(--color-text);
  }

  .main-page__content h2 {
    font-family: var(--font-heading);
    margin-top: 1.75em;
    margin-bottom: 0.75em;
    color: var(--color-text);
  }

  .main-page__content h3 {
    font-family: var(--font-heading);
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }

  .main-page__content ul,
  .main-page__content ol {
    margin-bottom: 1.25em;
    padding-left: 1.5em;
  }

  .main-page__content li {
    margin-bottom: 0.5em;
  }

  .main-page__content a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .main-page__content a:hover {
    opacity: 0.8;
  }

  .main-page__content blockquote {
    border-left: 4px solid var(--color-accent);
    padding-left: 1.25em;
    margin: 1.5em 0;
    color: var(--color-text-secondary);
    font-style: italic;
    font-family: var(--font-heading);
  }

  .main-page__content img {
    border-radius: var(--border-radius-lg);
    margin: 1.5em 0;
  }

  .main-page__content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5em;
    font-size: 0.9375rem;
  }

  .main-page__content th,
  .main-page__content td {
    padding: 12px 16px;
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .main-page__content th {
    background: var(--color-background-alt);
    font-weight: 600;
    font-family: var(--font-heading);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.main_page.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "t:sections.main_page.settings.show_title.label",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Page content"
    }
  ]
}
{% endschema %}
