<section class="customer-account section-padding">
  <div class="container">
    <h1 class="customer-account__title">{{ 'customer.account_title' | t }}</h1>

    <h2 class="customer-account__subtitle">{{ 'customer.order_history' | t }}</h2>

    {% if customer.orders.size > 0 %}
      <div class="customer-account__table-wrap">
        <table class="customer-account__orders">
          <thead>
            <tr>
              <th>{{ 'customer.order_number' | t: number: '' }}</th>
              <th>{{ 'customer.order_date' | t }}</th>
              <th>{{ 'customer.order_total' | t }}</th>
              <th>{{ 'customer.order_status' | t }}</th>
            </tr>
          </thead>
          <tbody>
            {% for order in customer.orders %}
              <tr>
                <td>
                  <a href="{{ order.customer_url }}" class="customer-account__order-link">
                    {{ order.name }}
                  </a>
                </td>
                <td>{{ order.created_at | date: "%B %d, %Y" }}</td>
                <td class="customer-account__order-total">{{ order.total_price | money }}</td>
                <td>
                  <span class="customer-account__status">{{ order.financial_status_label }}</span>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% else %}
      <p class="customer-account__no-orders">{{ 'customer.no_orders' | t }}</p>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .customer-account__title {
    font-family: var(--font-heading);
    margin-bottom: 8px;
    color: var(--color-text);
  }

  .customer-account__subtitle {
    font-family: var(--font-heading);
    margin-bottom: 28px;
    font-size: calc(1.25rem * var(--font-scale-factor));
    color: var(--color-text-secondary);
    font-weight: 400;
    font-style: italic;
  }

  .customer-account__no-orders {
    color: var(--color-text-secondary);
    padding: 32px 0;
    font-style: italic;
  }

  .customer-account__table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--border-radius-lg);
    border: 1px solid var(--color-border);
  }

  .customer-account__orders {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
  }

  .customer-account__orders thead {
    background: var(--color-background-warm);
  }

  .customer-account__orders th {
    padding: 16px 20px;
    text-align: left;
    font-weight: 600;
    font-family: var(--font-heading);
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    white-space: nowrap;
    font-size: 0.875rem;
    letter-spacing: 0.02em;
  }

  .customer-account__orders td {
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    vertical-align: middle;
  }

  .customer-account__orders tbody tr:last-child td {
    border-bottom: none;
  }

  .customer-account__orders tbody tr:hover {
    background: var(--color-background-alt);
  }

  .customer-account__order-link {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
    font-family: var(--font-heading);
  }

  .customer-account__order-link:hover {
    text-decoration: underline;
  }

  .customer-account__order-total {
    font-weight: 700;
    color: var(--color-primary);
  }

  .customer-account__status {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 600;
    background: var(--color-background-alt);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.customer_account.name",
  "settings": [],
  "templates": ["customers/account"]
}
{% endschema %}
