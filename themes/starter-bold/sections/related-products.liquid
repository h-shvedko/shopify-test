{% if recommendations.performed %}
  {% if recommendations.products_count > 0 %}
    <section class="related-products section-padding" data-product-id="{{ product.id }}" data-products-count="{{ section.settings.products_count }}">
      <div class="container">
        <h2 class="related-products__heading">{{ section.settings.heading }}</h2>
        <div class="related-products__grid" data-related-products>
          {% for recommendation in recommendations.products limit: section.settings.products_count %}
            {%- assign quick_view_label = 'products.quick_view' | t -%}
            {% render 'product-card', product: recommendation, quick_view_label: quick_view_label %}
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}
{% else %}
  <section class="related-products section-padding" data-product-id="{{ product.id }}" data-products-count="{{ section.settings.products_count }}">
    <div class="container">
      <h2 class="related-products__heading">{{ section.settings.heading }}</h2>
      <div class="related-products__grid" data-related-products>
      </div>
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .related-products {
    background: var(--color-background-warm);
  }

  .related-products__heading {
    text-align: center;
    margin-bottom: 40px;
    font-family: var(--font-heading);
    color: var(--color-text);
  }

  .related-products__heading em {
    font-style: italic;
    color: var(--color-accent-light);
  }

  .related-products__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media (min-width: 768px) {
    .related-products__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
    }
  }

  @media (min-width: 1024px) {
    .related-products__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var section = document.querySelector('.related-products[data-product-id]');
    if (!section) return;

    var grid = section.querySelector('[data-related-products]');
    if (!grid) return;

    if (grid.children.length > 0) return;

    var productId = section.dataset.productId;
    var limit = section.dataset.productsCount || '4';

    if (!productId) return;

    fetch(
      '/recommendations/products.json?product_id=' +
        encodeURIComponent(productId) +
        '&limit=' +
        encodeURIComponent(limit),
      { headers: { 'X-Requested-With': 'XMLHttpRequest' } }
    )
      .then(function (response) {
        if (!response.ok) throw new Error('Failed to load recommendations');
        return response.json();
      })
      .then(function (data) {
        var products = data.products;
        if (!products || products.length === 0) {
          section.hidden = true;
          return;
        }

        products.forEach(function (product) {
          var card = buildProductCard(product);
          grid.appendChild(card);
        });
      })
      .catch(function () {
        section.hidden = true;
      });

    function buildProductCard(product) {
      var article = document.createElement('article');
      article.className = 'product-card';

      var imageUrl = product.featured_image
        ? product.featured_image.replace(/(\.\w+)(\?.*)?$/, '_600x750$1')
        : null;

      var imageHtml = imageUrl
        ? '<img class="product-card__img" src="' + imageUrl + '" alt="' + escapeHtml(product.title) + '" width="600" height="750" loading="lazy">'
        : '<div class="product-card__image-placeholder" aria-hidden="true"></div>';

      var priceHtml = formatMoney(product.price_min);

      article.innerHTML =
        '<div class="product-card__image">' +
          '<a href="' + product.url + '" tabindex="-1" aria-hidden="true">' +
            imageHtml +
          '</a>' +
        '</div>' +
        '<div class="product-card__info">' +
          '<h3 class="product-card__title"><a href="' + product.url + '">' + escapeHtml(product.title) + '</a></h3>' +
          '<div class="product-card__prices"><span class="product-card__price-current">' + priceHtml + '</span></div>' +
        '</div>';

      return article;
    }

    function formatMoney(cents) {
      var amount = (cents / 100).toFixed(2);
      var format = (window.Shopify && window.Shopify.money_format) || '${{amount}}';
      return format
        .replace('{{amount}}', amount)
        .replace('{{amount_with_comma_separator}}', amount.replace('.', ','))
        .replace('{{amount_no_decimals}}', Math.round(cents / 100).toString());
    }

    function escapeHtml(str) {
      var div = document.createElement('div');
      div.appendChild(document.createTextNode(str));
      return div.innerHTML;
    }
  })();
</script>

{% schema %}
{
  "name": "t:sections.related_products.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.related_products.settings.heading.label",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "t:sections.related_products.settings.products_count.label",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Related products"
    }
  ]
}
{% endschema %}
