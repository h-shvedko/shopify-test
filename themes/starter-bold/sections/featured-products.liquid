{%- liquid
  assign columns = section.settings.columns_desktop | default: '4'
  assign products_to_show = section.settings.products_count | default: 8

  if section.settings.collection != blank
    assign source_collection = collections[section.settings.collection]
  endif

  assign quick_view_label = 'products.quick_view' | t

  assign all_label = 'products.all' | t
  assign paintings_label = 'products.filter_paintings' | t
  assign prints_label = 'products.filter_prints' | t
  assign sculptures_label = 'products.filter_sculptures' | t
  assign ceramics_label = 'products.filter_ceramics' | t
-%}

<section class="featured-products section-padding" data-section-id="{{ section.id }}" style="--fp-columns: {{ columns }};">
  <div class="container">
    <div class="featured-products__header">
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="featured-products__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      {%- if section.settings.show_tabs -%}
        <div class="featured-products__tabs" role="tablist" aria-label="{{ section.settings.heading | escape }}">
          <button
            class="featured-products__tab featured-products__tab--active"
            role="tab"
            aria-selected="true"
            data-filter="all"
          >{{ all_label }}</button>
          <button
            class="featured-products__tab"
            role="tab"
            aria-selected="false"
            data-filter="paintings"
          >{{ paintings_label }}</button>
          <button
            class="featured-products__tab"
            role="tab"
            aria-selected="false"
            data-filter="prints"
          >{{ prints_label }}</button>
          <button
            class="featured-products__tab"
            role="tab"
            aria-selected="false"
            data-filter="sculptures"
          >{{ sculptures_label }}</button>
          <button
            class="featured-products__tab"
            role="tab"
            aria-selected="false"
            data-filter="ceramics"
          >{{ ceramics_label }}</button>
        </div>
      {%- endif -%}
    </div>

    <div class="featured-products__grid" data-products-grid>
      {%- if source_collection != blank -%}
        {%- for product in source_collection.products limit: products_to_show -%}
          <div class="featured-products__item" data-product-types="{{ product.type | downcase | replace: ' ', '-' }}">
            {% render 'product-card', product: product, quick_view_label: quick_view_label %}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..products_to_show) -%}
          {%- assign placeholder_product = 'product-' | append: i -%}
          <div class="featured-products__item" data-product-types="paintings">
            <div class="product-card">
              <div class="product-card__image">
                {{ placeholder_product | placeholder_svg_tag: 'product-card__image-placeholder' }}
              </div>
              <div class="product-card__info">
                <p class="product-card__category">{{ 'products.filter_paintings' | t }}</p>
                <h3 class="product-card__title"><a href="#">{{ 'badges.featured' | t }} {{ 'products.filter_paintings' | t }}</a></h3>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .featured-products {
    padding: 48px 0;
    background: var(--color-background-warm, #f5f0eb);
  }

  @media (min-width: 1024px) {
    .featured-products {
      padding: 80px 0;
    }
  }

  .featured-products__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .featured-products__header h2 {
    font-family: var(--font-heading, georgia, serif);
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    margin: 0 0 8px;
  }

  .featured-products__subtitle {
    color: var(--color-text-secondary, #6b6b63);
    margin: 0 auto 0;
    max-width: 520px;
    line-height: 1.6;
  }

  .featured-products__tabs {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 24px;
  }

  .featured-products__tab {
    padding: 8px 20px;
    border-radius: 24px;
    font-size: 0.85rem;
    font-weight: 500;
    border: 1px solid var(--color-border, #e0ddd6);
    background: transparent;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    color: var(--color-text, #1a1a18);
  }

  .featured-products__tab:hover {
    border-color: var(--color-primary, #2d5a3d);
    color: var(--color-primary, #2d5a3d);
  }

  .featured-products__tab--active {
    background: var(--color-primary, #2d5a3d);
    color: #ffffff;
    border-color: var(--color-primary, #2d5a3d);
  }

  .featured-products__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media (min-width: 1024px) {
    .featured-products__grid {
      grid-template-columns: repeat(var(--fp-columns, 4), 1fr);
    }
  }

  .featured-products__item {
    transition: opacity 0.3s;
  }

  .featured-products__item[hidden] {
    display: none;
  }
{% endstylesheet %}

<script>
  (function () {
    var section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    var tabs = section.querySelectorAll('.featured-products__tab');
    var items = section.querySelectorAll('.featured-products__item');

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        var filter = tab.dataset.filter;

        tabs.forEach(function (t) {
          t.classList.remove('featured-products__tab--active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('featured-products__tab--active');
        tab.setAttribute('aria-selected', 'true');

        items.forEach(function (item) {
          if (filter === 'all') {
            item.hidden = false;
          } else {
            var types = (item.dataset.productTypes || '').split(' ');
            item.hidden = !types.includes(filter);
          }
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "t:sections.featured_products.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured_products.settings.heading.label",
      "default": "New arrivals"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:sections.featured_products.settings.subtitle.label",
      "default": "Fresh from the studios of our featured artists"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured_products.settings.collection.label"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "t:sections.featured_products.settings.products_count.label",
      "min": 2,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_tabs",
      "label": "t:sections.featured_products.settings.show_tabs.label",
      "default": true
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "t:sections.featured_products.settings.columns_desktop.label",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
