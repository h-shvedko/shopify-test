<section class="social-feed section-padding">
  <div class="container">
    <div class="social-feed__header">
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p>{{ section.settings.subtitle }}</p>
      {%- endif -%}
      {%- if section.settings.handle != blank -%}
        <a
          href="{{ section.settings.handle_url }}"
          class="social-feed__handle"
          {%- if section.settings.handle_url != blank -%}
            target="_blank"
            rel="noopener noreferrer"
          {%- endif -%}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="currentColor" stroke-width="2"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" stroke="currentColor" stroke-width="2"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
          </svg>
          {{ section.settings.handle }}
        </a>
      {%- endif -%}
    </div>
  </div>
  <div class="social-feed__grid">
    {% content_for 'blocks' %}
  </div>
</section>

{% stylesheet %}
  .social-feed {
    padding: 48px 0;
  }

  @media (min-width: 1024px) {
    .social-feed {
      padding: 80px 0;
    }
  }

  .social-feed__header {
    text-align: center;
    margin-bottom: 40px;
  }

  .social-feed__header h2 {
    font-family: var(--font-heading, georgia, serif);
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    margin: 0 0 12px;
  }

  .social-feed__header p {
    color: var(--color-text-secondary, #6b6b63);
    margin: 0 0 12px;
    line-height: 1.6;
  }

  .social-feed__handle {
    color: var(--color-primary, #2d5a3d);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    margin-top: 12px;
    transition: opacity 0.2s;
  }

  .social-feed__handle:hover {
    opacity: 0.75;
  }

  .social-feed__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
  }

  @media (min-width: 1024px) {
    .social-feed__grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.social_feed.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.social_feed.settings.heading.label",
      "default": "Follow the movement"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:sections.social_feed.settings.subtitle.label",
      "default": "See how our community styles their spaces"
    },
    {
      "type": "text",
      "id": "handle",
      "label": "t:sections.social_feed.settings.handle.label",
      "default": "@artvault"
    },
    {
      "type": "url",
      "id": "handle_url",
      "label": "t:sections.social_feed.settings.handle_url.label"
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    }
  ],
  "presets": [
    {
      "name": "Social feed"
    }
  ]
}
{% endschema %}
