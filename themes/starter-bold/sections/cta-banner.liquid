<section class="cta-banner">
  <div class="container">
    <div class="cta-banner__content">
      <h2 class="cta-banner__heading">{{ section.settings.heading }}</h2>

      {%- if section.settings.subtitle != blank -%}
        <p class="cta-banner__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        {%- assign btn_label = section.settings.button_label -%}
        {%- assign btn_url = section.settings.button_url | default: '/collections/all' -%}
        {% render 'button', label: btn_label, url: btn_url, variant: 'outline' %}
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .cta-banner {
    background: var(--color-primary, #2d5a3d);
    color: #ffffff;
    text-align: center;
    padding: 80px 0;
  }

  .cta-banner__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .cta-banner__heading {
    font-family: var(--font-heading, georgia, serif);
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    font-weight: 700;
    margin: 0;
    color: #ffffff;
    line-height: 1.2;
  }

  .cta-banner__subtitle {
    color: rgba(255, 255, 255, 0.8);
    max-width: 520px;
    margin: 0;
    line-height: 1.6;
    font-size: 1.05rem;
  }

  .cta-banner .btn--outline {
    margin-top: 8px;
    border-color: rgba(255, 255, 255, 0.6);
    color: #ffffff;
  }

  .cta-banner .btn--outline:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: #ffffff;
  }

  @media (max-width: 767px) {
    .cta-banner {
      padding: 56px 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.cta_banner.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.cta_banner.settings.heading.label",
      "default": "Ready to create?"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "t:sections.cta_banner.settings.subtitle.label",
      "default": "Discover unique artworks from independent artists worldwide."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.cta_banner.settings.button_label.label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.cta_banner.settings.button_url.label",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "CTA banner"
    }
  ]
}
{% endschema %}
