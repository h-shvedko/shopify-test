{%- liquid
  assign image_pos = section.settings.image_position | default: 'left'
-%}

<section class="editorial-split{% if image_pos == 'right' %} editorial-split--reverse{% endif %}">
  <div class="editorial-split__grid">
    <div class="editorial-split__image">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1000 }}"
          alt="{{ section.settings.image.alt | escape }}"
          width="1000"
          height="1000"
          loading="lazy"
        >
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'editorial-split__placeholder' }}
      {%- endif -%}
    </div>

    <div class="editorial-split__content">
      <h2>{{ section.settings.heading }}</h2>

      {%- if section.settings.description != blank -%}
        <p>{{ section.settings.description }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        {%- assign btn_label = section.settings.button_label -%}
        {%- assign btn_url = section.settings.button_url -%}
        {% render 'button', label: btn_label, url: btn_url, variant: 'primary' %}
      {%- endif -%}

      {%- assign has_stat1 = false -%}
      {%- assign has_stat2 = false -%}
      {%- assign has_stat3 = false -%}
      {%- if section.settings.stat_1_number != blank -%}
        {%- assign has_stat1 = true -%}
      {%- endif -%}
      {%- if section.settings.stat_2_number != blank -%}
        {%- assign has_stat2 = true -%}
      {%- endif -%}
      {%- if section.settings.stat_3_number != blank -%}
        {%- assign has_stat3 = true -%}
      {%- endif -%}

      {%- if has_stat1 or has_stat2 or has_stat3 -%}
        <div class="editorial-split__stats">
          {%- if has_stat1 -%}
            <div class="editorial-split__stat">
              <span class="editorial-split__stat-number">{{ section.settings.stat_1_number }}</span>
              {%- if section.settings.stat_1_label != blank -%}
                <span class="editorial-split__stat-label">{{ section.settings.stat_1_label }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
          {%- if has_stat2 -%}
            <div class="editorial-split__stat">
              <span class="editorial-split__stat-number">{{ section.settings.stat_2_number }}</span>
              {%- if section.settings.stat_2_label != blank -%}
                <span class="editorial-split__stat-label">{{ section.settings.stat_2_label }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
          {%- if has_stat3 -%}
            <div class="editorial-split__stat">
              <span class="editorial-split__stat-number">{{ section.settings.stat_3_number }}</span>
              {%- if section.settings.stat_3_label != blank -%}
                <span class="editorial-split__stat-label">{{ section.settings.stat_3_label }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .editorial-split__grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 480px;
  }

  @media (min-width: 1024px) {
    .editorial-split__grid {
      grid-template-columns: 1fr 1fr;
      min-height: 600px;
    }

    .editorial-split--reverse .editorial-split__grid {
      direction: rtl;
    }

    .editorial-split--reverse .editorial-split__content {
      direction: ltr;
    }
  }

  .editorial-split__image {
    overflow: hidden;
    min-height: 320px;
  }

  @media (min-width: 1024px) {
    .editorial-split__image {
      min-height: unset;
    }
  }

  .editorial-split__image img,
  .editorial-split__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .editorial-split__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 48px 24px;
    background: var(--color-primary-dark, #1e3d2a);
    color: #ffffff;
  }

  @media (min-width: 1024px) {
    .editorial-split__content {
      padding: 80px 64px;
    }
  }

  .editorial-split__content h2 {
    font-family: var(--font-heading, georgia, serif);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700;
    margin: 0 0 20px;
    color: #ffffff;
    line-height: 1.15;
  }

  .editorial-split__content h2 em {
    color: var(--color-accent-light, #e8c4a0);
    font-style: italic;
  }

  .editorial-split__content p {
    color: rgba(255, 255, 255, 0.75);
    margin: 0 0 32px;
    max-width: 420px;
    line-height: 1.7;
  }

  .editorial-split__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 40px;
    margin-top: 40px;
  }

  .editorial-split__stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .editorial-split__stat-number {
    font-family: var(--font-heading, georgia, serif);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-accent-light, #e8c4a0);
    line-height: 1;
  }

  .editorial-split__stat-label {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.editorial_split.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.editorial_split.settings.image.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.editorial_split.settings.heading.label",
      "default": "Every piece tells a story"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.editorial_split.settings.description.label",
      "default": "We partner directly with independent artists and small studios to bring you one-of-a-kind works that transform your space."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.editorial_split.settings.button_label.label",
      "default": "Meet our artists"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.editorial_split.settings.button_url.label"
    },
    {
      "type": "text",
      "id": "stat_1_number",
      "label": "t:sections.editorial_split.settings.stat_1_number.label",
      "default": "200+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "t:sections.editorial_split.settings.stat_1_label.label",
      "default": "Artists"
    },
    {
      "type": "text",
      "id": "stat_2_number",
      "label": "t:sections.editorial_split.settings.stat_2_number.label",
      "default": "12k"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "t:sections.editorial_split.settings.stat_2_label.label",
      "default": "Pieces sold"
    },
    {
      "type": "text",
      "id": "stat_3_number",
      "label": "t:sections.editorial_split.settings.stat_3_number.label",
      "default": "48"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "t:sections.editorial_split.settings.stat_3_label.label",
      "default": "Countries"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:sections.editorial_split.settings.image_position.label",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Editorial split"
    }
  ]
}
{% endschema %}
