<footer class="footer" data-section-id="{{ section.id }}" role="contentinfo">
  <div class="footer__container">

    <div class="footer__grid">

      {%- comment -%} Brand column {%- endcomment -%}
      <div class="footer__brand">
        <div class="footer__brand-logo">Art<em>Vault</em></div>

        {% if section.settings.about_text != blank %}
          <p class="footer__about">{{ section.settings.about_text }}</p>
        {% endif %}

        {%- comment -%} Social icons {%- endcomment -%}
        {%- assign follow_label = 'social.follow_us' | t -%}
        <div class="footer__social" aria-label="{{ follow_label }}">
          {% if section.settings.social_instagram != blank %}
            {% render 'social-icon', platform: 'instagram', url: section.settings.social_instagram, follow_label: follow_label %}
          {% endif %}
          {% if section.settings.social_facebook != blank %}
            {% render 'social-icon', platform: 'facebook', url: section.settings.social_facebook, follow_label: follow_label %}
          {% endif %}
          {% if section.settings.social_twitter != blank %}
            {% render 'social-icon', platform: 'twitter', url: section.settings.social_twitter, follow_label: follow_label %}
          {% endif %}
          {% if section.settings.social_pinterest != blank %}
            {% render 'social-icon', platform: 'pinterest', url: section.settings.social_pinterest, follow_label: follow_label %}
          {% endif %}
        </div>
      </div>

      {%- comment -%} Link column 1 {%- endcomment -%}
      {% if section.settings.menu_1 != blank %}
        <div class="footer__col">
          {% if section.settings.menu_1_heading != blank %}
            <h4 class="footer__col-heading">{{ section.settings.menu_1_heading }}</h4>
          {% endif %}
          <ul class="footer__link-list">
            {% for link in linklists[section.settings.menu_1].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      {%- comment -%} Link column 2 {%- endcomment -%}
      {% if section.settings.menu_2 != blank %}
        <div class="footer__col">
          {% if section.settings.menu_2_heading != blank %}
            <h4 class="footer__col-heading">{{ section.settings.menu_2_heading }}</h4>
          {% endif %}
          <ul class="footer__link-list">
            {% for link in linklists[section.settings.menu_2].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      {%- comment -%} Link column 3 {%- endcomment -%}
      {% if section.settings.menu_3 != blank %}
        <div class="footer__col">
          {% if section.settings.menu_3_heading != blank %}
            <h4 class="footer__col-heading">{{ section.settings.menu_3_heading }}</h4>
          {% endif %}
          <ul class="footer__link-list">
            {% for link in linklists[section.settings.menu_3].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

    </div>{%- comment -%} .footer__grid {%- endcomment -%}

  </div>{%- comment -%} .footer__container {%- endcomment -%}

  {%- comment -%} Bottom bar {%- endcomment -%}
  <div class="footer__bottom-wrap">
    <div class="footer__container">
      <div class="footer__bottom">
        <p class="footer__copyright">
          {%- assign current_year = 'now' | date: '%Y' -%}
          {{ 'footer.copyright' | t: year: current_year }}
        </p>
        {% render 'payment-icons' %}
      </div>
    </div>
  </div>

</footer>

{% stylesheet %}
  .footer {
    background: var(--color-footer-bg);
    color: var(--color-footer-text);
    padding: 64px 0 0;
  }

  .footer__container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Grid layout ── */
  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1024px) {
    .footer__grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }

    .footer__brand {
      grid-column: auto;
    }
  }

  /* ── Brand column ── */
  .footer__brand-logo {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 900;
    color: #ffffff;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 12px;
  }

  .footer__brand-logo em {
    font-style: italic;
    color: var(--color-accent);
    font-weight: 400;
  }

  .footer__about {
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 0 0 24px;
    max-width: 320px;
    opacity: 0.8;
  }

  /* ── Social icons ── */
  .footer__social {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ── Link columns ── */
  .footer__col-heading {
    color: #ffffff;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 16px;
  }

  .footer__link-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__link-list a {
    color: var(--color-footer-text);
    text-decoration: none;
    font-size: 0.875rem;
    opacity: 0.8;
    transition: color 0.2s, opacity 0.2s;
  }

  .footer__link-list a:hover,
  .footer__link-list a:focus-visible {
    color: var(--color-accent-light);
    opacity: 1;
  }

  .footer__link-list a:focus-visible {
    outline: 2px solid var(--color-accent-light);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* ── Bottom bar ── */
  .footer__bottom-wrap {
    margin-top: 64px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 24px 0;
  }

  @media (min-width: 768px) {
    .footer__bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .footer__copyright {
    font-size: 0.8rem;
    margin: 0;
    opacity: 0.6;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.footer.name",
  "settings": [
    {
      "type": "textarea",
      "id": "about_text",
      "label": "t:sections.footer.settings.about_text.label"
    },
    {
      "type": "header",
      "content": "Menu columns"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "t:sections.footer.settings.menu_1.label",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "menu_1_heading",
      "label": "t:sections.footer.settings.menu_1_heading.label",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "t:sections.footer.settings.menu_2.label",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "menu_2_heading",
      "label": "t:sections.footer.settings.menu_2_heading.label",
      "default": "Company"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "t:sections.footer.settings.menu_3.label",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "menu_3_heading",
      "label": "t:sections.footer.settings.menu_3_heading.label",
      "default": "Support"
    },
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "t:sections.footer.settings.social_instagram.label"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "t:sections.footer.settings.social_facebook.label"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "t:sections.footer.settings.social_twitter.label"
    },
    {
      "type": "url",
      "id": "social_pinterest",
      "label": "t:sections.footer.settings.social_pinterest.label"
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
