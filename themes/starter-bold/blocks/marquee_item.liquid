{% doc %}
  Renders a single text item with an accent dot separator for use inside
  a scrolling marquee strip section.

  Parameters (via block.settings):
  - text {string} required — The text label to display in the marquee strip
{% enddoc %}

<div class="marquee-item" {{ block.shopify_attributes }}>
  <span class="marquee-dot" aria-hidden="true"></span>
  <span>{{ block.settings.text | escape }}</span>
</div>

{% stylesheet %}
  .marquee-item {
    display: flex;
    align-items: center;
    gap: 48px;
    white-space: nowrap;
  }

  .marquee-dot {
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
    flex-shrink: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:blocks.marquee_item.name",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "t:blocks.marquee_item.settings.text.label",
      "default": "Handcrafted"
    }
  ]
}
{% endschema %}
