{% doc %}
  @prompt
    testimonial
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonial-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-testimonial-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: {{ block.settings.text_alignment }};
  }

  .ai-testimonial-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    justify-content: {{ block.settings.text_alignment }};
  }

  .ai-testimonial-star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    color: {{ block.settings.star_color }};
  }

  .ai-testimonial-quote-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-testimonial-author-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: {{ block.settings.text_alignment }};
  }

  .ai-testimonial-author-image-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    border-radius: 50%;
    object-fit: cover;
  }

  .ai-testimonial-author-image-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    border-radius: 50%;
    background-color: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-testimonial-author-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-testimonial-author-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-testimonial-author-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-testimonial-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.7 }}px;
    }

    .ai-testimonial-content-{{ ai_gen_id }} {
      gap: 16px;
    }
  }
{% endstyle %}

<ai-testimonial-{{ ai_gen_id }}
  class="ai-testimonial-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-testimonial-content-{{ ai_gen_id }}">
    {% if block.settings.show_stars %}
      <div class="ai-testimonial-stars-{{ ai_gen_id }}">
        {% for i in (1..block.settings.rating) %}
          <svg
            class="ai-testimonial-star-{{ ai_gen_id }}"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        {% endfor %}
      </div>
    {% endif %}

    {% if block.settings.quote != blank %}
      <blockquote class="ai-testimonial-quote-{{ ai_gen_id }}">
        {{ block.settings.quote }}
      </blockquote>
    {% endif %}

    <div class="ai-testimonial-author-{{ ai_gen_id }}">
      {% if block.settings.author_image != blank %}
        <img
          src="{{ block.settings.author_image | image_url: width: 200 }}"
          alt="{{ block.settings.author_name | escape }}"
          class="ai-testimonial-author-image-{{ ai_gen_id }}"
          loading="lazy"
          width="200"
          height="200"
        >
      {% else %}
        <div class="ai-testimonial-author-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}

      {% if block.settings.author_name != blank %}
        <p class="ai-testimonial-author-name-{{ ai_gen_id }}">
          {{ block.settings.author_name }}
        </p>
      {% endif %}

      {% if block.settings.author_title != blank %}
        <p class="ai-testimonial-author-title-{{ ai_gen_id }}">
          {{ block.settings.author_title }}
        </p>
      {% endif %}
    </div>
  </div>
</ai-testimonial-{{ ai_gen_id }}>

<script>
  (function() {
    class AiTestimonial{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('ai-testimonial-{{ ai_gen_id }}', AiTestimonial{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Testimonial",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "quote",
      "label": "Quote",
      "default": "<p>This product exceeded my expectations! The quality is outstanding and the customer service was exceptional.</p>"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Author name",
      "default": "Sarah Johnson"
    },
    {
      "type": "text",
      "id": "author_title",
      "label": "Author title",
      "default": "Verified Customer"
    },
    {
      "type": "image_picker",
      "id": "author_image",
      "label": "Author image"
    },
    {
      "type": "header",
      "content": "Rating"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show star rating",
      "default": true
    },
    {
      "type": "range",
      "id": "rating",
      "label": "Rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "star_size",
      "label": "Star size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#C8956C"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "quote_size",
      "label": "Quote size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "name_size",
      "label": "Name size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "image_size",
      "label": "Image size",
      "min": 40,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#F5F0EB"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1A1A18"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle",
      "default": "#6B6B63"
    }
  ],
  "presets": [
    {
      "name": "Testimonial"
    }
  ]
}
{% endschema %}
