{% doc %}
  Renders an Instagram-style square image tile with a green hover overlay
  and an Instagram icon. Intended for use in a social feed grid section.

  Parameters (via block.settings):
  - image {image} optional — The square image to display; shows placeholder when blank
  - url {url} optional — Link URL for the tile (e.g., a post or Instagram profile)
{% enddoc %}

{%- liquid
  assign wrapper_tag = 'div'
  if block.settings.url != blank
    assign wrapper_tag = 'a'
  endif
-%}

<{{ wrapper_tag }}
  class="social-item"
  {% if block.settings.url != blank %}href="{{ block.settings.url }}"{% endif %}
  {{ block.shopify_attributes }}
>
  {% if block.settings.image != blank %}
    <img
      src="{{ block.settings.image | image_url: width: 600 }}"
      alt="{{ block.settings.image.alt | escape }}"
      width="{{ block.settings.image.width }}"
      height="{{ block.settings.image.height }}"
      loading="lazy"
    >
  {% else %}
    {{ 'image' | placeholder_svg_tag: 'social-item__placeholder' }}
  {% endif %}

  <div class="social-item__overlay" aria-hidden="true">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
    </svg>
  </div>
</{{ wrapper_tag }}>

{% stylesheet %}
  .social-item {
    aspect-ratio: 1;
    overflow: hidden;
    position: relative;
    cursor: pointer;
    display: block;
    text-decoration: none;
  }

  .social-item img,
  .social-item .social-item__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }

  .social-item:hover img,
  .social-item:hover .social-item__placeholder {
    transform: scale(1.08);
  }

  .social-item__overlay {
    position: absolute;
    inset: 0;
    background: rgba(45, 90, 61, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .social-item:hover .social-item__overlay {
    opacity: 1;
  }

  .social-item__overlay svg {
    width: 28px;
    height: 28px;
    fill: #fff;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:blocks.social_feed_item.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:blocks.social_feed_item.settings.image.label"
    },
    {
      "type": "url",
      "id": "url",
      "label": "t:blocks.social_feed_item.settings.url.label"
    }
  ]
}
{% endschema %}
