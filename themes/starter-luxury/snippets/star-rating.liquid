{% doc %}
  Renders a star rating display using SVG star icons.

  @param {number} rating - Numeric rating value between 0 and 5
  @param {boolean} [show_count] - If true, displays the review count alongside stars
  @param {number} [count] - Number of reviews to display when show_count is true

  @example
  {% render 'star-rating', rating: 4.5, show_count: true, count: 28 %}
{% enddoc %}

<style>
  .star-rating {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .star-rating__stars {
    display: inline-flex;
    align-items: center;
    gap: 0.125rem;
    color: var(--color-primary);
  }

  .star-rating__count {
    font-size: 0.8125rem;
    font-weight: 300;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  .star-rating__value {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

{%- liquid
  assign star_rating = rating | default: 0 | plus: 0.0
  assign full_stars = star_rating | floor
  assign remainder = star_rating | minus: full_stars
  assign has_half = false
  if remainder >= 0.25
    if remainder < 0.75
      assign has_half = true
    endif
  endif
  assign empty_stars = 5 | minus: full_stars
  if has_half
    assign empty_stars = empty_stars | minus: 1
  endif
-%}

<div class="star-rating" role="img" aria-label="{{ rating }} out of 5 stars">
  <span class="star-rating__value">{{ rating }} / 5</span>
  <span class="star-rating__stars" aria-hidden="true">

    {%- for i in (1..full_stars) -%}
      {% render 'icon', name: 'star', size: 14 %}
    {%- endfor -%}

    {%- if has_half -%}
      {% render 'icon', name: 'star-half', size: 14 %}
    {%- endif -%}

    {%- if empty_stars > 0 -%}
      {%- for i in (1..empty_stars) -%}
        {% render 'icon', name: 'star-empty', size: 14 %}
      {%- endfor -%}
    {%- endif -%}

  </span>

  {%- if show_count -%}
    {%- if count != blank -%}
      <span class="star-rating__count">({{ count }})</span>
    {%- endif -%}
  {%- endif -%}
</div>
