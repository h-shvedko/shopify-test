<section class="testimonials section-padding">
  <div class="container">
    {% if section.settings.heading != blank %}
      <h2 class="testimonials__section-heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="testimonials__list">
        {% for block in section.blocks %}
          {% if block.type == 'testimonial' %}
            <blockquote class="testimonials__item" {{ block.shopify_attributes }}>
              <div class="testimonials__quote-mark" aria-hidden="true">&ldquo;</div>

              {% if block.settings.rating > 0 %}
                <div
                  class="testimonials__stars"
                  role="img"
                  aria-label="{{ 'testimonials.rating_label' | t: rating: block.settings.rating }}"
                >
                  {% for i in (1..5) %}
                    <span class="testimonials__star{% if i <= block.settings.rating %} testimonials__star--filled{% endif %}" aria-hidden="true">&#9733;</span>
                  {% endfor %}
                </div>
              {% endif %}

              {% if block.settings.quote != blank %}
                <p class="testimonials__quote">{{ block.settings.quote | escape }}</p>
              {% endif %}

              {% if block.settings.author != blank %}
                <footer class="testimonials__author-wrap">
                  <cite class="testimonials__author">{{ block.settings.author | escape }}</cite>
                </footer>
              {% endif %}
            </blockquote>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .testimonials__section-heading {
    font-family: var(--font-heading-family);
    font-style: italic;
    font-size: 1.5rem;
    color: var(--color-text-secondary);
    text-align: center;
    margin: 0 0 56px;
    letter-spacing: 0.03em;
  }

  .testimonials__list {
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .testimonials__item {
    margin: 0;
    text-align: center;
    padding: 0 20px;
  }

  .testimonials__quote-mark {
    font-family: var(--font-heading-family);
    font-size: 6rem;
    line-height: 1;
    color: var(--color-primary);
    opacity: 0.35;
    margin-bottom: -16px;
    display: block;
  }

  .testimonials__stars {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-bottom: 20px;
  }

  .testimonials__star {
    font-size: 1rem;
    color: var(--color-border);
  }

  .testimonials__star--filled {
    color: var(--color-primary);
  }

  .testimonials__quote {
    font-family: var(--font-heading-family);
    font-style: italic;
    font-size: 1.5rem;
    line-height: 1.55;
    color: var(--color-text);
    max-width: 760px;
    margin: 0 auto 24px;
    letter-spacing: 0.01em;
  }

  .testimonials__author-wrap {
    margin-top: 8px;
  }

  .testimonials__author {
    display: inline-block;
    font-style: normal;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  @media (min-width: 768px) {
    .testimonials__list {
      gap: 72px;
    }

    .testimonials__quote {
      font-size: 1.875rem;
    }
  }

  @media (min-width: 1024px) {
    .testimonials__quote {
      font-size: 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.testimonials.settings.heading.label",
      "default": "What our clients say"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "t:sections.testimonials.blocks.testimonial.name",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "t:sections.testimonials.blocks.testimonial.settings.quote.label",
          "default": "An exceptional piece — the craftsmanship speaks for itself. I wear it every day and receive compliments without fail."
        },
        {
          "type": "text",
          "id": "author",
          "label": "t:sections.testimonials.blocks.testimonial.settings.author.label",
          "default": "Isabelle M."
        },
        {
          "type": "range",
          "id": "rating",
          "label": "t:sections.testimonials.blocks.testimonial.settings.rating.label",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "The ring arrived beautifully packaged. The vintage style is exactly what I was looking for — timeless.",
            "author": "Clara R.",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}
