<section class="not-found section">
  <div class="container">
    <div class="not-found__inner">
      <p class="not-found__code">404</p>
      <h1 class="not-found__heading">
        {%- if section.settings.heading != blank -%}
          {{ section.settings.heading }}
        {%- else -%}
          {{ 'not_found.heading' | t }}
        {%- endif -%}
      </h1>
      <p class="not-found__subheading">
        {%- if section.settings.subheading != blank -%}
          {{ section.settings.subheading }}
        {%- else -%}
          {{ 'not_found.subheading' | t }}
        {%- endif -%}
      </p>
      <a href="{{ routes.root_url }}" class="btn btn--primary">
        {{ 'not_found.button_text' | t }}
      </a>
    </div>
  </div>
</section>

{% stylesheet %}
  .not-found__inner {
    text-align: center;
    padding: var(--space-20) 0;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }

  .not-found__code {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 300;
    color: var(--color-border);
    line-height: 1;
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
  }

  .not-found__heading {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .not-found__subheading {
    font-size: 1rem;
    font-weight: 300;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-10);
  }

  @media (min-width: 768px) {
    .not-found__inner {
      padding: var(--space-24) 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.not_found.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.not_found.settings.heading.label",
      "default": "Page not found"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.not_found.settings.subheading.label",
      "default": "The page you are looking for may have moved or no longer exists."
    }
  ],
  "presets": [
    {
      "name": "t:sections.not_found.presets.default"
    }
  ]
}
{% endschema %}
