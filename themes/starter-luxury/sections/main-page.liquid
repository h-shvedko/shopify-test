<section class="main-page section">
  <div class="container">
    <div class="main-page__inner">
      {%- if section.settings.show_title -%}
        <h1 class="main-page__title">{{ page.title }}</h1>
        <hr class="main-page__divider">
      {%- endif -%}
      <div class="main-page__content rte">
        {{ page.content }}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .main-page__inner {
    max-width: 760px;
    margin-left: auto;
    margin-right: auto;
  }

  .main-page__title {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 300;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .main-page__divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-bottom: var(--space-10);
  }

  .main-page__content {
    font-family: var(--font-body);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text);
  }

  .main-page__content p {
    margin-bottom: var(--space-6);
  }

  .main-page__content h2,
  .main-page__content h3,
  .main-page__content h4 {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 300;
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  .main-page__content ul,
  .main-page__content ol {
    padding-left: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .main-page__content ul {
    list-style: disc;
  }

  .main-page__content ol {
    list-style: decimal;
  }

  .main-page__content li {
    margin-bottom: var(--space-2);
    line-height: 1.8;
  }

  .main-page__content a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .main-page__content a:hover {
    opacity: 0.75;
  }

  .main-page__content blockquote {
    border-left: 2px solid var(--color-primary);
    margin: var(--space-8) 0;
    padding: var(--space-4) var(--space-6);
    color: var(--color-text-secondary);
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.25rem;
  }

  .main-page__content blockquote p {
    margin-bottom: 0;
  }

  .main-page__content img {
    max-width: 100%;
    height: auto;
    margin: var(--space-8) 0;
  }

  .main-page__content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--space-8);
    font-size: 0.9375rem;
  }

  .main-page__content th,
  .main-page__content td {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .main-page__content th {
    background-color: var(--color-surface);
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  @media (min-width: 768px) {
    .main-page__title {
      font-size: clamp(2rem, 4vw, 3.25rem);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.main_page.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "t:sections.main_page.settings.show_title.label",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:sections.main_page.presets.default"
    }
  ]
}
{% endschema %}
