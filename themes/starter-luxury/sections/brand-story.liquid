{%- liquid
  assign layout = section.settings.layout | default: 'image_left'
  assign has_secondary = false
  if section.settings.secondary_image != blank
    assign has_secondary = true
  endif
-%}

<section
  class="patina-brand-story section"
  data-section-id="{{ section.id }}"
  data-layout="{{ layout }}"
>
  <div class="container">
    <div class="patina-brand-story__inner patina-brand-story__inner--{{ layout }}">

      {%- comment -%} Image column {%- endcomment -%}
      <div class="patina-brand-story__images">
        {%- comment -%} Primary image — offset/larger {%- endcomment -%}
        <div class="patina-brand-story__img-primary-wrap">
          {%- if section.settings.image != blank -%}
            {{
              section.settings.image
              | image_url: width: 900
              | image_tag:
                class: 'patina-brand-story__img',
                loading: 'lazy',
                alt: section.settings.image.alt | escape
            }}
          {%- else -%}
            <div class="patina-brand-story__img-placeholder" aria-hidden="true">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" style="opacity:0.2;">
                <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
              </svg>
            </div>
          {%- endif -%}
        </div>

        {%- if has_secondary -%}
          <div class="patina-brand-story__img-secondary-wrap">
            {{
              section.settings.secondary_image
              | image_url: width: 600
              | image_tag:
                class: 'patina-brand-story__img',
                loading: 'lazy',
                alt: section.settings.secondary_image.alt | escape
            }}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Text column {%- endcomment -%}
      <div class="patina-brand-story__text">
        {%- if section.settings.eyebrow != blank -%}
          <p class="patina-brand-story__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="patina-brand-story__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.content != blank -%}
          <div class="patina-brand-story__body rte">{{ section.settings.content }}</div>
        {%- endif -%}

        {%- if section.settings.button_text != blank -%}
          {%- assign cta_url = section.settings.button_url | default: '/pages/about' -%}
          <div class="patina-brand-story__actions">
            <a href="{{ cta_url }}" class="btn btn--secondary patina-brand-story__btn">
              {{ section.settings.button_text | escape }}
            </a>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% stylesheet %}
  /* ---- Brand story ---- */

  .patina-brand-story__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
    align-items: center;
  }

  @media (min-width: 768px) {
    .patina-brand-story__inner {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: start;
    }

    /* Layout flip: image right → text first in DOM order, image second */
    .patina-brand-story__inner--image_right .patina-brand-story__images {
      order: 2;
    }

    .patina-brand-story__inner--image_right .patina-brand-story__text {
      order: 1;
    }
  }

  @media (min-width: 1024px) {
    .patina-brand-story__inner {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 96px;
    }

    .patina-brand-story__inner--image_right {
      grid-template-columns: 0.9fr 1.1fr;
    }
  }

  /* Image column — asymmetric offset */

  .patina-brand-story__images {
    position: relative;
  }

  .patina-brand-story__img-primary-wrap {
    position: relative;
    z-index: 2;
    overflow: hidden;
  }

  .patina-brand-story__img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .patina-brand-story__img-primary-wrap .patina-brand-story__img {
    aspect-ratio: 4 / 5;
  }

  .patina-brand-story__img-placeholder {
    aspect-ratio: 4 / 5;
    background-color: var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
  }

  /* Secondary image — overlaps primary from bottom-right corner */

  .patina-brand-story__img-secondary-wrap {
    position: absolute;
    bottom: -32px;
    right: -24px;
    width: 52%;
    z-index: 3;
    overflow: hidden;
    border: 6px solid var(--color-background);
  }

  .patina-brand-story__img-secondary-wrap .patina-brand-story__img {
    aspect-ratio: 1 / 1;
  }

  /* Offset: on image_right layout, secondary flips to left */
  .patina-brand-story__inner--image_right .patina-brand-story__img-secondary-wrap {
    right: auto;
    left: -24px;
  }

  /* Text column */

  .patina-brand-story__text {
    padding-top: 32px;
    padding-bottom: 32px;
  }

  @media (min-width: 768px) {
    .patina-brand-story__text {
      padding-top: 48px;
      padding-bottom: 0;
    }
  }

  .patina-brand-story__eyebrow {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 20px;
  }

  .patina-brand-story__heading {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    line-height: 1.15;
    color: var(--color-text);
    margin: 0 0 28px;
    letter-spacing: 0.01em;
  }

  .patina-brand-story__body {
    font-size: 0.9375rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin-bottom: 0;
  }

  /* RTE rich text inside body */
  .patina-brand-story__body p {
    margin-bottom: 16px;
    color: var(--color-text-secondary);
    font-weight: 300;
    line-height: 1.75;
  }

  .patina-brand-story__body p:last-child {
    margin-bottom: 0;
  }

  .patina-brand-story__actions {
    margin-top: 36px;
  }

  .patina-brand-story__btn {
    letter-spacing: 0.1em;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.brand_story.name",
  "tag": "div",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.brand_story.settings.image.label"
    },
    {
      "type": "image_picker",
      "id": "secondary_image",
      "label": "t:sections.brand_story.settings.secondary_image.label",
      "info": "t:sections.brand_story.settings.secondary_image.info"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.brand_story.settings.eyebrow.label",
      "default": "Our story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.brand_story.settings.heading.label",
      "default": "Crafted with intention, kept with love"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "t:sections.brand_story.settings.content.label",
      "default": "<p>Each piece begins as a sketch—drawn by hand, refined over weeks, and realized by artisans who have spent their lives perfecting the ancient craft of fine jewelry.</p><p>We believe in adornments that accumulate meaning. Objects that move with you through decades, not seasons.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:sections.brand_story.settings.button_text.label",
      "default": "Read our story"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.brand_story.settings.button_url.label"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.brand_story.settings.layout.label",
      "default": "image_left",
      "options": [
        { "value": "image_left", "label": "t:sections.brand_story.settings.layout.options.image_left" },
        { "value": "image_right", "label": "t:sections.brand_story.settings.layout.options.image_right" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.brand_story.name"
    }
  ]
}
{% endschema %}
