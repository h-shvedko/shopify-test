{%- liquid
  assign is_home = false
  if request.page_type == 'index'
    assign is_home = true
  endif
  assign transparent_enabled = false
  if section.settings.transparent_on_home
    if is_home
      assign transparent_enabled = true
    endif
  endif
-%}

{%- if section.settings.enable_announcement -%}
  {%- if section.settings.announcement_text != blank -%}
    <div class="header-announcement" role="region" aria-label="{{ 'sections.header.announcement_label' | t }}">
      <div class="container header-announcement__inner">
        <p class="header-announcement__text">{{ section.settings.announcement_text }}</p>
      </div>
    </div>
  {%- endif -%}
{%- endif -%}

<header
  class="patina-header{% if transparent_enabled %} patina-header--transparent{% endif %}{% if section.settings.sticky_header %} patina-header--sticky{% endif %}"
  data-section-id="{{ section.id }}"
  data-sticky="{{ section.settings.sticky_header }}"
  data-transparent="{{ transparent_enabled }}"
>
  <div class="container patina-header__inner">

    {%- comment -%} Search icon — left side {%- endcomment -%}
    <div class="patina-header__left">
      <a
        href="{{ routes.search_url }}"
        class="patina-header__icon"
        aria-label="{{ 'general.search' | t }}"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
        </svg>
      </a>
    </div>

    {%- comment -%} Centered logo {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="patina-header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {{
          section.settings.logo
          | image_url: width: section.settings.logo_width
          | image_tag:
            alt: shop.name,
            width: section.settings.logo_width,
            loading: 'eager',
            fetchpriority: 'high'
        }}
      {%- else -%}
        <span class="patina-header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} Right: cart + hamburger {%- endcomment -%}
    <div class="patina-header__right">
      <a
        href="{{ routes.cart_url }}"
        class="patina-header__icon patina-header__cart"
        aria-label="{{ 'general.cart' | t }}"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span
          class="patina-header__cart-count{% if cart.item_count == 0 %} patina-header__cart-count--empty{% endif %}"
          data-cart-count
          aria-label="{{ 'sections.header.cart_count' | t: count: cart.item_count }}"
        >
          {{ cart.item_count }}
        </span>
      </a>

      <button
        class="patina-header__hamburger"
        aria-label="{{ 'accessibility.open_menu' | t }}"
        aria-expanded="false"
        aria-controls="patina-mobile-menu-{{ section.id }}"
        data-menu-toggle
      >
        <span class="patina-header__hamburger-line" aria-hidden="true"></span>
        <span class="patina-header__hamburger-line" aria-hidden="true"></span>
        <span class="patina-header__hamburger-line" aria-hidden="true"></span>
      </button>
    </div>

  </div>

  {%- comment -%} Desktop horizontal nav below logo {%- endcomment -%}
  <nav class="patina-header__nav" aria-label="{{ 'sections.header.nav_aria_label' | t }}">
    <div class="patina-header__nav-inner">
      {%- for link in section.settings.menu.links -%}
        <a
          href="{{ link.url }}"
          class="patina-header__nav-link{% if link.active %} patina-header__nav-link--active{% endif %}"
          {% if link.current %}aria-current="page"{% endif %}
        >
          {{ link.title }}
        </a>
      {%- endfor -%}
    </div>
  </nav>

  {%- comment -%} Mobile full-screen overlay menu {%- endcomment -%}
  <dialog
    class="patina-mobile-menu"
    id="patina-mobile-menu-{{ section.id }}"
    aria-label="{{ 'sections.header.mobile_menu_aria_label' | t }}"
    data-mobile-menu
  >
    <div class="patina-mobile-menu__inner">
      <div class="patina-mobile-menu__header">
        <a href="{{ routes.root_url }}" class="patina-mobile-menu__logo" aria-label="{{ shop.name }}">
          {%- if section.settings.logo != blank -%}
            {{
              section.settings.logo
              | image_url: width: 140
              | image_tag: alt: shop.name, width: 140, loading: 'lazy'
            }}
          {%- else -%}
            <span class="patina-mobile-menu__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
        <button
          class="patina-mobile-menu__close"
          aria-label="{{ 'accessibility.close_menu' | t }}"
          data-menu-close
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true" focusable="false">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <nav class="patina-mobile-menu__nav" aria-label="{{ 'sections.header.mobile_nav_aria_label' | t }}">
        {%- for link in section.settings.menu.links -%}
          <a
            href="{{ link.url }}"
            class="patina-mobile-menu__link{% if link.active %} patina-mobile-menu__link--active{% endif %}"
            {% if link.current %}aria-current="page"{% endif %}
          >
            {{ link.title }}
          </a>
        {%- endfor -%}
      </nav>

      <div class="patina-mobile-menu__footer">
        <a href="{{ routes.cart_url }}" class="patina-mobile-menu__cart-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
          </svg>
          {{ 'general.cart' | t }}
          {%- if cart.item_count > 0 -%}
            <span class="patina-mobile-menu__cart-count">({{ cart.item_count }})</span>
          {%- endif -%}
        </a>
        <a href="{{ routes.search_url }}" class="patina-mobile-menu__search-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true" focusable="false">
            <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
          </svg>
          {{ 'general.search' | t }}
        </a>
      </div>
    </div>
  </dialog>

</header>

{% stylesheet %}
  /* ---- Announcement bar ---- */

  .header-announcement {
    background-color: var(--color-text);
    color: var(--color-background);
    padding: 10px 0;
    text-align: center;
  }

  .header-announcement__inner {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .header-announcement__text {
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
    color: var(--color-background);
  }

  /* ---- Header shell ---- */

  .patina-header {
    position: relative;
    z-index: 200;
    background-color: var(--color-background);
    border-bottom: 1px solid var(--color-border);
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .patina-header--sticky {
    position: sticky;
    top: 0;
  }

  .patina-header--transparent {
    background-color: transparent;
    border-bottom-color: transparent;
    position: absolute;
    width: 100%;
    top: 0;
  }

  .patina-header--transparent.patina-header--scrolled {
    background-color: var(--color-background);
    border-bottom-color: var(--color-border);
    position: sticky;
  }

  /* ---- Top row (search / logo / cart+hamburger) ---- */

  .patina-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding-top: 20px;
    padding-bottom: 20px;
    min-height: 72px;
  }

  .patina-header__left {
    display: flex;
    align-items: center;
    gap: 16px;
    justify-content: flex-start;
  }

  .patina-header__right {
    display: flex;
    align-items: center;
    gap: 16px;
    justify-content: flex-end;
  }

  .patina-header__logo {
    display: flex;
    justify-content: center;
    align-items: center;
    text-decoration: none;
    color: var(--color-text);
    transition: opacity var(--transition-base);
  }

  .patina-header__logo:hover {
    opacity: 0.75;
    text-decoration: none;
  }

  .patina-header__logo img {
    height: auto;
    display: block;
    max-width: 100%;
  }

  .patina-header__logo-text {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 300;
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    color: var(--color-text);
    white-space: nowrap;
  }

  .patina-header--transparent .patina-header__logo-text,
  .patina-header--transparent .patina-header__icon,
  .patina-header--transparent .patina-header__hamburger {
    color: #FAF7F2;
  }

  .patina-header--transparent.patina-header--scrolled .patina-header__logo-text,
  .patina-header--transparent.patina-header--scrolled .patina-header__icon,
  .patina-header--transparent.patina-header--scrolled .patina-header__hamburger {
    color: var(--color-text);
  }

  .patina-header__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    color: var(--color-text);
    text-decoration: none;
    padding: 4px;
    transition: color var(--transition-base), opacity var(--transition-base);
  }

  .patina-header__icon:hover {
    color: var(--color-primary);
    opacity: 1;
    text-decoration: none;
  }

  .patina-header__icon:focus-visible {
    outline: 1px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Cart badge */

  .patina-header__cart-count {
    position: absolute;
    top: -4px;
    right: -6px;
    background-color: var(--color-primary);
    color: #FAF7F2;
    font-size: 0.5625rem;
    font-weight: 700;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    pointer-events: none;
    font-style: normal;
  }

  .patina-header__cart-count--empty {
    display: none;
  }

  /* Hamburger button */

  .patina-header__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-end;
    gap: 5px;
    width: 28px;
    height: 28px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    color: var(--color-text);
    transition: color var(--transition-base);
  }

  .patina-header__hamburger:hover {
    color: var(--color-primary);
  }

  .patina-header__hamburger-line {
    display: block;
    height: 1px;
    background-color: currentColor;
    transition: width var(--transition-base);
  }

  .patina-header__hamburger-line:nth-child(1) { width: 22px; }
  .patina-header__hamburger-line:nth-child(2) { width: 16px; }
  .patina-header__hamburger-line:nth-child(3) { width: 22px; }

  .patina-header__hamburger:hover .patina-header__hamburger-line {
    width: 22px;
  }

  /* ---- Desktop horizontal nav ---- */

  .patina-header__nav {
    display: none;
    border-top: 1px solid var(--color-border);
  }

  .patina-header--transparent .patina-header__nav {
    border-top-color: rgba(232, 224, 212, 0.25);
  }

  .patina-header--transparent.patina-header--scrolled .patina-header__nav {
    border-top-color: var(--color-border);
  }

  .patina-header__nav-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 40px;
    padding: 12px 0;
  }

  .patina-header__nav-link {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    position: relative;
    padding-bottom: 2px;
    transition: color var(--transition-base);
  }

  .patina-header__nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-primary);
    transition: width var(--transition-base);
  }

  .patina-header__nav-link:hover {
    color: var(--color-primary);
    text-decoration: none;
    opacity: 1;
  }

  .patina-header__nav-link:hover::after,
  .patina-header__nav-link--active::after,
  .patina-header__nav-link[aria-current="page"]::after {
    width: 100%;
  }

  .patina-header__nav-link--active,
  .patina-header__nav-link[aria-current="page"] {
    color: var(--color-primary);
  }

  .patina-header--transparent .patina-header__nav-link {
    color: rgba(250, 247, 242, 0.85);
  }

  .patina-header--transparent.patina-header--scrolled .patina-header__nav-link {
    color: var(--color-text);
  }

  /* ---- Mobile menu dialog ---- */

  .patina-mobile-menu {
    border: none;
    padding: 0;
    margin: 0;
    width: 100%;
    max-width: 100%;
    max-height: 100%;
    height: 100%;
    position: fixed;
    inset: 0;
    background-color: var(--color-background);
    overflow-y: auto;
    overscroll-behavior: contain;
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .patina-mobile-menu[open] {
    display: flex;
    opacity: 1;
    transform: translateY(0);
  }

  .patina-mobile-menu::backdrop {
    background-color: rgba(44, 24, 16, 0.5);
  }

  .patina-mobile-menu__inner {
    display: flex;
    flex-direction: column;
    width: 100%;
    min-height: 100%;
    padding: 0;
  }

  .patina-mobile-menu__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid var(--color-border);
  }

  .patina-mobile-menu__logo {
    text-decoration: none;
    color: var(--color-text);
  }

  .patina-mobile-menu__logo:hover {
    opacity: 0.75;
    text-decoration: none;
  }

  .patina-mobile-menu__logo-text {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 300;
    font-size: 1.375rem;
    color: var(--color-text);
  }

  .patina-mobile-menu__close {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: 4px;
    transition: color var(--transition-base);
  }

  .patina-mobile-menu__close:hover {
    color: var(--color-primary);
  }

  .patina-mobile-menu__nav {
    flex: 1;
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .patina-mobile-menu__link {
    display: block;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(1.75rem, 6vw, 2.5rem);
    font-weight: 300;
    color: var(--color-text);
    text-decoration: none;
    padding: 16px 0;
    border-bottom: 1px solid var(--color-border);
    letter-spacing: 0.01em;
    transition: color var(--transition-base), padding-left var(--transition-base);
  }

  .patina-mobile-menu__link:first-child {
    border-top: 1px solid var(--color-border);
  }

  .patina-mobile-menu__link:hover {
    color: var(--color-primary);
    text-decoration: none;
    padding-left: 12px;
    opacity: 1;
  }

  .patina-mobile-menu__link--active,
  .patina-mobile-menu__link[aria-current="page"] {
    color: var(--color-primary);
  }

  .patina-mobile-menu__footer {
    padding: 24px;
    border-top: 1px solid var(--color-border);
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .patina-mobile-menu__cart-link,
  .patina-mobile-menu__search-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .patina-mobile-menu__cart-link:hover,
  .patina-mobile-menu__search-link:hover {
    color: var(--color-primary);
    text-decoration: none;
    opacity: 1;
  }

  .patina-mobile-menu__cart-count {
    color: var(--color-primary);
  }

  /* ---- Breakpoint: show desktop nav, hide hamburger ---- */

  @media (min-width: 1024px) {
    .patina-header__nav {
      display: block;
    }

    .patina-header__hamburger {
      display: none;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    'use strict';

    var headerEl = document.querySelector('.patina-header[data-section-id="{{ section.id }}"]');
    if (!headerEl) return;

    var toggle = headerEl.querySelector('[data-menu-toggle]');
    var dialog = headerEl.querySelector('[data-mobile-menu]');
    var closeBtn = headerEl.querySelector('[data-menu-close]');
    var isTransparent = headerEl.dataset.transparent === 'true';
    var isSticky = headerEl.dataset.sticky === 'true';

    /* --- Transparent-on-scroll behaviour --- */
    if (isTransparent) {
      function onScroll() {
        if (window.scrollY > 40) {
          headerEl.classList.add('patina-header--scrolled');
          if (isSticky) {
            headerEl.style.position = 'sticky';
          }
        } else {
          headerEl.classList.remove('patina-header--scrolled');
          if (isSticky) {
            headerEl.style.position = 'absolute';
          }
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    /* --- Mobile menu --- */
    if (!toggle || !dialog) return;

    function openMenu() {
      dialog.showModal();
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      dialog.close();
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', openMenu);

    if (closeBtn) {
      closeBtn.addEventListener('click', closeMenu);
    }

    dialog.addEventListener('click', function (e) {
      if (e.target === dialog) {
        closeMenu();
      }
    });

    dialog.addEventListener('close', function () {
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });

    /* --- Cart badge sync after AJAX cart updates --- */
    document.addEventListener('cart:updated', function (e) {
      var badge = document.querySelector('[data-cart-count]');
      if (!badge) return;
      var count = e.detail.item_count;
      badge.textContent = count;
      if (count > 0) {
        badge.classList.remove('patina-header__cart-count--empty');
      } else {
        badge.classList.add('patina-header__cart-count--empty');
      }
    });
  })();
</script>

{% schema %}
{
  "name": "t:sections.header.name",
  "tag": "div",
  "class": "header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:sections.header.settings.logo.label"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "t:sections.header.settings.logo_width.label",
      "default": 120,
      "min": 60,
      "max": 240,
      "step": 10,
      "unit": "px"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:sections.header.settings.menu.label",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.announcement_header.content"
    },
    {
      "type": "checkbox",
      "id": "enable_announcement",
      "label": "t:sections.header.settings.enable_announcement.label",
      "default": false
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "t:sections.header.settings.announcement_text.label",
      "default": "Complimentary shipping on orders over $150"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.behaviour_header.content"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "t:sections.header.settings.sticky_header.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "transparent_on_home",
      "label": "t:sections.header.settings.transparent_on_home.label",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:sections.header.name"
    }
  ]
}
{% endschema %}
