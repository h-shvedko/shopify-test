<section class="newsletter-cta">
  <div class="container newsletter-cta__inner">
    <div class="newsletter-cta__text">
      {% if section.settings.heading != blank %}
        <h2 class="newsletter-cta__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="newsletter-cta__subheading">{{ section.settings.subheading | escape }}</p>
      {% endif %}
    </div>

    <div class="newsletter-cta__form-wrap">
      {% form 'customer', id: 'newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter-cta__form-row">
          <label for="newsletter-email" class="visually-hidden">{{ 'newsletter_cta.email_label' | t }}</label>
          <input
            type="email"
            id="newsletter-email"
            name="contact[email]"
            class="newsletter-cta__input"
            placeholder="{{ 'newsletter_cta.email_placeholder' | t }}"
            required
            autocomplete="email"
          >
          <button type="submit" class="newsletter-cta__btn">
            {{ 'newsletter_cta.subscribe' | t }}
          </button>
        </div>

        {% if form.posted_successfully? %}
          <p class="newsletter-cta__success" role="status">{{ 'newsletter_cta.success' | t }}</p>
        {% endif %}

        {% if form.errors %}
          <p class="newsletter-cta__error" role="alert">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

{% stylesheet %}
  .newsletter-cta {
    background: var(--color-primary);
    padding: 64px 20px;
  }

  .newsletter-cta__inner {
    display: flex;
    flex-direction: column;
    gap: 32px;
    align-items: flex-start;
  }

  .newsletter-cta__heading {
    font-family: var(--font-heading-family);
    font-style: italic;
    font-size: 1.875rem;
    color: #FAF7F2;
    margin: 0 0 8px;
    letter-spacing: 0.02em;
    line-height: 1.2;
  }

  .newsletter-cta__subheading {
    font-size: 0.9375rem;
    color: rgba(250, 247, 242, 0.8);
    margin: 0;
    line-height: 1.6;
  }

  .newsletter-cta__form-wrap {
    width: 100%;
    max-width: 480px;
  }

  .newsletter-cta__form-row {
    display: flex;
    gap: 0;
  }

  .newsletter-cta__input {
    flex: 1;
    padding: 14px 16px;
    border: 1px solid rgba(250, 247, 242, 0.4);
    border-right: none;
    border-radius: 0;
    background: rgba(250, 247, 242, 0.12) !important;
    color: #FAF7F2;
    font-family: var(--font-body-family);
    font-size: 0.9375rem;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .newsletter-cta__input::placeholder {
    color: rgba(250, 247, 242, 0.55);
  }

  .newsletter-cta__input:focus {
    border-color: #FAF7F2;
  }

  .newsletter-cta__btn {
    padding: 14px 24px;
    background: #FAF7F2;
    color: var(--color-primary);
    border: 1px solid #FAF7F2;
    border-radius: 0;
    font-family: var(--font-body-family);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease;
    flex-shrink: 0;
  }

  .newsletter-cta__btn:hover {
    background: transparent;
    color: #FAF7F2;
  }

  .newsletter-cta__btn:focus-visible {
    outline: 1px solid #FAF7F2;
    outline-offset: 3px;
  }

  .newsletter-cta__success {
    margin-top: 12px;
    font-size: 0.875rem;
    color: rgba(250, 247, 242, 0.9);
  }

  .newsletter-cta__error {
    margin-top: 12px;
    font-size: 0.875rem;
    color: rgba(250, 247, 242, 0.9);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (min-width: 768px) {
    .newsletter-cta__inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }

    .newsletter-cta__text {
      flex: 1;
      max-width: 400px;
    }

    .newsletter-cta__heading {
      font-size: 2.25rem;
      margin-bottom: 10px;
    }

    .newsletter-cta__form-wrap {
      flex-shrink: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.newsletter_cta.name",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.newsletter_cta.settings.heading.label",
      "default": "Join the Patina circle"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.newsletter_cta.settings.subheading.label",
      "default": "Be the first to know about new collections and private events."
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
