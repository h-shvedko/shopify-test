<section class="collections-list section-padding">
  <div class="container">
    {% if section.settings.heading != blank %}
      <h1 class="collections-list__heading">{{ section.settings.heading | escape }}</h1>
    {% endif %}

    <div class="collections-list__grid">
      {% for collection in collections %}
        {% unless collection.handle == 'all' %}
          <a href="{{ collection.url }}" class="collections-list__item">
            <div class="collections-list__item-media">
              {% if collection.image %}
                {{ collection.image
                  | image_url: width: 600
                  | image_tag:
                    loading: 'lazy',
                    alt: collection.title,
                    class: 'collections-list__item-image',
                    width: 600,
                    height: 600
                }}
              {% else %}
                <div class="collections-list__item-placeholder" aria-hidden="true"></div>
              {% endif %}
            </div>
            <div class="collections-list__item-overlay" aria-hidden="true"></div>
            <div class="collections-list__item-info">
              <h3 class="collections-list__item-title">{{ collection.title }}</h3>
              <span class="collections-list__item-cta">{{ 'collections_list.explore' | t }}</span>
            </div>
          </a>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .collections-list__heading {
    font-family: var(--font-heading-family);
    font-style: italic;
    font-size: 2rem;
    color: var(--color-text);
    margin: 0 0 40px;
    letter-spacing: 0.02em;
  }

  .collections-list__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .collections-list__item {
    position: relative;
    display: block;
    text-decoration: none;
    overflow: hidden;
  }

  .collections-list__item-media {
    position: relative;
    overflow: hidden;
  }

  .collections-list__item-image {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .collections-list__item-placeholder {
    width: 100%;
    aspect-ratio: 3 / 4;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .collections-list__item:hover .collections-list__item-image {
    transform: scale(1.04);
  }

  .collections-list__item-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(44, 24, 16, 0.6) 0%,
      rgba(44, 24, 16, 0.15) 50%,
      transparent 100%
    );
    transition: opacity 0.3s ease;
  }

  .collections-list__item:hover .collections-list__item-overlay {
    opacity: 0.9;
  }

  .collections-list__item-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px 16px;
    z-index: 1;
  }

  .collections-list__item-title {
    font-family: var(--font-heading-family);
    font-style: italic;
    font-size: 1.25rem;
    color: #FAF7F2;
    margin: 0 0 4px;
    letter-spacing: 0.02em;
    line-height: 1.2;
  }

  .collections-list__item-cta {
    display: block;
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(250, 247, 242, 0.75);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .collections-list__item:hover .collections-list__item-cta,
  .collections-list__item:focus-visible .collections-list__item-cta {
    opacity: 1;
    transform: translateY(0);
  }

  .collections-list__item:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  @media (min-width: 768px) {
    .collections-list__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
  }

  @media (min-width: 1024px) {
    .collections-list__heading {
      font-size: 2.5rem;
    }

    .collections-list__item-title {
      font-size: 1.5rem;
    }

    .collections-list__item-info {
      padding: 28px 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.collections_list.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.collections_list.settings.heading.label",
      "default": "Shop by collection"
    }
  ],
  "presets": [
    {
      "name": "Collections list"
    }
  ]
}
{% endschema %}
